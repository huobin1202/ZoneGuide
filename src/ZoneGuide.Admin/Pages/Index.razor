@page "/"
@inject IApiService ApiService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@implements IAsyncDisposable

@using Microsoft.AspNetCore.SignalR.Client
@using ZoneGuide.Shared.Models


@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_dashboard != null)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng số địa điểm</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalPOIs</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng số chuyến tham quan</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalTours</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Headset" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng lượt nghe</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalListens</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Người dùng duy nhất</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.UniqueUsers</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        
        <MudItem xs="12" sm="6" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Mobile App Monitoring</MudText>
                    <MudChip T="string" Color="@(_mobileRealtimeConnected ? Color.Success : Color.Warning)" Variant="Variant.Filled" Size="Size.Small">
                        @(_mobileRealtimeConnected ? "LIVE" : "OFFLINE")
                    </MudChip>
                </MudStack>

                <MudGrid Class="mt-2">
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Phiên active</MudText>
                        <MudText Typo="Typo.h5">@(_mobileRealtime?.ActiveSessionCount ?? 0)</MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Đang tracking</MudText>
                        <MudText Typo="Typo.h5">@(_mobileRealtime?.TrackingSessionCount ?? 0)</MudText>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                    @GetMobileRealtimeFooterText()
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-6">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6">Chỉ số hoàn thành</MudText>
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                        @(_dashboard.CompletionRate.ToString("P1"))
                    </MudChip>
                </MudStack>

                <MudGrid>
                    <MudItem xs="12" sm="6">
                        @if (_dashboard.TotalListens > 0)
                        {
                            <MudChart ChartType="ChartType.Donut"
                                      InputData="@_completionChartData"
                                      InputLabels="@_completionChartLabels"
                                      Width="100%"
                                      Height="240px"
                                      ChartOptions="@_donutChartOptions" />
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Chưa có dữ liệu lượt nghe</MudAlert>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudStack Class="dashboard-metric-stack" Spacing="2">
                            <MudPaper Class="dashboard-metric-tile pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Thời lượng nghe trung bình</MudText>
                                <MudText Typo="Typo.h5">@FormatDuration(_dashboard.AverageListenDurationSeconds)</MudText>
                            </MudPaper>
                            <MudPaper Class="dashboard-metric-tile pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Tổng lượt nghe hoàn thành</MudText>
                                <MudText Typo="Typo.h5">@_estimatedCompletedListens</MudText>
                            </MudPaper>
                            <MudPaper Class="dashboard-metric-tile pa-3" Elevation="0">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Lượt nghe chưa hoàn thành</MudText>
                                <MudText Typo="Typo.h5">@_estimatedIncompleteListens</MudText>
                            </MudPaper>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-4">Top địa điểm theo lượt nghe</MudText>
                @if (_dashboard.TopPOIs.Any())
                {
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_topPoiListenSeries"
                              XAxisLabels="@_topPoiLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_barChartOptions" />

                    <MudStack Row="true" Class="mt-3 flex-wrap" Spacing="1">
                        @foreach (var poi in _dashboard.TopPOIs.Take(5))
                        {
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small">
                                @poi.Name: @FormatDuration(poi.AvgDurationSeconds) TB
                            </MudChip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Chưa có dữ liệu địa điểm nổi bật</MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_dashboard.DailyStats.Any())
    {
        <MudPaper Class="pa-4 mt-6" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-4">Hoạt động theo ngày (30 ngày gần nhất)</MudText>
            <MudChart ChartType="ChartType.Line"
                      ChartSeries="@_dailyActivitySeries"
                      XAxisLabels="@_dailyActivityLabels"
                      Width="100%"
                      Height="360px"
                      ChartOptions="@_lineChartOptions" />
        </MudPaper>
    }
}
else
{
    <MudAlert Severity="Severity.Warning">
        Không thể tải dữ liệu bảng điều khiển. Vui lòng kiểm tra kết nối API.
    </MudAlert>
}

@code {
    private DashboardAnalyticsDto? _dashboard;
    private QrMonitoringSnapshotDto? _qrRealtime;
    private HubConnection? _qrHubConnection;
    private bool _qrRealtimeConnected;
    private MobileLiveMonitoringSnapshotDto? _mobileRealtime;
    private HubConnection? _mobileHubConnection;
    private bool _mobileRealtimeConnected;
    private bool _loading = true;
    private int _estimatedCompletedListens;
    private int _estimatedIncompleteListens;
    private double[] _completionChartData = [];
    private string[] _completionChartLabels = [];
    private string[] _topPoiLabels = [];
    private string[] _dailyActivityLabels = [];
    private List<ChartSeries> _topPoiListenSeries = [];
    private List<ChartSeries> _dailyActivitySeries = [];
    private readonly ChartOptions _donutChartOptions = new()
    {
        ShowLegend = true,
        ChartPalette = ["#16a34a", "#f59e0b"]
    };
    private readonly ChartOptions _barChartOptions = new()
    {
        ShowLegend = false,
        YAxisLines = true,
        XAxisLines = false,
        MaxNumYAxisTicks = 6,
        ChartPalette = ["#2563eb"]
    };
    private readonly ChartOptions _lineChartOptions = new()
    {
        ShowLegend = true,
        YAxisLines = true,
        XAxisLines = true,
        MaxNumYAxisTicks = 6,
        LineStrokeWidth = 3,
        InterpolationOption = InterpolationOption.NaturalSpline,
        ChartPalette = ["#2563eb", "#16a34a"]
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var currentUser = await LocalStorage.GetItemAsync<UserDto>("user");
            if (currentUser?.Role == "Contributor")
            {
                Navigation.NavigateTo("/contributor-dashboard");
                return;
            }
        }
        catch
        {
            // Ignore local storage errors and continue loading admin dashboard.
        }

        await LoadDashboard();
        await InitializeQrRealtimeAsync();
        await InitializeMobileRealtimeAsync();
        StateHasChanged();
    }

    private async Task LoadDashboard()
    {
        _loading = true;
        _dashboard = await ApiService.GetDashboardAsync();
        BuildDashboardCharts();
        _loading = false;
    }

    private void BuildDashboardCharts()
    {
        if (_dashboard == null)
        {
            return;
        }

        _estimatedCompletedListens = (int)Math.Round(_dashboard.TotalListens * Math.Clamp(_dashboard.CompletionRate, 0, 1));
        _estimatedIncompleteListens = Math.Max(0, _dashboard.TotalListens - _estimatedCompletedListens);
        _completionChartData = [_estimatedCompletedListens, _estimatedIncompleteListens];
        _completionChartLabels = ["Hoàn thành", "Chưa hoàn thành"];

        var topPois = _dashboard.TopPOIs.Take(5).ToList();
        _topPoiLabels = topPois.Select(p => ShortenLabel(p.Name, 18)).ToArray();
        _topPoiListenSeries =
        [
            new ChartSeries
            {
                Name = "Lượt nghe",
                Data = topPois.Select(p => (double)p.ListenCount).ToArray()
            }
        ];

        var dailyStats = _dashboard.DailyStats
            .OrderBy(s => s.Date)
            .TakeLast(30)
            .ToList();

        _dailyActivityLabels = dailyStats.Select(s => s.Date.ToString("dd/MM")).ToArray();
        _dailyActivitySeries =
        [
            new ChartSeries
            {
                Name = "Lượt nghe",
                Data = dailyStats.Select(s => (double)s.ListenCount).ToArray()
            },
            new ChartSeries
            {
                Name = "Người dùng",
                Data = dailyStats.Select(s => (double)s.UniqueUsers).ToArray()
            }
        ];
    }

    private async Task InitializeQrRealtimeAsync()
    {
        _qrRealtime = await ApiService.GetQrMonitoringSnapshotAsync();

        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:56040";
        var hubUrl = $"{apiBaseUrl.TrimEnd('/')}/hubs/qr-monitor";

        _qrHubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _qrHubConnection.Reconnecting += _ =>
        {
            _qrRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.Reconnected += _ =>
        {
            _qrRealtimeConnected = true;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.Closed += _ =>
        {
            _qrRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.On<QrMonitoringSnapshotDto>("QrMonitorUpdated", snapshot =>
        {
            _qrRealtime = snapshot;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            await _qrHubConnection.StartAsync();
            _qrRealtimeConnected = true;
        }
        catch
        {
            _qrRealtimeConnected = false;
        }
    }

    private string GetRealtimeFooterText()
    {
        if (_qrRealtime == null || !_qrRealtime.LastAccessAtUtc.HasValue)
        {
            return "Chưa ghi nhận truy cập QR";
        }

        var poiText = _qrRealtime.LastPoiId.HasValue ? $"POI #{_qrRealtime.LastPoiId.Value}" : "POI không xác định";
        var localTime = _qrRealtime.LastAccessAtUtc.Value.ToLocalTime();
        return $"Truy cập gần nhất: {poiText} lúc {localTime:dd/MM/yyyy HH:mm:ss}";
    }

    private async Task InitializeMobileRealtimeAsync()
    {
        _mobileRealtime = await ApiService.GetMobileMonitoringSnapshotAsync();

        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:56040";
        var hubUrl = $"{apiBaseUrl.TrimEnd('/')}/hubs/mobile-monitor";

        _mobileHubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _mobileHubConnection.Reconnecting += _ =>
        {
            _mobileRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _mobileHubConnection.Reconnected += _ =>
        {
            _mobileRealtimeConnected = true;
            return InvokeAsync(StateHasChanged);
        };

        _mobileHubConnection.Closed += _ =>
        {
            _mobileRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _mobileHubConnection.On<MobileLiveMonitoringSnapshotDto>("MobileMonitorUpdated", snapshot =>
        {
            _mobileRealtime = snapshot;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            await _mobileHubConnection.StartAsync();
            _mobileRealtimeConnected = true;
        }
        catch
        {
            _mobileRealtimeConnected = false;
        }
    }

    private string GetMobileRealtimeFooterText()
    {
        if (_mobileRealtime == null || !_mobileRealtime.LastUpdatedAtUtc.HasValue)
        {
            return "Chưa ghi nhận phiên mobile";
        }

        var localTime = _mobileRealtime.LastUpdatedAtUtc.Value.ToLocalTime();
        return $"Cập nhật gần nhất lúc {localTime:dd/MM/yyyy HH:mm:ss}";
    }

    private string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 
            ? $"{(int)ts.TotalMinutes}m {ts.Seconds}s" 
            : $"{ts.Seconds}s";
    }

    private static string ShortenLabel(string value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value;
        }

        return $"{value[..Math.Max(0, maxLength - 1)]}…";
    }

    public async ValueTask DisposeAsync()
    {
        if (_qrHubConnection != null)
        {
            await _qrHubConnection.DisposeAsync();
        }
        if (_mobileHubConnection != null)
        {
            await _mobileHubConnection.DisposeAsync();
        }
    }
}
