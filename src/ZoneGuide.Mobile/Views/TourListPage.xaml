<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
             x:Class="ZoneGuide.Mobile.Views.TourListPage"
             x:DataType="vm:TourListViewModel"
             Title="{local:Translate tours_title}">

    <Grid RowDefinitions="*,Auto">
        <RefreshView IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Tours}"
                            SelectionMode="None"
                            Margin="0,8,0,16">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Padding="32"
                                     Spacing="8">
                    <Label Text="🗺️"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="{local:Translate tours_empty_title}"
                           FontSize="16"
                           TextColor="Gray"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Tour">
                    <Frame Margin="16,8"
                           Padding="0"
                           CornerRadius="20"
                           HasShadow="False"
                           BorderColor="#E5E7EB"
                           BackgroundColor="White"
                           IsClippedToBounds="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TourListViewModel}}, Path=ViewDetailCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <Grid RowDefinitions="180,Auto">
                            <Grid Grid.Row="0">
                                <Image Source="{Binding ThumbnailUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                       Aspect="AspectFill"
                                       BackgroundColor="#E5E7EB" />
                                <BoxView Color="#66000000" />
                                <VerticalStackLayout Padding="16"
                                                     Spacing="6"
                                                     VerticalOptions="End">
                                    <Label Text="{Binding Name}"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout Grid.Row="1"
                                                 Padding="16"
                                                 Spacing="14">
                                <Grid ColumnDefinitions="*,*,*"
                                      ColumnSpacing="10">
                                    <Frame Grid.Column="0"
                                           Padding="12,10"
                                           CornerRadius="14"
                                           HasShadow="False"
                                           BorderColor="#E5E7EB"
                                           BackgroundColor="#F9FAFB">
                                        <HorizontalStackLayout Spacing="6"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center">
                                            <Label Text="📍"
                                                   FontSize="16"
                                                   VerticalTextAlignment="Center" />
                                            <Label Text="{Binding POICount}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Frame>

                                    <Frame Grid.Column="1"
                                           Padding="12,10"
                                           CornerRadius="14"
                                           HasShadow="False"
                                           BorderColor="#E5E7EB"
                                           BackgroundColor="#F9FAFB">
                                        <HorizontalStackLayout Spacing="6"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center">
                                            <Label Text="⏱️"
                                                   FontSize="16"
                                                   VerticalTextAlignment="Center" />
                                            <Label Text="{Binding EstimatedDurationMinutes}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Frame>

                                    <Frame Grid.Column="2"
                                           Padding="12,10"
                                           CornerRadius="14"
                                           HasShadow="False"
                                           BorderColor="#E5E7EB"
                                           BackgroundColor="#F9FAFB">
                                        <HorizontalStackLayout Spacing="6"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center">
                                            <Label Text="🚶"
                                                   FontSize="16"
                                                   VerticalTextAlignment="Center" />
                                            <Label Text="{Binding EstimatedDistanceMeters, Converter={StaticResource PreferredDistanceConverter}, ConverterParameter=km}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Frame>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <views:MiniPlayerView Grid.Row="1" />
    </Grid>

</ContentPage>
