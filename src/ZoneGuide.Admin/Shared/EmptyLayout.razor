@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="false" />

<MudLayout>
    <MudMainContent Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#667eea",
            Secondary = "#764ba2",
            AppbarBackground = "#667eea"
        }
    };
}
