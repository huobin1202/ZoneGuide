    private async Task SavePOI()
    {
        var isEditingCurrentTab = _activeTabIndex == 0 && _isEditMode && !string.IsNullOrEmpty(_editingPoiId);

        if (isEditingCurrentTab)
        {
            await _editForm.Validate();
        }
        else
        {
            await _createForm.Validate();
        }
        
        if (!_isValid) return;

        _saving = true;
        try
        {
            if (isEditingCurrentTab)
            {
                var updateDto = new UpdatePOIDto
                {
                    Address = NormalizePoiAddress(_newPoi.Address),
                    Name = _newPoi.Name,
                    ShortDescription = _newPoi.ShortDescription,
                    FullDescription = _newPoi.FullDescription,
                    Latitude = _newPoi.Latitude,
                    Longitude = _newPoi.Longitude,
                    TriggerRadiusMeters = _newPoi.TriggerRadius,
                    ApproachRadius = _newPoi.ApproachRadius,
                    Priority = _newPoi.Priority,
                    Category = _newPoi.Category,
                    ImageUrl = _newPoi.ImageUrl,
                    AudioUrl = _newPoi.AudioUrl,
                    TTSScript = _newPoi.TTSScript,
                    Language = _newPoi.Language,
                    IsActive = _newPoi.IsActive
                };
                var updated = await ApiService.UpdatePOIAsync(_editingPoiId!, updateDto);
                if (updated != null)
                {
                    Snackbar.Add("Cập nhật địa điểm thành công", Severity.Success);
                    _activeTabIndex = 0;
                    _isEditMode = false;
                    _editingPoiId = null;
                    _editDraftPoi = null;
                    _editAddressQuery = "";
                    _editAddressStatus = "";
                    _editSelectedPoiAddressSuggestion = null;
                    _editLastAutoFilledPoiName = null;
                    await JS.InvokeVoidAsync("removeTempMarkerFromPOIMap");
                    await LoadPOIs();
                }
                else
                {
                    Snackbar.Add("Cập nhật thất bại", Severity.Error);
                }
            }
            else
            {
                var createDto = new CreatePOIDto
                {
                    Address = NormalizePoiAddress(_newPoi.Address),
                    Name = _newPoi.Name,
                    ShortDescription = _newPoi.ShortDescription,
                    FullDescription = _newPoi.FullDescription,
                    Latitude = _newPoi.Latitude,
                    Longitude = _newPoi.Longitude,
                    TriggerRadiusMeters = _newPoi.TriggerRadius,
                    ApproachRadius = _newPoi.ApproachRadius,
                    Priority = _newPoi.Priority,
                    Category = _newPoi.Category,
                    ImageUrl = _newPoi.ImageUrl,
                    AudioUrl = _newPoi.AudioUrl,
                    TTSScript = _newPoi.TTSScript,
                    Language = _newPoi.Language
                };
                var created = await ApiService.CreatePOIAsync(createDto);
                if (created != null)
                {
                    Snackbar.Add("Thêm địa điểm thành công", Severity.Success);
                    _activeTabIndex = 0; // Go back to List
                    _newPoi = CreateDefaultPoi();
                    await JS.InvokeVoidAsync("removeTempMarkerFromPOIMap");
                    await LoadPOIs();
                }
                else
                {
                    Snackbar.Add("Thêm thất bại", Severity.Error);
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private Task OnPoiAddressTextChanged(string text)
