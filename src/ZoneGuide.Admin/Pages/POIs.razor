    private async Task ResolvePoiAddressAsync(double lat, double lng)
    {
        try
        {
            using var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"https://nominatim.openstreetmap.org/reverse?format=json&lat={lat.ToString(System.Globalization.CultureInfo.InvariantCulture)}&lon={lng.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
            request.Headers.TryAddWithoutValidation("User-Agent", "ZoneGuide-Admin/1.0");
            request.Headers.TryAddWithoutValidation("Accept-Language", "vi");

            using var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                SetPoiAddressNotFound();
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ReverseGeocodeResult>();
            if (string.IsNullOrWhiteSpace(result?.DisplayName))
            {
                SetPoiAddressNotFound();
                return;
            }

            _newPoi.Address = result.DisplayName;
            _poiAddressQuery = result.DisplayName;
            _poiAddressStatus = "Đã cập nhật địa chỉ từ vị trí trên bản đồ.";
            ApplyAutoPoiName(result.Name, result.DisplayName);
        }
        catch
        {
            SetPoiAddressNotFound();
        }
    }

    private void SetPoiAddressNotFound()
    {
        const string fallback = "Không có địa chỉ";
        _newPoi.Address = fallback;
        _poiAddressQuery = fallback;
        _poiAddressStatus = fallback;
    }

    private void ApplyAutoPoiName(string? candidateName, string? displayName)
    {
        var suggestedName = string.IsNullOrWhiteSpace(candidateName)
            ? ExtractPoiNameFromAddress(displayName)
            : candidateName!.Trim();

        if (string.IsNullOrWhiteSpace(suggestedName))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPoi.Name) ||
            string.Equals(_newPoi.Name, _lastAutoFilledPoiName, StringComparison.Ordinal))
        {
            _newPoi.Name = suggestedName;
            _lastAutoFilledPoiName = suggestedName;
        }
    }

    private static string ExtractPoiNameFromAddress(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return string.Empty;
        }

        var firstPart = displayName.Split(',', 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault();

        return firstPart ?? displayName.Trim();
    }

    private static string DisplayAddressOrFallback(string? address)
        => string.IsNullOrWhiteSpace(address) ? "Không có địa chỉ" : address.Trim();

    private static string GetPoiDescriptionOrFallback(POIDto poi)
    {
        var description = poi.TTSScript ?? poi.FullDescription ?? poi.ShortDescription;
        return string.IsNullOrWhiteSpace(description)
            ? "Chưa có nội dung thuyết minh"
            : description.Trim();
    }

    private static string? NormalizePoiAddress(string? address)
    {
        if (string.IsNullOrWhiteSpace(address))
        {
            return null;
        }

        var trimmed = address.Trim();
        return string.Equals(trimmed, "Không có địa chỉ", StringComparison.OrdinalIgnoreCase) ? trimmed : trimmed;
    }

    private string GetPoiCardClass(POIDto poi)
        => string.Equals(_highlightedPoiId, poi.Id, StringComparison.Ordinal) ? "poi-card-selected" : string.Empty;

    [JSInvokable]
    public async Task OnPoiMarkerSelected(string poiId)
    {
        _highlightedPoiId = poiId;
        await InvokeAsync(StateHasChanged);

        try
        {
            await JS.InvokeVoidAsync("scrollPoiCardIntoView", poiId);
        }
        catch
        {
            // ignore
        }
    }

    [JSInvokable]
    public Task OnPoiMarkerEditRequested(string poiId)
    {
        var poi = _pois.FirstOrDefault(p => p.Id == poiId);
        return poi != null ? OpenEditMode(poi) : Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnPoiMarkerDeleteRequested(string poiId)
    {
        var poi = _pois.FirstOrDefault(p => p.Id == poiId);
        return poi != null ? TogglePoiStatus(poi) : Task.CompletedTask;
    }

    private async Task TogglePoiStatus(POIDto poi)
    {
        var willActivate = !poi.IsActive;
        var confirm = await DialogService.ShowMessageBox(
            "Cập nhật trạng thái địa điểm",
            willActivate
                ? $"Bạn có chắc muốn bật lại '{poi.Name}' không?"
                : $"Bạn có chắc muốn tắt '{poi.Name}' không?",
            yesText: "Xác nhận", cancelText: "Hủy");

        if (confirm == true)
        {
            var success = await ApiService.UpdatePOIAsync(poi.Id, new UpdatePOIDto
            {
                IsActive = willActivate
            });

            if (success != null)
            {
                if (!willActivate && string.Equals(_highlightedPoiId, poi.Id, StringComparison.Ordinal))
                {
                    _highlightedPoiId = null;
                }

                await LoadPOIs();
                Snackbar.Add(willActivate ? "Đã bật địa điểm" : "Đã tắt địa điểm", Severity.Success);
            }
            else
            {
                Snackbar.Add("Không thể cập nhật trạng thái", Severity.Error);
            }
        }
    }

    private async Task UploadImage(IBrowserFile file)
    {
        try
        {
            if (file != null)
            {
                var maxAllowedSize = 512000 * 10; // 5MB
                if(file.Size > maxAllowedSize)
                {
                    Snackbar.Add("File quá lớn (Max 5MB).", Severity.Error);
                    return;
                }
                
                using var stream = file.OpenReadStream(maxAllowedSize);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                
                var bytes = ms.ToArray();
                var base64 = Convert.ToBase64String(bytes);
                var format = file.ContentType;
                
                _newPoi.ImageUrl = $"data:{format};base64,{base64}";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi upload: {ex.Message}", Severity.Error);
        }
    }

