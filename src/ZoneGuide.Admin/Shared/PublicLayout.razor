@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="public-layout">
    <header class="public-header">
        <div class="public-header-content">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit"
                           Class="@(_showBack ? "" : "d-none")" OnClick="GoBack" />
            <MudText Typo="Typo.h6" Class="public-header-title">@Title</MudText>
            <MudSpacer />
        </div>
    </header>

    <main class="public-main">
        @Body
    </main>

    <AudioPlayer />

    <nav class="public-bottom-nav">
        <a href="/home" class="bottom-nav-item @(IsActive("/home"))">
            <svg class="bottom-nav-svg" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
            <span class="bottom-nav-label">Trang chủ</span>
        </a>
        <a href="/map" class="bottom-nav-item @(IsActive("/map"))">
            <svg class="bottom-nav-svg" viewBox="0 0 24 24"><path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/></svg>
            <span class="bottom-nav-label">Bản đồ</span>
        </a>
        <a href="/tour-list" class="bottom-nav-item @(IsActive("/tour-list"))">
            <svg class="bottom-nav-svg" viewBox="0 0 24 24"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
            <span class="bottom-nav-label">Tour</span>
        </a>
        <a href="/more" class="bottom-nav-item @(IsActive("/more"))">
            <svg class="bottom-nav-svg" viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
            <span class="bottom-nav-label">Thêm</span>
        </a>
    </nav>
</div>

<style>
:root {
    --bg-primary: #f6f7fb;
    --bg-card: #ffffff;
    --bg-header: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
    --bg-nav: #ffffff;
    --text-primary: #333333;
    --text-secondary: #666666;
    --text-muted: #999999;
    --border-color: #e0e0e0;
    --shadow-color: rgba(0,0,0,0.1);
    --nav-shadow: rgba(0,0,0,0.1);
}
@@media (prefers-color-scheme: dark) {
    :root {
        --bg-primary: #121212;
        --bg-card: #1e1e1e;
        --bg-header: linear-gradient(135deg, #1565C0 0%, #0D47A1 100%);
        --bg-nav: #1e1e1e;
        --text-primary: #e0e0e0;
        --text-secondary: #aaaaaa;
        --text-muted: #777777;
        --border-color: #333333;
        --shadow-color: rgba(0,0,0,0.3);
        --nav-shadow: rgba(0,0,0,0.3);
    }
}
.public-layout {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: var(--bg-primary);
    position: relative;
}
.public-header {
    background: var(--bg-header);
    color: white;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.public-header-content {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    min-height: 52px;
}
.public-header-title {
    font-weight: 600;
    margin-left: 8px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.public-main {
    flex: 1;
    padding-top: 52px;
    padding-bottom: 72px;
    overflow-y: auto;
}
.public-bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-nav);
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 4px 0;
    padding-bottom: env(safe-area-inset-bottom, 4px);
    box-shadow: 0 -2px 10px var(--nav-shadow);
    z-index: 100;
    height: 64px;
}
.bottom-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: #999;
    padding: 4px 12px;
    border-radius: 8px;
    transition: all 0.2s;
    gap: 2px;
}
.bottom-nav-item.active {
    color: #1976D2;
}
.bottom-nav-svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
}
.bottom-nav-label {
    font-size: 11px;
    font-weight: 500;
}
</style>

@code {
    [Parameter] public string Title { get; set; } = "ZoneGuide";

    private bool _showBack => Navigation.Uri != Navigation.BaseUri;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += (_, _) => StateHasChanged();
    }

    private bool IsActive(string path)
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath;
        if (path == "/home") return uri == "/home" || uri == "/";
        if (path == "/map") return uri == "/map" || uri.StartsWith("/poi-list") || uri.StartsWith("/poi/");
        return uri == path || (path != "" && uri.StartsWith(path));
    }

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }
}
