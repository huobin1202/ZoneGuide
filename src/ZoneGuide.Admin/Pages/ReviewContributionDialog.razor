@using ZoneGuide.Shared.Models
@using System.Globalization
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.RateReview" Class="mr-2" />
            Duyệt đóng góp: @Contribution.Name
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2">Thông tin POI</MudText>
                <MudDivider Class="my-2" />
                <MudText><strong>Tên:</strong> @Contribution.Name</MudText>
                <MudText><strong>Mô tả ngắn:</strong> @(Contribution.ShortDescription ?? "-")</MudText>
                <MudText>
                    <strong>Vị trí:</strong>
                    @if (HasLocation)
                    {
                        <MudLink Href="javascript:void(0)" OnClick="ShowLocationAsync">
                            @_addressDisplay
                        </MudLink>
                    }
                    else
                    {
                        <span>Không có địa chỉ</span>
                    }
                </MudText>
                <MudText><strong>Bán kính kích hoạt:</strong> @Contribution.TriggerRadius m</MudText>
                <MudText><strong>Danh mục:</strong> @(Contribution.Category ?? "-")</MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2">Thông tin người gửi</MudText>
                <MudDivider Class="my-2" />
                <MudText><strong>Người đóng góp:</strong> @Contribution.ContributorName</MudText>
                <MudText><strong>Ngày tạo:</strong> @Contribution.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudText>
                <MudText><strong>Ngày gửi:</strong> @(Contribution.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudText>
                @if (!string.IsNullOrEmpty(Contribution.ContributorNotes))
                {
                    <MudText><strong>Ghi chú:</strong> @Contribution.ContributorNotes</MudText>
                }
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2">Mô tả đầy đủ</MudText>
                <MudDivider Class="my-2" />
                <MudText Style="white-space: pre-wrap;">@(Contribution.FullDescription ?? "-")</MudText>
            </MudItem>
            @if (!string.IsNullOrEmpty(Contribution.ImageUrl))
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2">Hình ảnh</MudText>
                    <MudDivider Class="my-2" />
                    <MudImage Src="@Contribution.ImageUrl" Alt="POI Image" Width="300" Class="rounded" />
                </MudItem>
            }
            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudSelect @bind-Value="decision" Label="Quyết định" Required="true" Variant="Variant.Outlined">
                    <MudSelectItem Value="@POIApprovalStatus.Approved">✅ Duyệt - Tạo POI mới</MudSelectItem>
                    <MudSelectItem Value="@POIApprovalStatus.NeedsRevision">🔄 Yêu cầu chỉnh sửa</MudSelectItem>
                    <MudSelectItem Value="@POIApprovalStatus.Rejected">❌ Từ chối</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="feedback" Label="Phản hồi" Variant="Variant.Outlined"
                              Lines="3" Placeholder="Nhập lý do duyệt/từ chối..." />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@isSaving">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Xác nhận
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public POIContributionDto Contribution { get; set; } = null!;
    
    private POIApprovalStatus decision = POIApprovalStatus.Approved;
    private string? feedback;
    private bool isSaving = false;
    private string _addressDisplay = "Đang tải địa chỉ...";
    private bool HasLocation => Contribution.Latitude.HasValue && Contribution.Longitude.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (!HasLocation)
        {
            _addressDisplay = "Không có địa chỉ";
            return;
        }

        await ResolveAddressAsync();
    }
    
    private async Task Submit()
    {
        isSaving = true;
        try
        {
            var request = new ReviewPOIContributionDto
            {
                ContributionId = Contribution.Id,
                Decision = decision,
                Feedback = feedback
            };
            
            var response = await Http.PostAsJsonAsync("api/contributions/review", request);
            if (response.IsSuccessStatusCode)
            {
                var message = decision switch
                {
                    POIApprovalStatus.Approved => "Đã duyệt và tạo POI mới!",
                    POIApprovalStatus.NeedsRevision => "Đã yêu cầu chỉnh sửa",
                    POIApprovalStatus.Rejected => "Đã từ chối đóng góp",
                    _ => "Đã xử lý"
                };
                Snackbar.Add(message, Severity.Success);
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Lỗi: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }
    
    private void Cancel() => MudDialog?.Cancel();

    private async Task ShowLocationAsync()
    {
        var parameters = new DialogParameters
        {
            { "Contribution", Contribution }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        await DialogService.ShowAsync<ContributionLocationDialog>("Xem vị trí đóng góp", parameters, options);
    }

    private async Task ResolveAddressAsync()
    {
        try
        {
            var address = await JS.InvokeAsync<string>(
                "reverseGeocodeAddress",
                Contribution.Latitude!.Value.ToString(CultureInfo.InvariantCulture),
                Contribution.Longitude!.Value.ToString(CultureInfo.InvariantCulture));
            _addressDisplay = string.IsNullOrWhiteSpace(address) ? "Không có địa chỉ" : address;
        }
        catch
        {
            _addressDisplay = "Không có địa chỉ";
        }
    }
}
