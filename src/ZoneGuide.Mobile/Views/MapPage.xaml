<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.MapPage"
             x:Name="MapPageRoot"
             x:DataType="vm:MapViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid>
        <maps:Map x:Name="MainMap"
                  IsShowingUser="True"
                  MapType="Street" />

        <Border Margin="14,12,14,0"
                VerticalOptions="Start"
                BackgroundColor="White"
                Stroke="#E2E8F0"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="1"
                Padding="14,10">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Label Text="⌕"
                       FontSize="20"
                       TextColor="{StaticResource Gray400}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{local:Translate map_search_placeholder}"
                       FontSize="16"
                       TextColor="{StaticResource Gray500}"
                       VerticalTextAlignment="Center" />
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOpenSearchSheetTapped" />
            </Border.GestureRecognizers>
        </Border>

        <VerticalStackLayout HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,82,18,0"
                         Spacing="10">
            <Button Text="◉"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="18"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding ShowTourGroupMarkersCommand}"
                    SemanticProperties.Hint="Hiển thị POI trong tour hiện tại" />

            <Button Text="⏹"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="16"
                    BackgroundColor="#FFE6E6"
                    TextColor="#B3261E"
                    Command="{Binding StopTourCommand}"
                    IsVisible="{Binding IsTourModeActive}"
                    SemanticProperties.Hint="Dừng tour hiện tại" />

            <Button Text="◎"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="18"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding CenterOnUserCommand}"
                    SemanticProperties.Hint="Định vị vị trí hiện tại" />
        </VerticalStackLayout>

    <Border x:Name="SelectedPoiOverlay"
        BackgroundColor="White"
        Stroke="{StaticResource Primary}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 20"
        Margin="16,0,16,16"
        Padding="12,10"
        VerticalOptions="End"
                IsVisible="{Binding IsSelectedPoiPlayerVisible}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding IsTourPoiListVisible}"
                                 Value="True">
                        <Setter Property="Margin"
                                Value="16,0,16,228" />
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="4"
                                         VerticalOptions="Center">
                        <Label Text="{Binding SelectedPOI.Name}"
                               FontSize="16"
                               FontAttributes="Bold"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />
                        <HorizontalStackLayout Spacing="8">
                            <Border BackgroundColor="#F2EFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8,2">
                                <Label Text="{Binding SelectedPOI.Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                       FontSize="11"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                            <Label Text="{Binding SelectedPoiDistanceDisplay}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            WidthRequest="42"
                            HeightRequest="42"
                            CornerRadius="21"
                            Padding="0"
                            FontSize="18"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            Command="{Binding PlaySelectedPOICommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsSelectedPoiNarrationActive}"
                                         Value="True">
                                <Setter Property="Text"
                                        Value="⏸" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsSelectedPoiNarrationActive}"
                                         Value="False">
                                <Setter Property="Text"
                                        Value="▶" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Grid.Column="2"
                            Text="▢"
                            WidthRequest="42"
                            HeightRequest="42"
                            CornerRadius="21"
                            Padding="0"
                            FontSize="16"
                            BackgroundColor="White"
                            BorderColor="#D1D5DB"
                            BorderWidth="1"
                            TextColor="#374151"
                            Command="{Binding ViewPOIDetailCommand}" />
                </Grid>
        </Border>

        <Border x:Name="TourPoiBottomSheet"
                IsVisible="{Binding IsTourPoiListVisible}"
                VerticalOptions="End"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                Margin="8,0,8,8"
                HeightRequest="220"
                Padding="0,6,0,10">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="6">
                    <Border Grid.Row="0"
                            HorizontalOptions="Center"
                            WidthRequest="52"
                            HeightRequest="6"
                            BackgroundColor="#D1D5DB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3" />

                    <Grid Grid.Row="1"
                          Padding="14,0,14,0"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <Label Text="{Binding ActiveTourName}"
                               FontSize="16"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"
                               VerticalOptions="Center" />

                        <Border Grid.Column="1"
                                BackgroundColor="#F3F4F6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                Padding="10,5"
                                VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="⌖"
                                       FontSize="13" />
                                <Label Text="{Binding ActiveTourPoiCount}"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <CollectionView Grid.Row="2"
                                    ItemsSource="{Binding POIs}"
                                    SelectionMode="None"
                                    Margin="10,0,0,0"
                                    HeightRequest="168">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="10" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Frame WidthRequest="206"
                                       Padding="8"
                                       CornerRadius="16"
                                       HasShadow="False"
                                       BorderColor="#E5E7EB"
                                       BackgroundColor="White">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference MapPageRoot}, Path=BindingContext.SelectPOICommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>

                                    <Grid RowDefinitions="102,Auto"
                                          RowSpacing="8">
                                        <Frame Grid.Row="0"
                                               Padding="0"
                                               CornerRadius="12"
                                               HasShadow="False"
                                               BackgroundColor="#EEF2F7">
                                            <Grid>
                                                <Image Source="{Binding ImageUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                                       Aspect="AspectFill" />
                                            </Grid>
                                        </Frame>

                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="Auto,*"
                                              ColumnSpacing="8">
                                            <Border BackgroundColor="#E8EDFF"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,3"
                                                    VerticalOptions="Start">
                                                <Label Text="{Binding OrderInTour}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}" />
                                            </Border>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </Grid>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
        </Border>

        <BoxView x:Name="SearchSheetBackdrop"
                 IsVisible="False"
                 Opacity="0"
                 BackgroundColor="#66000000">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseSearchSheetTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

    <Border x:Name="MapSearchSheet"
        VerticalOptions="Fill"
        Margin="0"
        Padding="12,8,12,12"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                TranslationY="700">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="8">
                <Border Grid.Row="0"
                        HorizontalOptions="Center"
                        WidthRequest="52"
                        HeightRequest="6"
                        BackgroundColor="#D1D5DB"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 3" />

                <Border Grid.Row="1"
                        BackgroundColor="White"
                        Stroke="#E2E8F0"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1"
                        Padding="12,2">
                    <SearchBar Placeholder="{local:Translate map_search_placeholder}"
                               Text="{Binding SearchQuery}"
                               SearchCommand="{Binding PerformSearchCommand}"
                               BackgroundColor="Transparent" />
                </Border>

                <CollectionView Grid.Row="2"
                                HeightRequest="50"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Padding="14,8"
                                    BackgroundColor="White"
                                    Stroke="#D9E0EA"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding Converter={StaticResource CategoryChipIconConverter}}"
                                           FontSize="14"
                                           TextColor="#111111"
                                           VerticalTextAlignment="Center" />
                                    <Label x:Name="MapChipLabel"
                                           Text="{Binding}"
                                           FontSize="14"
                                           TextColor="{StaticResource Gray900}"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup Name="CommonStates">
                                            <VisualState Name="Normal" />
                                            <VisualState Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor"
                                                            Value="#DDF4E4" />
                                                    <Setter Property="Stroke"
                                                            Value="#34C759" />
                                                    <Setter TargetName="MapChipLabel"
                                                            Property="Label.TextColor"
                                                            Value="#198754" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView Grid.Row="3"
                                x:Name="MapSearchResults"
                                ItemsSource="{Binding POIs}"
                                SelectionMode="Single"
                                SelectionChanged="OnMapSearchResultSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Grid ColumnDefinitions="78,*,Auto"
                                  ColumnSpacing="12"
                                  Padding="4,8">
                                <Frame Grid.Column="0"
                                       WidthRequest="78"
                                       HeightRequest="78"
                                       CornerRadius="14"
                                       Padding="0"
                                       BackgroundColor="#ECEAF8"
                                       IsClippedToBounds="True">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                           Aspect="AspectFill" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           MaxLines="2" />
                                    <Label Text="{Binding Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                           FontSize="14"
                                           TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="28"
                                       TextColor="{StaticResource Gray400}"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}" />
    </Grid>

</ContentPage>
