<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Primary}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Padding="20,28,20,22">
            <Label Text="{local:Translate settings_title}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White" />
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16"
                                 Padding="16,14,16,30">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{local:Translate settings_audio}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Frame Padding="16"
                           CornerRadius="18"
                           BackgroundColor="White">
                        <VerticalStackLayout Spacing="16">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Text="{local:Translate settings_language}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}" />
                                <Picker Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        ItemsSource="{Binding AvailableLanguages}"
                                        ItemDisplayBinding="{Binding DisplayName}"
                                        SelectedItem="{Binding SelectedLanguageOption}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Text="{local:Translate settings_voice}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}" />
                                <Picker Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        ItemsSource="{Binding AvailableVoices}"
                                        SelectedItem="{Binding SelectedVoice}" />
                            </Grid>

                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Tốc độ đọc"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding TtsSpeed, StringFormat='{0:F1}x'}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>
                                <Slider Grid.Row="1"
                                        Minimum="0.5"
                                        Maximum="2.0"
                                        Value="{Binding TtsSpeed}" />
                            </Grid>

                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Âm lượng"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Volume, StringFormat='{0:P0}'}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>
                                <Slider Grid.Row="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding Volume}" />
                            </Grid>

                                <Button Text="{local:Translate settings_test_voice}"
                                    BackgroundColor="{StaticResource Secondary}"
                                    Command="{Binding TestTTSCommand}" />
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="GPS và vị trí"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Frame Padding="16"
                           CornerRadius="18"
                           BackgroundColor="White">
                        <VerticalStackLayout Spacing="16">
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Text="Độ chính xác GPS"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}" />
                                <Picker Grid.Row="1"
                                        SelectedIndex="{Binding GpsAccuracyIndex}">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Thấp (tiết kiệm pin)</x:String>
                                            <x:String>Trung bình</x:String>
                                            <x:String>Cao (chính xác nhất)</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Grid>

                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Bán kính kích hoạt"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding TriggerRadius, StringFormat='{0:F0}m'}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>
                                <Slider Grid.Row="1"
                                        Minimum="10"
                                        Maximum="200"
                                        Value="{Binding TriggerRadius}" />
                            </Grid>

                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Bán kính cảnh báo"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding ApproachRadius, StringFormat='{0:F0}m'}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>
                                <Slider Grid.Row="1"
                                        Minimum="50"
                                        Maximum="500"
                                        Value="{Binding ApproachRadius}" />
                            </Grid>

                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="Thời gian chờ"
                                           FontSize="14" />
                                    <Label Grid.Column="1"
                                           Text="{Binding CooldownSeconds, StringFormat='{0}s'}"
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </Grid>
                                <Slider Grid.Row="1"
                                        Minimum="60"
                                        Maximum="600"
                                        Value="{Binding CooldownSeconds}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="Hành vi"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Frame Padding="16"
                           CornerRadius="18"
                           BackgroundColor="White">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Tự động phát khi vào vùng"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding AutoPlayOnEnter}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Thông báo khi đến gần"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding NotifyOnApproach}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Theo dõi ở nền"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding BackgroundTracking}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Chế độ tiết kiệm pin"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding BatterySaverMode}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Chế độ Offline"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding OfflineMode}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{local:Translate settings_sync}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Frame Padding="16"
                           CornerRadius="18"
                           BackgroundColor="White">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding LastSyncTime, StringFormat='Lần cuối: {0:dd/MM/yyyy HH:mm}'}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}"
                                   IsVisible="{Binding LastSyncTime, Converter={StaticResource IsNotNullConverter}}" />

                            <Button Text="{Binding IsSyncing, Converter={StaticResource SyncButtonTextConverter}}"
                                    Command="{Binding SyncDataCommand}"
                                    IsEnabled="{Binding IsSyncing, Converter={StaticResource InverseBoolConverter}}" />

                                <Button Text="{local:Translate settings_upload_analytics}"
                                    BackgroundColor="{StaticResource Secondary}"
                                    Command="{Binding UploadAnalyticsCommand}" />
                        </VerticalStackLayout>
                    </Frame>
                </VerticalStackLayout>

                <Frame Padding="16"
                       CornerRadius="18"
                       BackgroundColor="White">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Khác"
                               FontSize="18"
                               FontAttributes="Bold" />
                        <Button Text="Xóa cache"
                                BackgroundColor="{StaticResource Gray500}"
                                Command="{Binding ClearCacheCommand}" />
                    </VerticalStackLayout>
                </Frame>

              <Button Text="{local:Translate settings_save}"
                        HeightRequest="56"
                        CornerRadius="24"
                        FontSize="18"
                        Margin="0,4,0,10"
                        Command="{Binding SaveSettingsCommand}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
