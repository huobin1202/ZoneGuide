<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.MapPage"
             x:DataType="vm:MapViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Primary}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Padding="20,28,20,24">
            <VerticalStackLayout Spacing="18">
                    <Label Text="{local:Translate map_title}"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White" />

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 18"
                        Padding="8,0">
                    <SearchBar Placeholder="{local:Translate map_search_placeholder}"
                               Text="{Binding SearchQuery}"
                               SearchCommand="{Binding PerformSearchCommand}"
                               BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,12,0,0">
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True"
                      MapType="Street" />

                <VerticalStackLayout HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,18,18,0"
                         Spacing="10">
                <Button Text="◉"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="18"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding ShowAllMarkersCommand}"
                    SemanticProperties.Hint="Hiển thị tất cả marker" />

                <Button Text="◎"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="18"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding CenterOnUserCommand}"
                    SemanticProperties.Hint="Định vị vị trí hiện tại" />
                </VerticalStackLayout>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 22"
                    Margin="16,0,16,16"
                    Padding="14"
                    VerticalOptions="End"
                    IsVisible="{Binding SelectedPOI, Converter={StaticResource IsNotNullConverter}}">
                                <Grid ColumnDefinitions="*,Auto"
                                            RowDefinitions="Auto,*"
                                            ColumnSpacing="12"
                                            RowSpacing="8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding SelectedPOI.Name}"
                               FontSize="18"
                               FontAttributes="Bold" />
                        <Label Text="{Binding SelectedPOI.ShortDescription}"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               MaxLines="2" />
                        <HorizontalStackLayout Spacing="8">
                            <Border BackgroundColor="#F2EFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="8,2">
                                    <Label Text="{Binding SelectedPOI.Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                       FontSize="11"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                            <Label Text="{Binding SelectedPOI.Priority, StringFormat='Ưu tiên {0}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                            <Button Grid.Column="1"
                                Grid.Row="0"
                                Text="✕"
                                WidthRequest="34"
                                HeightRequest="34"
                                CornerRadius="17"
                                Padding="0"
                                FontSize="13"
                                BackgroundColor="#EFEAFD"
                                TextColor="{StaticResource Primary}"
                                Command="{Binding DismissSelectedPOICommand}" />

                    <VerticalStackLayout Grid.Column="1"
                                     Grid.Row="1"
                                         Spacing="10"
                                         VerticalOptions="Center">
                        <Button Text="▶"
                                WidthRequest="46"
                                HeightRequest="46"
                                CornerRadius="23"
                                Padding="0"
                                FontSize="16"
                                Command="{Binding PlaySelectedPOICommand}" />
                        <Button Text="↗"
                                WidthRequest="40"
                                HeightRequest="40"
                                CornerRadius="20"
                                Padding="0"
                                FontSize="15"
                                BackgroundColor="#EEE9FF"
                                TextColor="{StaticResource Primary}"
                                Command="{Binding NavigateToPOICommand}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="{StaticResource Primary}" />
        </Grid>
    </Grid>

</ContentPage>
