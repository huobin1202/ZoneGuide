<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.MapPage"
             x:Name="MapPageRoot"
             x:DataType="vm:MapViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid>
        <maps:Map x:Name="MainMap"
                  IsShowingUser="False"
                  MapType="Street" />

        <Border Margin="14,12,14,0"
                VerticalOptions="Start"
                BackgroundColor="White"
        Stroke="#000000"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="1"
                Padding="14,10">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Label Text="⌕"
                       FontSize="20"
                       TextColor="{StaticResource Gray400}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{local:Translate map_search_placeholder}"
                       FontSize="16"
                       TextColor="{StaticResource Gray500}"
                       VerticalTextAlignment="Center" />
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOpenSearchSheetTapped" />
            </Border.GestureRecognizers>
        </Border>

        <VerticalStackLayout HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,82,18,0"
                         Spacing="10">
            <Button Text="◉"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="18"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding ShowTourGroupMarkersCommand}"
                    SemanticProperties.Hint="Hiển thị POI trong tour hiện tại" />

            <Button Text="⏹"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="16"
                    BackgroundColor="#FFE6E6"
                    TextColor="#B3261E"
                    Command="{Binding StopTourCommand}"
                    IsVisible="{Binding IsTourModeActive}"
                    SemanticProperties.Hint="Dừng tour hiện tại" />

            <Button Text="➤"
                    WidthRequest="48"
                    HeightRequest="48"
                    CornerRadius="24"
                    Padding="0"
                    FontSize="20"
                    Rotation="-45"
                    BackgroundColor="White"
                    TextColor="{StaticResource Primary}"
                    Command="{Binding CenterOnUserCommand}"
                    SemanticProperties.Hint="Định vị vị trí hiện tại" />
        </VerticalStackLayout>

        <Button x:Name="TourRecenterButton"
                Text="➤"
                WidthRequest="48"
                HeightRequest="48"
                CornerRadius="24"
                Padding="0"
                FontSize="22"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="0"
                BackgroundColor="White"
                BorderColor="#1664D6"
                BorderWidth="2"
                TextColor="#1664D6"
                IsVisible="False"
                Command="{Binding CenterOnUserCommand}"
                SemanticProperties.Hint="Chỉ hướng vị trí hiện tại khi nằm ngoài vùng bản đồ đang hiển thị" />

        <Border x:Name="SelectedPoiOverlay"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Margin="16,0,16,16"
                Padding="10,8"
                VerticalOptions="End"
                IsVisible="{Binding IsSelectedPoiPlayerVisible}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ViewPOIDetailCommand}" />
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="92,*,Auto,Auto"
                  ColumnSpacing="12">
                <Grid WidthRequest="92"
                      HeightRequest="70"
                      VerticalOptions="Center">
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#E5E7EB">
                        <Image Aspect="AspectFill">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource PreferredPoiImageSourceConverter}">
                                    <Binding Path="SelectedPOI.ImagePath" />
                                    <Binding Path="SelectedPOI.ImageUrl" />
                                </MultiBinding>
                            </Image.Source>
                        </Image>
                    </Border>

                    <Border IsVisible="{Binding IsTourModeActive}"
                            BackgroundColor="#99111827"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,4,4"
                            Padding="6,2">
                        <HorizontalStackLayout Spacing="3">
                            <Label Text="➤"
                                   FontSize="9"
                                   Rotation="-45"
                                   TextColor="White"
                                   VerticalTextAlignment="Center" />
                            <Label Text="{Binding SelectedPoiDistanceDisplay}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border BackgroundColor="#E91E63"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 8"
                            Padding="8,1"
                            IsVisible="{Binding IsTourModeActive}"
                            HorizontalOptions="Start"
                            VerticalOptions="End"
                            Margin="4,0,0,3">
                        <Label Text="{Binding SelectedPOI.OrderInTour}"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </Border>
                </Grid>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     VerticalOptions="Center">
                    <Label Text="{Binding SelectedPOI.Name}"
                          FontSize="16"
                           FontAttributes="Bold"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <HorizontalStackLayout Spacing="6">
                        <Label Text="➤"
                               FontSize="11"
                               Rotation="-45"
                               TextColor="#6B7280"
                               VerticalTextAlignment="Center" />
                        <Label Text="{Binding SelectedPoiDistanceDisplay}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#4B5563"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <BoxView Grid.Column="2"
                         WidthRequest="1"
                         Margin="0,8"
                         Color="#E5E7EB" />

                <Button Grid.Column="3"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="12"
                        Padding="0"
                        FontSize="20"
                        BackgroundColor="White"
                        TextColor="#111827"
                        BorderWidth="0"
                        Text="▶"
                        Command="{Binding PlaySelectedPOICommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsSelectedPoiNarrationActive}"
                                     Value="True">
                            <Setter Property="Text"
                                    Value="⏸" />
                            <Setter Property="Command"
                                    Value="{Binding StopNarrationAndBlockReplayCommand}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsSelectedPoiNarrationPaused}"
                                     Value="True">
                            <Setter Property="Text"
                                    Value="▶" />
                            <Setter Property="Command"
                                    Value="{Binding PlaySelectedPOICommand}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="TourPoiBottomSheet"
                IsVisible="{Binding IsTourPoiListVisible}"
                VerticalOptions="End"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                Margin="0"
                HeightRequest="296"
                Padding="0,8,0,12">
                <Grid RowDefinitions="Auto,Auto,*"
                    RowSpacing="10">
                    <Grid Grid.Row="0"
                          HeightRequest="28">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnTourSheetPanUpdated" />
                        </Grid.GestureRecognizers>

                        <Border HorizontalOptions="Center"
                                VerticalOptions="Center"
                                WidthRequest="90"
                                HeightRequest="10"
                                BackgroundColor="#D1D5DB"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 5" />
                    </Grid>

                          <Grid Grid.Row="1"
                                  Padding="16,0,16,0"
                          ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                        <Label Text="{Binding ActiveTourName}"
                                         FontSize="18"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"
                               VerticalOptions="Center" />

                        <Border Grid.Column="1"
                                BackgroundColor="#E5E7EB"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="9,5"
                                VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="5"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <Label Text="⌖"
                                       FontSize="13"
                                       VerticalTextAlignment="Center" />
                                <Label Text="{Binding ActiveTourPoiCount}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <CollectionView x:Name="TourPoiCollectionView"
                                    Grid.Row="2"
                                    ItemsSource="{Binding POIs}"
                                    SelectionMode="None"
                                    Margin="10,0,0,0"
                                    HeightRequest="214">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.Header>
                            <Grid ColumnDefinitions="Auto,Auto"
                                  Margin="0,0,10,0"
                                  ColumnSpacing="8">
                                <Border WidthRequest="108"
                                        Padding="10"
                                        BackgroundColor="White"
                                        Stroke="#D1D5DB"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference MapPageRoot}, Path=BindingContext.ShowStartTourCommand}" />
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout Spacing="10"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="Center">
                                        <Border WidthRequest="56"
                                                HeightRequest="56"
                                                Padding="0"
                                                BackgroundColor="#1664D6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 28">
                                            <Label Text="🗺"
                                                   FontSize="24"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>

                                        <Label Text="Show Start"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="#374151" />
                                    </VerticalStackLayout>
                                </Border>

                                <Label Grid.Column="1"
                                       Text="···▶"
                                       FontSize="16"
                                       TextColor="#9CA3AF"
                                       VerticalTextAlignment="Center"
                                       VerticalOptions="Center" />
                            </Grid>
                        </CollectionView.Header>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Border WidthRequest="176"
                                        HeightRequest="202"
                                        Padding="7"
                                        BackgroundColor="White"
                                        Stroke="#E5E7EB"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource PoiMatchConverter}">
                                                    <Binding Source="{x:Reference MapPageRoot}"
                                                             Path="BindingContext.SelectedPOI.Id" />
                                                    <Binding Path="Id" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="Stroke"
                                                    Value="#E91E63" />
                                            <Setter Property="StrokeThickness"
                                                    Value="4" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference MapPageRoot}, Path=BindingContext.SelectPOICommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="104,*"
                                        RowSpacing="7">
                                        <Grid Grid.Row="0">
                                            <Border Padding="0"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 12"
                                                    BackgroundColor="#E5E7EB">
                                                <Image Aspect="AspectFill">
                                                    <Image.Source>
                                                        <MultiBinding Converter="{StaticResource PreferredPoiImageSourceConverter}">
                                                            <Binding Path="ImagePath" />
                                                            <Binding Path="ImageUrl" />
                                                        </MultiBinding>
                                                    </Image.Source>
                                                </Image>
                                            </Border>

                                            <Border HorizontalOptions="End"
                                                    VerticalOptions="End"
                                                    Margin="0,0,6,6"
                                                    Padding="6,3"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 9"
                                                    BackgroundColor="#99111827">
                                                <HorizontalStackLayout Spacing="3">
                                                    <Label Text="➤"
                                                           FontSize="10"
                                                           Rotation="-45"
                                                           TextColor="White"
                                                           VerticalTextAlignment="Center" />
                                                    <Label FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="White"
                                                           VerticalTextAlignment="Center">
                                                        <Label.Text>
                                                            <MultiBinding Converter="{StaticResource PoiDistanceFromLocationConverter}">
                                                                <Binding Source="{x:Reference MapPageRoot}"
                                                                         Path="BindingContext.UserLocation" />
                                                                <Binding Path="Latitude" />
                                                                <Binding Path="Longitude" />
                                                            </MultiBinding>
                                                        </Label.Text>
                                                    </Label>
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              ColumnDefinitions="Auto,*"
                                                ColumnSpacing="7">
                                            <Border BackgroundColor="#E91E63"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8"
                                                    Padding="8,3"
                                                    VerticalOptions="Start">
                                                <Label Text="{Binding OrderInTour}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="White" />
                                            </Border>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
        </Border>

        <BoxView x:Name="SearchSheetBackdrop"
                 IsVisible="False"
                 Opacity="0"
                 BackgroundColor="#66000000">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseSearchSheetTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

    <Border x:Name="MapSearchSheet"
        IsVisible="False"
        VerticalOptions="Fill"
        Margin="0"
        Padding="12,8,12,12"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                TranslationY="700">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="8">
                <Border Grid.Row="0"
                        HorizontalOptions="Center"
                        WidthRequest="52"
                        HeightRequest="6"
                        BackgroundColor="#D1D5DB"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 3" />

                <Border Grid.Row="1"
                        BackgroundColor="White"
            Stroke="#000000"
                        StrokeShape="RoundRectangle 20"
                        StrokeThickness="1"
                        Padding="12,2">
                    <SearchBar Placeholder="{local:Translate map_search_placeholder}"
                               Text="{Binding SearchQuery}"
                               SearchCommand="{Binding PerformSearchCommand}"
                               BackgroundColor="Transparent" />
                </Border>

                <CollectionView Grid.Row="2"
                                HeightRequest="50"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Border Padding="14,8"
                                    BackgroundColor="White"
                                    Stroke="#D9E0EA"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding Converter={StaticResource CategoryChipIconConverter}}"
                                           FontSize="14"
                                           TextColor="#111111"
                                           VerticalTextAlignment="Center" />
                                    <Label x:Name="MapChipLabel"
                                           Text="{Binding}"
                                           FontSize="14"
                                           TextColor="{StaticResource Gray900}"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup Name="CommonStates">
                                            <VisualState Name="Normal" />
                                            <VisualState Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor"
                                                            Value="#DDF4E4" />
                                                    <Setter Property="Stroke"
                                                            Value="#34C759" />
                                                    <Setter TargetName="MapChipLabel"
                                                            Property="Label.TextColor"
                                                            Value="#198754" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView Grid.Row="3"
                                x:Name="MapSearchResults"
                                ItemsSource="{Binding POIs}"
                                SelectionMode="Single"
                                SelectionChanged="OnMapSearchResultSelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Grid ColumnDefinitions="78,*,Auto"
                                  ColumnSpacing="12"
                                  Padding="4,8">
                                <Frame Grid.Column="0"
                                       WidthRequest="78"
                                       HeightRequest="78"
                                       CornerRadius="14"
                                       Padding="0"
                                       BackgroundColor="#ECEAF8"
                                       IsClippedToBounds="True">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                           Aspect="AspectFill" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           MaxLines="2" />
                                    <Label Text="{Binding Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                           FontSize="14"
                                           TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="28"
                                       TextColor="{StaticResource Gray400}"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Border x:Name="MapZoomControls"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,16,16"
                BackgroundColor="#F8FAFC"
                Stroke="#D1D5DB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="4">
            <VerticalStackLayout Spacing="2">
                <Button Text="+"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="12"
                        Padding="0"
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="#111827"
                        Clicked="OnZoomInClicked" />

                <BoxView HeightRequest="1"
                         Margin="4,0"
                         Color="#E5E7EB" />

                <Button Text="−"
                        WidthRequest="44"
                        HeightRequest="44"
                        CornerRadius="12"
                        Padding="0"
                        FontSize="24"
                        FontAttributes="Bold"
                        BackgroundColor="Transparent"
                        TextColor="#111827"
                        Clicked="OnZoomOutClicked" />
            </VerticalStackLayout>
        </Border>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}" />
    </Grid>

</ContentPage>
