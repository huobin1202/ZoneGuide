<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
                         xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
             x:Class="ZoneGuide.Mobile.Views.POIDetailPage"
             x:DataType="vm:POIDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

        <Grid RowDefinitions="300,*">
        <Grid Grid.Row="0"
              HeightRequest="300">
            <Image Source="{Binding ImageSource}"
                   Aspect="AspectFill" />

            <BoxView Color="#66000000" />

            <Grid Padding="16,26,16,18"
                                    RowDefinitions="Auto,*,Auto"
                                    ZIndex="3">
                <Button Grid.Row="0"
                    Text="←"
                    WidthRequest="46"
                        HeightRequest="46"
                    CornerRadius="23"
                    FontSize="22"
                    Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        BackgroundColor="#66FFFFFF"
                        TextColor="White"
                        SemanticProperties.Hint="{local:Translate poi_detail_back}"
                        Command="{Binding BackCommand}" />
            </Grid>
        </Grid>

        <Button Grid.Row="0"
                Text="{local:Translate poi_detail_play_button}"
                HeightRequest="54"
                WidthRequest="170"
                CornerRadius="27"
                Margin="18,0,0,-26"
                HorizontalOptions="Start"
                VerticalOptions="End"
        BackgroundColor="#111111"
        TextColor="White"
                FontAttributes="Bold"
                Command="{Binding TogglePlayerPanelCommand}"
                ZIndex="10" />

    <ScrollView Grid.Row="1"
        Margin="0,0,0,0"
        VerticalScrollBarVisibility="Never"
        HorizontalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20,36,20,116"
                                 Spacing="14">
                <Label Text="{Binding CurrentPoi.Name}"
                       FontSize="44"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gray900}"
                       LineBreakMode="WordWrap" />

                <Border BackgroundColor="#CDD2DA"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        Padding="12,9"
                        HorizontalOptions="Start">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🏷"
                               FontSize="14"
                               VerticalTextAlignment="Center"
                               TextColor="#1F2937" />
                        <Label Text="{Binding CurrentPoi.Category, Converter={StaticResource LocalizedCategoryConverter}}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#1F2937"
                               VerticalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </HorizontalStackLayout>
                </Border>

                <Label Text="{Binding CurrentPoi.TTSScript}"
                       FontSize="19"
              TextColor="{StaticResource Gray600}"
                       LineHeight="1.45" />

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        Padding="0">
                    <Grid RowDefinitions="220,Auto">
                        <maps:Map x:Name="MiniPoiMap"
                                  Grid.Row="0"
                                  IsShowingUser="False"
                                  IsTrafficEnabled="False"
                                  IsScrollEnabled="False"
                                  IsZoomEnabled="False" />

                        <Grid Grid.Row="1"
                              Padding="14,10"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="8"
                              BackgroundColor="White">
                            <Label Text="⌖"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Primary}" />
                            <Label Grid.Column="1"
                                   Text="{local:Translate poi_detail_open_map_hint}"
                                   FontSize="13"
                                   TextColor="#374151"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenMapCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        Padding="18"
                        IsVisible="{Binding Distance, Converter={StaticResource IsNotNullConverter}}">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="14" />
               <Label Text="{Binding Distance, Converter={StaticResource PreferredDistanceConverter}, ConverterParameter=prefix}"
                               FontSize="14"
                               TextColor="{StaticResource Primary}" />
                    </HorizontalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="{local:Translate poi_detail_navigate}"
                            HeightRequest="52"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="White"
                            Command="{Binding NavigateCommand}" />

                    <Button Grid.Column="1"
                            Text="{local:Translate poi_detail_share}"
                            HeightRequest="52"
                            CornerRadius="16"
                            BackgroundColor="#4B5563"
                            TextColor="White"
                            Command="{Binding ShareCommand}" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                Margin="16,0,16,16"
                VerticalOptions="End"
                BackgroundColor="#111111"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                Padding="12,10"
                IsVisible="False"
                ZIndex="20">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="10">
                <Slider Grid.Column="0"
                        Minimum="0"
                        Maximum="1"
                        Value="{Binding Progress}"
                        IsEnabled="False"
                        ThumbColor="#F97316"
                        MinimumTrackColor="#F97316"
                        MaximumTrackColor="#6B7280"
                        HeightRequest="26"
                        VerticalOptions="Center" />

                <Button Grid.Column="1"
                        Text="⏹"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Padding="0"
                        FontSize="16"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        Command="{Binding StopCommand}" />

        <Button Grid.Column="2"
            Text="↺10"
            WidthRequest="46"
            HeightRequest="40"
            CornerRadius="20"
            Padding="0"
            FontSize="12"
            FontAttributes="Bold"
            BackgroundColor="#2A2A2A"
            TextColor="White"
            Command="{Binding Rewind10SecondsCommand}" />

        <Button Grid.Column="3"
                        Text="✕"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Padding="0"
                        FontSize="14"
                        BackgroundColor="#2A2A2A"
                        TextColor="White"
                        Command="{Binding HidePlayerPanelCommand}" />
            </Grid>
        </Border>

        <views:MiniPlayerView Grid.RowSpan="2"
                              VerticalOptions="End"
                              ZIndex="25" />
    </Grid>

</ContentPage>
