    private async Task InitializeMap()
    {
        try
        {
            var activePois = _allPoisForMap.Where(p => p.IsActive).ToList();
            var manageablePoiIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var contrib in _myContributions)
            {
                if (contrib.OriginalPOIId.HasValue)
                {
                    manageablePoiIds.Add(contrib.OriginalPOIId.Value.ToString());
                }

                manageablePoiIds.Add(contrib.Id.ToString());
            }

            double centerLat = activePois.Any() ? activePois.Average(p => p.Latitude) : 10.762622;
            double centerLng = activePois.Any() ? activePois.Average(p => p.Longitude) : 106.660172;

            var poiData = activePois.Select(p => new
            {
                id = p.Id,
                name = p.Name,
                lat = p.Latitude,
                lng = p.Longitude,
                description = p.TTSScript ?? "",
                thumbnailUrl = p.ImageUrl,
                category = p.Category,
                isActive = p.IsActive,
                audioUrl = p.AudioUrl,
                isDraft = false,
                isContribution = false,
                canManage = manageablePoiIds.Contains(p.Id)
            }).ToList();

            // Thêm các đóng góp chưa duyệt (nháp) của chính user này vào bản đồ
            var myDrafts = _myContributions.Where(m => m.Status != POIApprovalStatus.Approved.ToString());
            foreach (var draft in myDrafts)
            {
                poiData.Add(new
                {
                    id = draft.Id.ToString(),
                    name = $"{draft.Name} (Nháp)",
                    lat = draft.Latitude ?? 0.0,
                    lng = draft.Longitude ?? 0.0,
                    description = draft.TTSScript ?? "",
                    thumbnailUrl = draft.ImageUrl,
                    category = draft.Category,
                    isActive = false,
                    audioUrl = (string?)null,
                    isDraft = true,
                    isContribution = true,
                    canManage = true
                });
            }

            await JS.InvokeVoidAsync("initPOIMap", "contributor-poi-map", centerLat, centerLng, poiData, _dotNetRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Could not center map: " + ex.Message);
        }
    }

