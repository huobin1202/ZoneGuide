@using ZoneGuide.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
            Lịch sử duyệt
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (histories.Count == 0)
        {
            <MudText>Chưa có lịch sử</MudText>
        }
        else
        {
            <MudTimeline TimelinePosition="TimelinePosition.Start">
                @foreach (var history in histories)
                {
                    <MudTimelineItem Color="@GetStatusColor(history.NewStatus)" Size="Size.Small">
                        <ItemContent>
                            <MudText Typo="Typo.body2">
                                <strong>@GetStatusText(history.OldStatus)</strong> → <strong>@GetStatusText(history.NewStatus)</strong>
                            </MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @history.ActionByName - @history.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </MudText>
                            @if (!string.IsNullOrEmpty(history.Notes))
                            {
                                <MudText Typo="Typo.body2" Class="mt-1">@history.Notes</MudText>
                            }
                        </ItemContent>
                    </MudTimelineItem>
                }
            </MudTimeline>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public int ContributionId { get; set; }
    
    private List<POIApprovalHistoryDto> histories = new();
    private bool isLoading = true;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }
    
    private async Task LoadHistory()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<POIApprovalHistoryDto>>($"api/contributions/{ContributionId}/history");
            histories = response ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private void Cancel() => MudDialog?.Cancel();
    
    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "NeedsRevision" => Color.Info,
        _ => Color.Default
    };
    
    private string GetStatusText(string status) => status switch
    {
        "Draft" => "Bản nháp",
        "Pending" => "Chờ duyệt",
        "Approved" => "Đã duyệt",
        "Rejected" => "Từ chối",
        "NeedsRevision" => "Cần sửa",
        _ => status
    };
}
