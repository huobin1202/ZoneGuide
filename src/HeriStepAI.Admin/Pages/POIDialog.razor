@inject IApiService ApiService
@inject IJSRuntime JS

<MudDialog Style="max-width: 900px;">
    <DialogContent>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-3">
            <MudTabPanel Text="Thông tin" Icon="@Icons.Material.Filled.Info">
                <MudForm @ref="_form" @bind-IsValid="_isValid">
                    <MudTextField @bind-Value="_model.Name" Label="Tên POI" Required="true" 
                                  RequiredError="Tên là bắt buộc" Class="mb-3" />
                    
                    <MudTextField @bind-Value="_model.ShortDescription" Label="Mô tả ngắn" 
                                  Lines="2" Class="mb-3" />
                    
                    <MudTextField @bind-Value="_model.FullDescription" Label="Mô tả chi tiết" 
                                  Lines="3" Class="mb-3" />
                    
                    <MudText Typo="Typo.subtitle2" Class="mb-2 mt-3">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" />
                        Vị trí (Click tab "Chọn trên Map" để chọn nhanh)
                    </MudText>
                    <MudGrid>
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_model.Latitude" Label="Vĩ độ (Latitude)" Required="true"
                                             Min="-90" Max="90" Step="0.000001" Format="F6" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_model.Longitude" Label="Kinh độ (Longitude)" Required="true"
                                             Min="-180" Max="180" Step="0.000001" Format="F6" />
                        </MudItem>
                    </MudGrid>
                    
                    <MudGrid Class="mt-3">
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_model.TriggerRadiusMeters" 
                                             Label="Bán kính kích hoạt (m)" Min="10" Max="1000" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudNumericField @bind-Value="_model.Priority" Label="Độ ưu tiên" Min="1" Max="100" />
                        </MudItem>
                    </MudGrid>
                    
                    <MudTextField @bind-Value="_model.Category" Label="Danh mục" Class="mt-3" 
                                  Placeholder="VD: Di tích, Bảo tàng, Công viên..." />
                    
                    <MudTextField @bind-Value="_model.ImageUrl" Label="URL Hình ảnh" Class="mt-3" />
                    
                    <MudTextField @bind-Value="_model.AudioUrl" Label="URL Audio thuyết minh" Class="mt-3" />
                    
                    @if (!string.IsNullOrEmpty(_model.AudioUrl))
                    {
                        <MudNumericField @bind-Value="_model.AudioDurationSeconds" 
                                         Label="Thời lượng Audio (giây)" Class="mt-3" Min="0" />
                    }
                    
                    <MudSwitch @bind-Value="_model.IsActive" Label="Kích hoạt" Color="Color.Primary" Class="mt-3" />
                </MudForm>
            </MudTabPanel>
            
            <MudTabPanel Text="Chọn trên Map" Icon="@Icons.Material.Filled.Map" OnClick="InitPickerMap">
                <MudText Typo="Typo.body2" Class="mb-2" Color="Color.Primary">
                    <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Small" />
                    Click vào bản đồ để chọn vị trí. Kéo marker để điều chỉnh.
                </MudText>
                
                <MudPaper Elevation="2" Class="mb-3" Style="height: 350px; position: relative;">
                    <div id="poi-picker-map" style="width: 100%; height: 100%; border-radius: 4px;"></div>
                </MudPaper>
                
                <MudGrid>
                    <MudItem xs="5">
                        <MudTextField @bind-Value="_model.Latitude" Label="Vĩ độ" ReadOnly="true" 
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.NorthEast" />
                    </MudItem>
                    <MudItem xs="5">
                        <MudTextField @bind-Value="_model.Longitude" Label="Kinh độ" ReadOnly="true"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.East" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                   OnClick="UseCurrentLocation" StartIcon="@Icons.Material.Filled.MyLocation">
                            GPS
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudTextField @bind-Value="_searchAddress" Label="Tìm địa chỉ" Class="mt-3"
                              Placeholder="Nhập địa chỉ và nhấn Enter..."
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                              OnKeyDown="SearchAddress" />
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                   OnClick="Submit" Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEdit ? "Cập nhật" : "Tạo mới")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public POIDto? POI { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private bool _mapInitialized = false;
    private string _searchAddress = "";
    private POIFormModel _model = new();
    
    private DotNetObjectReference<POIDialog>? _dotNetRef;

    protected override void OnInitialized()
    {
        if (POI != null)
        {
            _model = new POIFormModel
            {
                Name = POI.Name,
                ShortDescription = POI.ShortDescription,
                FullDescription = POI.FullDescription,
                Latitude = POI.Latitude,
                Longitude = POI.Longitude,
                TriggerRadiusMeters = POI.TriggerRadiusMeters,
                Priority = POI.Priority,
                Category = POI.Category,
                ImageUrl = POI.ImageUrl,
                AudioUrl = POI.AudioUrl,
                AudioDurationSeconds = POI.AudioDurationSeconds ?? 0,
                MapDeepLink = POI.MapDeepLink,
                IsActive = POI.IsActive
            };
        }
        
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    private async Task InitPickerMap()
    {
        if (_mapInitialized) return;
        
        // Delay to ensure DOM is ready
        await Task.Delay(100);
        
        try
        {
            double lat = _model.Latitude != 0 ? _model.Latitude : 10.762622; // Default: HCM
            double lng = _model.Longitude != 0 ? _model.Longitude : 106.660172;
            
            await JS.InvokeVoidAsync("initPickerMap", "poi-picker-map", lat, lng, _dotNetRef);
            _mapInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing map: {ex.Message}");
        }
    }

    [JSInvokable]
    public void OnLocationPicked(double lat, double lng)
    {
        _model.Latitude = Math.Round(lat, 6);
        _model.Longitude = Math.Round(lng, 6);
        StateHasChanged();
    }

    private async Task UseCurrentLocation()
    {
        try
        {
            await JS.InvokeVoidAsync("getCurrentLocation", _dotNetRef);
        }
        catch
        {
            // Browser may not support geolocation
        }
    }

    [JSInvokable]
    public async Task OnCurrentLocationReceived(double lat, double lng)
    {
        _model.Latitude = Math.Round(lat, 6);
        _model.Longitude = Math.Round(lng, 6);
        StateHasChanged();
        
        // Update map marker
        await JS.InvokeVoidAsync("updatePickerMarker", lat, lng);
    }

    private async Task SearchAddress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchAddress))
        {
            try
            {
                await JS.InvokeVoidAsync("searchAndMoveToAddress", _searchAddress, _dotNetRef);
            }
            catch
            {
                // Search failed
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;

        try
        {
            if (IsEdit && POI != null)
            {
                var updateDto = new UpdatePOIDto
                {
                    Name = _model.Name,
                    ShortDescription = _model.ShortDescription,
                    FullDescription = _model.FullDescription,
                    Latitude = _model.Latitude,
                    Longitude = _model.Longitude,
                    TriggerRadiusMeters = _model.TriggerRadiusMeters,
                    Priority = _model.Priority,
                    Category = _model.Category,
                    ImageUrl = _model.ImageUrl,
                    AudioUrl = _model.AudioUrl,
                    AudioDurationSeconds = _model.AudioDurationSeconds,
                    MapDeepLink = _model.MapDeepLink,
                    IsActive = _model.IsActive
                };
                
                var result = await ApiService.UpdatePOIAsync(POI.Id, updateDto);
                if (result != null)
                {
                    MudDialog.Close(DialogResult.Ok(result));
                }
            }
            else
            {
                var createDto = new CreatePOIDto
                {
                    Name = _model.Name,
                    ShortDescription = _model.ShortDescription,
                    FullDescription = _model.FullDescription,
                    Latitude = _model.Latitude,
                    Longitude = _model.Longitude,
                    TriggerRadiusMeters = _model.TriggerRadiusMeters,
                    Priority = _model.Priority,
                    Category = _model.Category,
                    ImageUrl = _model.ImageUrl,
                    AudioUrl = _model.AudioUrl,
                    AudioDurationSeconds = _model.AudioDurationSeconds,
                    MapDeepLink = _model.MapDeepLink
                };

                var result = await ApiService.CreatePOIAsync(createDto);
                if (result != null)
                {
                    MudDialog.Close(DialogResult.Ok(result));
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    private class POIFormModel
    {
        public string Name { get; set; } = "";
        public string? ShortDescription { get; set; }
        public string? FullDescription { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double TriggerRadiusMeters { get; set; } = 50;
        public int Priority { get; set; } = 1;
        public string? Category { get; set; }
        public string? ImageUrl { get; set; }
        public string? AudioUrl { get; set; }
        public int AudioDurationSeconds { get; set; }
        public string? MapDeepLink { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
