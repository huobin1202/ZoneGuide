@page "/poi-translations"
@inject IApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.Components.Forms



@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
    <MudItem xs="12" md="2">
            <MudPaper Class="pa-3" Outlined="true">
                <MudTabs Rounded="true" Outlined="true" Centered="true" PanelClass="pt-2" ActivePanelIndex="@_activeEntityTabIndex" ActivePanelIndexChanged="OnEntityTabChanged">
                    <MudTabPanel Text="Địa điểm" />
                    <MudTabPanel Text="Tour" />
                </MudTabs>

                <MudTextField @bind-Value="_searchKeyword" Label="@SearchLabel" Placeholder="@SearchPlaceholder"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />

                <div class="mt-3 poi-list-scroll">
                    @if (IsPoiTabActive)
                    {
                        @foreach (var poi in FilteredPois)
                        {
                            <MudCard Class="@($"poi-item-card {(poi.Id == _selectedPoiId ? "active" : string.Empty)}")"
                                     @onclick="async () => await SelectPoiAsync(poi)">
                                <MudCardContent Class="pa-2">
                                    <div class="poi-list-item-layout">
                                        <img class="poi-list-thumb" src="@(string.IsNullOrEmpty(poi.ImageUrl) ? "/images/placeholder.png" : poi.ImageUrl)" alt="Ảnh POI @poi.Name" />
                                        <div class="poi-list-main">
                                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-1">
                                                <MudText Typo="Typo.subtitle2">@poi.Name</MudText>
                                                @if (HasPoiOutdatedTranslations(poi.Id))
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Small" Title="Có bản dịch/audio outdated" />
                                                }
                                            </MudStack>
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                                                @($"{GetPoiTranslationCount(poi.Id)} bản dịch")
                                            </MudChip>
                                        </div>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    }
                    else
                    {
                        @foreach (var tour in FilteredTours)
                        {
                            <MudCard Class="@($"poi-item-card {(tour.Id == _selectedTourId ? "active" : string.Empty)}")"
                                     @onclick="async () => await SelectTourAsync(tour)">
                                <MudCardContent Class="pa-2">
                                    <div class="poi-list-main">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-1">
                                            <MudText Typo="Typo.subtitle2">@tour.Name</MudText>
                                            @if (HasTourOutdatedTranslations(tour.Id))
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Color="Color.Warning" Size="Size.Small" Title="Có bản dịch outdated" />
                                            }
                                        </MudStack>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                                            @($"{GetTourTranslationCount(tour.Id)} bản dịch")
                                        </MudChip>
                                    </div>
                                </MudCardContent>
                            </MudCard>
                        }
                    }

                    @if (_loadingSummaries)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-1" />
                    }
                </div>
            </MudPaper>
        </MudItem>

    <MudItem xs="12" md="6">
            @if (SelectedEntityName is null)
            {
                <MudAlert Severity="Severity.Info">Chọn một @SelectedEntityTypeLabel ở bên trái để tạo bản dịch và audio.</MudAlert>
            }
            else
            {
                <MudPaper Class="pa-3 mb-3" Outlined="true">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6">@SelectedEntityName</MudText>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-3" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle1">Bản tạo audio / bản dịch</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshCurrentSelectionAsync" Disabled="@((IsPoiTabActive ? _selectedPoi is null : _selectedTour is null) || _refreshingCurrentPoi)">
                            @(_refreshingCurrentPoi ? "Đang làm mới..." : "Làm mới")
                        </MudButton>
                    </MudStack>

                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.End" Class="mb-2 flex-wrap">
                        <MudSelect T="string" Value="@_selectedLanguage" ValueChanged="OnSelectedLanguageChangedAsync" Label="" Style="min-width: 260px;">
                            @foreach (var option in LanguageOptions)
                            {
                                <MudSelectItem Value="@option.Code">@option.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>

                    @if (IsOriginalLanguageSelected)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mt-2">
                            Ngôn ngữ gốc đang được khóa để tránh sửa nhầm nội dung gốc.
                        </MudAlert>
                    }

                    @if (CanEditTranslation && IsOriginalNarrationMissing)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mt-2">
                            Chưa có nội dung gốc, không thể nhập nội dung bản dịch.
                        </MudAlert>
                    }

                    @if (_translatingContent)
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-2">Đang tự động dịch nội dung theo ngôn ngữ đã chọn...</MudAlert>
                    }

                    @if (_isEditorLoading)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mt-2 mb-2" />
                    }

                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2">Nội dung</MudText>
                    <MudGrid Class="mb-2" @key="EditorRenderKey">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="EditingContent"
                                          Label="Nội dung bản dịch"
                                          Lines="6"
                                          Immediate="true"
                                          Class="@(_translatingContent ? "content-pulse" : string.Empty)"
                                          Disabled="@(!CanEditTranslatedContent || _isEditorLoading)" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField Value="@OriginalNarrationContent"
                                          Label="Nội dung gốc"
                                          Lines="6"
                                          Class="@(IsOriginalNarrationMissing ? "content-pulse" : string.Empty)"
                                          ReadOnly="true"
                                          Disabled="true" />
                        </MudItem>
                    </MudGrid>

                    <MudText Typo="Typo.subtitle2" Class="mb-2">Audio</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2 audio-actions-row">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.GraphicEq"
                                   OnClick="GenerateTtsForEditingAsync" Disabled="@(_generatingTts || !CanEditTranslatedContent || IsTourTabActive || _isEditorLoading)">
                            @(_generatingTts ? "Generating audio..." : "Generate audio (TTS)")
                        </MudButton>

                        <div class="audio-upload-action">
                            <InputFile id="audio-upload" class="audio-upload-input" OnChange="UploadAudioFromInput" accept="audio/*,.mp3,.wav,.m4a,.ogg,.webm" disabled="@(!CanEditTranslatedContent || _uploadingAudio || _isEditorLoading)" />
                            <MudButton HtmlTag="label" for="audio-upload" Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.UploadFile"
                                       Disabled="@(!CanEditTranslatedContent || _uploadingAudio || IsTourTabActive || _isEditorLoading)">
                                @(_uploadingAudio ? "Đang tải audio..." : "Upload audio")
                            </MudButton>
                        </div>

                        <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="PreviewAudio" Disabled="@(!HasEditingAudio || IsTourTabActive || _isEditorLoading)">
                            Preview audio
                        </MudButton>
                    </MudStack>

                    <MudText Typo="Typo.caption" Class="@($"mb-2 {AudioStatusCssClass}")">Audio status: @AudioStatusText</MudText>

                    @if (HasEditingAudio && _showAudioPreview && IsPoiTabActive)
                    {
                        <MudPaper Class="pa-2 mb-2" Outlined="true">
                            <audio @key="EditingAudioSource" controls preload="metadata" style="width:100%">
                                <source src="@EditingAudioSource" />
                            </audio>
                        </MudPaper>
                    }

                    <MudTextField @bind-Value="_editingTranslation.AudioUrl" Label="Audio URL / Base64" Lines="2" Disabled="@(!CanEditTranslatedContent || IsTourTabActive || _isEditorLoading)" Class="mb-2" />
                    <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteOutline"
                               OnClick="ClearEditingAudio" Disabled="@(!HasEditingAudio || !CanEditTranslatedContent || IsTourTabActive || _isEditorLoading)">
                        Xóa audio hiện tại
                    </MudButton>

                    <MudDivider Class="my-2" />
                    <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="flex-wrap">
                        <MudButton Variant="Variant.Outlined" OnClick="ResetEditingTranslation">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                                   Disabled="@(!CanEditTranslatedContent || _isEditorLoading)" OnClick="SaveCurrentTranslationAsync">
                            Save translation
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-3 mb-3" Outlined="true">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Những audio đã tạo</MudText>

                @if (IsTourTabActive)
                {
                    <MudAlert Severity="Severity.Info">Tour chưa hỗ trợ danh sách audio riêng.</MudAlert>
                }
                else if (_selectedPoi is null)
                {
                    <MudAlert Severity="Severity.Info">Chọn một POI để xem audio đã tạo.</MudAlert>
                }
                else if (CreatedAudios.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">POI này chưa có audio nào.</MudAlert>
                }
                else
                {
                    <div class="audio-created-scroll">
                        @foreach (var audio in CreatedAudios)
                        {
                            <MudPaper Class="pa-2 mb-2" Outlined="true">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-1">
                                    <MudText Typo="Typo.body2">@GetLanguageLabel(audio.LanguageCode)</MudText>
                                    <MudText Typo="Typo.caption" Class="@GetAudioStatusClass(audio)">@GetAudioStatusText(audio)</MudText>
                                </MudStack>

                                <audio controls preload="metadata" style="width:100%" class="mb-2">
                                    <source src="@ResolveAudioSource(audio.AudioUrl)" />
                                </audio>

                             
                            </MudPaper>
                        }
                    </div>
                }
            </MudPaper>

            @if (IsPoiTabActive && _selectedPoi is not null)
            {
                <MudPaper Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Tất cả bản dịch</MudText>

                    @if (_translations.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">POI này chưa có bản dịch nào.</MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_translations" Dense="true" Hover="true" Bordered="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Ngôn ngữ</MudTh>
                                <MudTh>Nội dung</MudTh>
                                <MudTh>Audio</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Ngôn ngữ">@context.LanguageCode</MudTd>
                                <MudTd DataLabel="Nội dung">
                                    <MudText Typo="Typo.caption" Class="@GetContentStatusClass(context)">@GetContentStatusText(context)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Audio">
                                    <MudText Typo="Typo.caption" Class="@GetAudioStatusClass(context)">@GetAudioStatusText(context)</MudText>
                                </MudTd>
                                <MudTd Class="text-right">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                   OnClick="@(() => LoadTranslationToEditor(context))" />
                                      <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => DeleteTranslationAsync(context)" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            }
            else if (IsTourTabActive && _selectedTour is not null)
            {
                <MudPaper Class="pa-3" Outlined="true">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Tất cả bản dịch Tour</MudText>

                    @if (_tourTranslations.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info">Tour này chưa có bản dịch nào.</MudAlert>
                    }
                    else
                    {
                        <MudTable Items="_tourTranslations" Dense="true" Hover="true" Bordered="true" Striped="true">
                            <HeaderContent>
                                <MudTh>Ngôn ngữ</MudTh>
                                <MudTh>Nội dung</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Ngôn ngữ">@context.LanguageCode</MudTd>
                                <MudTd DataLabel="Nội dung">
                                    <MudText Typo="Typo.caption" Class="@GetTourContentStatusClass(context)">@GetTourContentStatusText(context)</MudText>
                                </MudTd>
                                <MudTd Class="text-right">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                                   OnClick="@(() => LoadTourTranslationToEditor(context))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => DeleteTourTranslationAsync(context)" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}

<style>
    .poi-header-compact {
        min-height: 40px;
    }

    .poi-list-scroll {
        max-height: calc(100vh - 260px);
        overflow-y: auto;
    }

    .poi-item-card {
        border-radius: 10px;
        margin-bottom: 8px;
        border: 1px solid #e7ebf0;
        cursor: pointer;
        box-shadow: none;
    }

    .poi-item-card.active {
        border-color: #1976d2;
        box-shadow: 0 0 0 2px rgba(25, 118, 210, 0.12);
        background: rgba(25, 118, 210, 0.08);
    }

    .poi-list-item-layout {
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .poi-list-thumb {
        width: 64px;
        height: 64px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        flex: 0 0 auto;
    }

    .poi-list-main {
        min-width: 0;
        flex: 1;
    }

    .workflow-steps {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .workflow-step {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        border: 1px solid #e4e7ec;
        border-radius: 12px;
        background: #f8fafc;
    }

    .workflow-step.active {
        border-color: #1976d2;
        background: rgba(25, 118, 210, 0.08);
    }

    .workflow-step.done {
        border-color: #2e7d32;
        background: rgba(46, 125, 50, 0.08);
    }

    .step-index {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        background: #cfd8dc;
        color: #263238;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
    }

    .workflow-step.active .step-index {
        background: #1976d2;
        color: white;
    }

    .workflow-step.done .step-index {
        background: #2e7d32;
        color: white;
    }

    .step-label {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .lang-tag {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        background: #eceff1;
        color: #455a64;
        font-weight: 600;
    }

    .audio-upload-input {
        display: none;
    }

    .audio-actions-row {
        flex-wrap: nowrap;
    }

    .audio-actions-row > * {
        flex: 0 0 auto;
    }

    @@media (max-width: 900px) {
        .audio-actions-row {
            overflow-x: auto;
            padding-bottom: 4px;
        }
    }

    .audio-created-scroll {
        max-height: calc(100vh - 360px);
        overflow-y: auto;
    }

    .status-green {
        color: #2e7d32;
        font-weight: 700;
    }

    .status-yellow {
        color: #ed6c02;
        font-weight: 700;
    }

    .status-gray {
        color: #607d8b;
        font-weight: 700;
    }

    .content-pulse .mud-input-slot {
        background: linear-gradient(90deg, rgba(25, 118, 210, 0.06) 0%, rgba(25, 118, 210, 0.18) 50%, rgba(25, 118, 210, 0.06) 100%);
        background-size: 240% 100%;
        animation: content-shimmer 1.6s ease-in-out infinite;
    }

    .content-pulse textarea,
    .content-pulse input {
        font-style: italic;
    }

    @@keyframes content-shimmer {
        0% { background-position: 100% 0; }
        100% { background-position: -100% 0; }
    }
</style>

@code {
    private readonly List<(string Code, string Label)> LanguageOptions =
    [
        ("en-US", "🇺🇸 English (US)"),
        ("ja-JP", "🇯🇵 日本語"),
        ("ko-KR", "🇰🇷 한국어"),
        ("zh-CN", "🇨🇳 中文"),
        ("fr-FR", "🇫🇷 Français"),
        ("de-DE", "🇩🇪 Deutsch")
    ];

    private bool _loading = true;
    private bool _generatingTts;
    private bool _translatingContent;
    private bool _uploadingAudio;
    private bool _showAudioPreview;
    private bool _isEditorLoading;
    private bool _loadingSummaries;
    private bool _refreshingCurrentPoi;
    private int _activeEntityTabIndex;
    private string _searchKeyword = string.Empty;
    private string _selectedPoiId = string.Empty;
    private string _selectedTourId = string.Empty;
    private string _selectedLanguage = "en-US";

    private List<POIDto> _pois = new();
    private List<TourDto> _tours = new();
    private POIDto? _selectedPoi;
    private TourDto? _selectedTour;
    private List<POITranslationDto> _translations = new();
    private List<TourTranslationDto> _tourTranslations = new();
    private readonly Dictionary<string, (int Count, bool HasOutdated)> _poiTranslationSummaries = new();
    private readonly Dictionary<string, (int Count, bool HasOutdated)> _tourTranslationSummaries = new();
    private POITranslationDto _editingTranslation = CreateEmptyTranslation("en-US");
    private TourTranslationDto _editingTourTranslation = CreateEmptyTourTranslation("en-US");

    private bool IsPoiTabActive => _activeEntityTabIndex == 0;
    private bool IsTourTabActive => _activeEntityTabIndex == 1;
    private string SearchLabel => IsPoiTabActive ? "Tìm Địa điểm" : "Tìm Tour";
    private string SearchPlaceholder => IsPoiTabActive ? "Nhập tên hoặc địa chỉ..." : "Nhập tên hoặc mô tả tour...";
    private string? SelectedEntityName => IsPoiTabActive ? _selectedPoi?.Name : _selectedTour?.Name;
    private string SelectedEntityTypeLabel => IsPoiTabActive ? "Địa điểm" : "Tour";

    private string OriginalLanguageCode => IsPoiTabActive
        ? (_selectedPoi?.Language ?? "vi-VN")
        : (_selectedTour?.Language ?? "vi-VN");
    private string OriginalLanguageTag => $"{OriginalLanguageCode} (Original)";
    private string OriginalLanguageLabel => $"{GetLanguageLabel(OriginalLanguageCode)} ({OriginalLanguageCode})";
    private bool IsOriginalLanguageSelected => string.Equals(_selectedLanguage, OriginalLanguageCode, StringComparison.OrdinalIgnoreCase);
    private bool CanEditTranslation => (IsPoiTabActive ? _selectedPoi is not null : _selectedTour is not null) && !IsOriginalLanguageSelected;
    private bool CanEditTranslatedContent => CanEditTranslation && !IsOriginalNarrationMissing;
    private bool IsOriginalNarrationMissing => IsPoiTabActive
        ? string.IsNullOrWhiteSpace(_selectedPoi?.TTSScript)
        : string.IsNullOrWhiteSpace(_selectedTour?.Description);
    private string OriginalNarrationContent => IsPoiTabActive
        ? (_selectedPoi?.TTSScript ?? string.Empty)
        : (_selectedTour?.Description ?? string.Empty);
    private string EditingAudioSource => ResolveAudioSource(_editingTranslation.AudioUrl);
    private bool HasEditingAudio => !string.IsNullOrWhiteSpace(EditingAudioSource);
    private int CurrentWorkflowStep => ComputeCurrentStep();
    private string AudioStatusText => _generatingTts || _uploadingAudio
        ? "Generating"
        : HasEditingAudio ? "Ready" : "No audio";
    private string AudioStatusCssClass => _generatingTts || _uploadingAudio
        ? "status-yellow"
        : HasEditingAudio ? "status-green" : "status-gray";
    private List<POITranslationDto> CreatedAudios => _translations
        .Where(HasAudio)
        .OrderBy(t => t.LanguageCode)
        .ToList();

    private string EditingContent
    {
        get => IsPoiTabActive
            ? (_editingTranslation.TTSScript ?? string.Empty)
            : (_editingTourTranslation.Description ?? string.Empty);
        set => OnEditingContentChanged(value);
    }

    private string EditorRenderKey =>
        $"{_activeEntityTabIndex}:{(IsPoiTabActive ? _selectedPoiId : _selectedTourId)}:{_selectedLanguage}";

    private IEnumerable<POIDto> FilteredPois => _pois
        .Where(p => p.IsActive)
        .Where(p => string.IsNullOrWhiteSpace(_searchKeyword)
            || p.Name.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)
            || (p.Address?.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(p => p.Name);

    private IEnumerable<TourDto> FilteredTours => _tours
        .Where(t => t.IsActive)
        .Where(t => string.IsNullOrWhiteSpace(_searchKeyword)
            || t.Name.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)
            || (t.Description?.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(t => t.Name);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _pois = await ApiService.GetPOIsAsync();
        _tours = await ApiService.GetToursAsync();
        _loading = false;

        _ = LoadPoiTranslationSummariesAsync();
        _ = LoadTourTranslationSummariesAsync();

        var firstPoi = _pois.FirstOrDefault(p => p.IsActive);
        if (firstPoi is not null)
        {
            await SelectPoiAsync(firstPoi);
            return;
        }

        var firstTour = _tours.FirstOrDefault(t => t.IsActive);
        if (firstTour is not null)
        {
            _activeEntityTabIndex = 1;
            await SelectTourAsync(firstTour);
        }
    }

    private async Task OnEntityTabChanged(int tabIndex)
    {
        _activeEntityTabIndex = tabIndex;

        _editingTranslation = CreateEmptyTranslation(_selectedLanguage);
        _editingTourTranslation = CreateEmptyTourTranslation(_selectedLanguage);
        _showAudioPreview = false;
        await InvokeAsync(StateHasChanged);

        if (IsPoiTabActive && _selectedPoi is null)
        {
            var firstPoi = FilteredPois.FirstOrDefault();
            if (firstPoi is not null)
            {
                await SelectPoiAsync(firstPoi);
            }
        }
        else if (IsPoiTabActive && _selectedPoi is not null)
        {
            await SelectPoiAsync(_selectedPoi);
        }

        if (IsTourTabActive && _selectedTour is null)
        {
            var firstTour = FilteredTours.FirstOrDefault();
            if (firstTour is not null)
            {
                await SelectTourAsync(firstTour);
            }
        }
        else if (IsTourTabActive && _selectedTour is not null)
        {
            await SelectTourAsync(_selectedTour);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectPoiAsync(POIDto poi)
    {
        _isEditorLoading = true;
        _showAudioPreview = false;
        _selectedPoi = poi;
        _selectedPoiId = poi.Id;
        _activeEntityTabIndex = 0;

        _editingTranslation = CreateEmptyTranslation(_selectedLanguage);
        await InvokeAsync(StateHasChanged);

        try
        {
            _translations = await ApiService.GetPOITranslationsAsync(poi.Id);
            UpdatePoiTranslationSummary(poi.Id, _translations);

            _selectedLanguage = DetermineDefaultLanguage();
            await SyncEditorFromSelectedLanguageAsync(autoTranslateIfMissing: true);
        }
        finally
        {
            _isEditorLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SelectTourAsync(TourDto tour)
    {
        _isEditorLoading = true;
        _selectedTour = tour;
        _selectedTourId = tour.Id;
        _activeEntityTabIndex = 1;

        _editingTourTranslation = CreateEmptyTourTranslation(_selectedLanguage);
        await InvokeAsync(StateHasChanged);

        try
        {
            _tourTranslations = await ApiService.GetTourTranslationsAsync(tour.Id);
            UpdateTourTranslationSummary(tour.Id, _tourTranslations);

            _selectedLanguage = DetermineDefaultLanguage();
            await SyncEditorFromSelectedLanguageAsync(autoTranslateIfMissing: true);
        }
        finally
        {
            _isEditorLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string DetermineDefaultLanguage()
    {
        var sourceLanguage = IsPoiTabActive
            ? _selectedPoi?.Language
            : _selectedTour?.Language;

        if (string.IsNullOrWhiteSpace(sourceLanguage))
        {
            return "en-US";
        }

        var primary = sourceLanguage;
        var candidate = LanguageOptions.FirstOrDefault(x => !string.Equals(x.Code, primary, StringComparison.OrdinalIgnoreCase));
        return candidate.Code == default ? "en-US" : candidate.Code;
    }

    private async Task OnSelectedLanguageChangedAsync(string languageCode)
    {
        _isEditorLoading = true;
        _selectedLanguage = languageCode;
        if (IsPoiTabActive)
        {
            _editingTranslation = CreateEmptyTranslation(_selectedLanguage);
        }
        else
        {
            _editingTourTranslation = CreateEmptyTourTranslation(_selectedLanguage);
        }

        await InvokeAsync(StateHasChanged);

        try
        {
            await SyncEditorFromSelectedLanguageAsync(autoTranslateIfMissing: true);
        }
        finally
        {
            _isEditorLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshCurrentPoiAsync()
    {
        if (_selectedPoi is null)
        {
            return;
        }

        _refreshingCurrentPoi = true;
        try
        {
            var latestPoi = await ApiService.GetPOIAsync(_selectedPoi.Id);
            if (latestPoi is null)
            {
                Snackbar.Add("Không thể làm mới nội dung POI", Severity.Error);
                return;
            }

            _selectedPoi = latestPoi;
            var poiIndex = _pois.FindIndex(p => p.Id == latestPoi.Id);
            if (poiIndex >= 0)
            {
                _pois[poiIndex] = latestPoi;
            }

            _translations = await ApiService.GetPOITranslationsAsync(latestPoi.Id);
            UpdatePoiTranslationSummary(latestPoi.Id, _translations);

            // Reload form from latest data first, then refresh translated content from base POI
            // so old translations in editor do not remain stale after POI content changes.
            await SyncEditorFromSelectedLanguageAsync(autoTranslateIfMissing: false);

            if (CanEditTranslation)
            {
                await TranslateFromBaseContentAsync(showSuccessToast: false);
            }

            Snackbar.Add("Đã làm mới dữ liệu từ Quản lý địa điểm", Severity.Success);
        }
        finally
        {
            _refreshingCurrentPoi = false;
        }
    }

    private async Task RefreshCurrentTourAsync()
    {
        if (_selectedTour is null)
        {
            return;
        }

        _refreshingCurrentPoi = true;
        try
        {
            var latestTour = await ApiService.GetTourAsync(_selectedTour.Id);
            if (latestTour is null)
            {
                Snackbar.Add("Không thể làm mới nội dung Tour", Severity.Error);
                return;
            }

            _selectedTour = latestTour;
            var tourIndex = _tours.FindIndex(t => t.Id == latestTour.Id);
            if (tourIndex >= 0)
            {
                _tours[tourIndex] = latestTour;
            }

            _tourTranslations = await ApiService.GetTourTranslationsAsync(latestTour.Id);
            UpdateTourTranslationSummary(latestTour.Id, _tourTranslations);

            await SyncEditorFromSelectedLanguageAsync(autoTranslateIfMissing: false);

            if (CanEditTranslation)
            {
                await TranslateFromBaseContentAsync(showSuccessToast: false);
            }

            Snackbar.Add("Đã làm mới dữ liệu Tour", Severity.Success);
        }
        finally
        {
            _refreshingCurrentPoi = false;
        }
    }

    private Task RefreshCurrentSelectionAsync()
    {
        return IsPoiTabActive ? RefreshCurrentPoiAsync() : RefreshCurrentTourAsync();
    }

    private async Task SyncEditorFromSelectedLanguageAsync(bool autoTranslateIfMissing)
    {
        if (IsPoiTabActive)
        {
            if (_selectedPoi is null)
            {
                _editingTranslation = CreateEmptyTranslation(_selectedLanguage);
                return;
            }

            var existing = _translations.FirstOrDefault(t => t.LanguageCode == _selectedLanguage);
            if (existing is not null)
            {
                _editingTranslation = CloneTranslation(existing);
                _showAudioPreview = false;
                return;
            }

            _editingTranslation = new POITranslationDto
            {
                POIId = int.TryParse(_selectedPoi.Id, out var poiId) ? poiId : 0,
                LanguageCode = _selectedLanguage,
                Name = string.Empty,
                TTSScript = string.Empty,
                AudioUrl = null,
                IsOutdated = false,
                IsAudioOutdated = false
            };
            _showAudioPreview = false;

            if (autoTranslateIfMissing && CanEditTranslatedContent)
            {
                await TranslateFromBaseContentAsync(showSuccessToast: false);
            }

            return;
        }

        if (_selectedTour is null)
        {
            _editingTourTranslation = CreateEmptyTourTranslation(_selectedLanguage);
            return;
        }

        var existingTour = _tourTranslations.FirstOrDefault(t => t.LanguageCode == _selectedLanguage);
        if (existingTour is not null)
        {
            _editingTourTranslation = CloneTourTranslation(existingTour);
            return;
        }

        _editingTourTranslation = new TourTranslationDto
        {
            TourId = int.TryParse(_selectedTour.Id, out var tourId) ? tourId : 0,
            LanguageCode = _selectedLanguage,
            Description = string.Empty,
            IsOutdated = false
        };

        if (autoTranslateIfMissing && CanEditTranslatedContent)
        {
            await TranslateFromBaseContentAsync(showSuccessToast: false);
        }
    }

    private async Task SaveTranslationAsync()
    {
        if (_selectedPoi is null)
            return;

        if (string.IsNullOrWhiteSpace(_editingTranslation.LanguageCode))
        {
            Snackbar.Add("Vui lòng chọn ngôn ngữ", Severity.Warning);
            return;
        }

        if (IsOriginalLanguageSelected)
        {
            Snackbar.Add("Không thể lưu đè ngôn ngữ gốc tại màn bản dịch", Severity.Warning);
            return;
        }

        if (IsOriginalNarrationMissing)
        {
            Snackbar.Add("Chưa có nội dung gốc, không thể lưu bản dịch", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editingTranslation.Name))
        {
            Snackbar.Add("Tên bản dịch không được để trống", Severity.Warning);
            return;
        }

        var saved = await ApiService.UpsertPOITranslationAsync(_selectedPoi.Id, _editingTranslation.LanguageCode, _editingTranslation);
        if (saved is null)
        {
            Snackbar.Add("Không thể lưu bản dịch", Severity.Error);
            return;
        }

        Snackbar.Add($"Đã lưu bản dịch {_editingTranslation.LanguageCode}", Severity.Success);
        _translations = await ApiService.GetPOITranslationsAsync(_selectedPoi.Id);
    UpdatePoiTranslationSummary(_selectedPoi.Id, _translations);
        _selectedLanguage = saved.LanguageCode;
        LoadTranslationToEditor(saved);
    }

