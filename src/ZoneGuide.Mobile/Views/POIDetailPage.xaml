<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.POIDetailPage"
             x:DataType="vm:POIDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0"
              HeightRequest="320">
            <Image Source="{Binding ImageSource}"
                   Aspect="AspectFill" />

            <BoxView Color="#66000000" />

            <Grid Padding="16,26,16,18"
                  RowDefinitions="Auto,*,Auto">
                <Button Grid.Row="0"
                        Text="←"
                        WidthRequest="42"
                        HeightRequest="42"
                        CornerRadius="21"
                        FontSize="18"
                        Padding="0"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        BackgroundColor="#66FFFFFF"
                        TextColor="White"
                        SemanticProperties.Hint="{local:Translate poi_detail_back}"
                        Command="{Binding BackCommand}" />

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="10">
                    <Border BackgroundColor="#66FFFFFF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            Padding="10,4"
                            HorizontalOptions="Start">
                        <Label Text="{Binding CurrentPoi.Category, Converter={StaticResource LocalizedCategoryConverter}}"
                               TextColor="White"
                               FontSize="12" />
                    </Border>

                    <Label Text="{Binding CurrentPoi.Name}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           LineBreakMode="WordWrap" />

                    <Label Text="{Binding CurrentPoi.ShortDescription}"
                           FontSize="14"
                           TextColor="#F3F0FF"
                           MaxLines="3" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,-26,20,24"
                                 Spacing="18">
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{local:Translate poi_detail_now_playing}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding PlaybackStatusText}"
                                       FontSize="13"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>

                            <Border BackgroundColor="#F2EFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Label Text="{Binding ProgressText}"
                                       FontSize="12"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                        </Grid>

                        <ProgressBar Progress="{Binding Progress}"
                                     HeightRequest="8"
                                     ProgressColor="{StaticResource Primary}"
                                     BackgroundColor="#ECEAF8" />

                        <Button Text="⏯"
                                HeightRequest="52"
                                CornerRadius="16"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                Command="{Binding TogglePlayPauseCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        Padding="18">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{local:Translate poi_detail_description}"
                               FontSize="18"
                               FontAttributes="Bold" />

                        <Label Text="{Binding CurrentPoi.FullDescription}"
                               FontSize="14"
                               TextColor="{StaticResource Gray700}"
                               LineHeight="1.5" />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        Padding="18"
                        IsVisible="{Binding Distance}">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="14" />
                        <Label Text="{Binding Distance, StringFormat='Cách {0:F0}m'}"
                               FontSize="14"
                               TextColor="{StaticResource Primary}" />
                    </HorizontalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="{local:Translate poi_detail_navigate}"
                            HeightRequest="52"
                            CornerRadius="16"
                            BackgroundColor="{StaticResource Secondary}"
                            TextColor="White"
                            Command="{Binding NavigateCommand}" />

                    <Button Grid.Column="1"
                            Text="{local:Translate poi_detail_share}"
                            HeightRequest="52"
                            CornerRadius="16"
                            BackgroundColor="#4B5563"
                            TextColor="White"
                            Command="{Binding ShareCommand}" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>