@inherits LayoutComponentBase
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject IJSRuntime JS
@using ZoneGuide.Shared.Models

@if (_initialized)
{
<MudLayout Class="layout-tall-appbar">
    <MudAppBar Elevation="1" Class="topbar-tall">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
            OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3 app-title">ZoneGuide</MudText>
        <MudSpacer />

        @if (_currentUser != null)
        {
            @if (_isAdmin || _isContributor)
            {
                <MudBadge Color="Color.Error" Content="@_unreadCount.ToString()" Visible="@(_unreadCount > 0)" Class="mr-2">
                    <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                                   Href="/notifications" />
                </MudBadge>
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="cursor-pointer user-info" @onclick="@(() => Navigation.NavigateTo("/profile"))">
                <MudAvatar Size="Size.Small" Color="Color.Primary" Style="background-color: #22ffd6 !important;">
                    @if (!string.IsNullOrEmpty(_currentUser.AvatarUrl))
                    {
                        <MudImage Src="@_currentUser.AvatarUrl" />
                    }
                    else
                    {
                        @(_currentUser.DisplayName?.FirstOrDefault())
                    }
                </MudAvatar>
                <MudStack Spacing="0" Class="user-details">
                    <MudText Typo="Typo.subtitle2" Class="text-white">@_currentUser.DisplayName</MudText>
                    <MudText Typo="Typo.caption" Class="text-white" Style="color:#fff !important;">@GetRoleDisplayName()</MudText>
                </MudStack>
            </MudStack>
        }
        else
        {
            <MudButton Color="Color.Inherit" Href="/login" StartIcon="@Icons.Material.Filled.Login">
                Đăng nhập
            </MudButton>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Class="main-sidebar">
        <div class="drawer-layout">
            <MudNavMenu>
                @if (_isAdmin)
                {
                    <!-- Admin Menu -->
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                        Dashboard
                    </MudNavLink>
                    <MudNavLink Href="/pois" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocationOn">
                        Quản lý địa điểm
                    </MudNavLink>
                    <MudNavLink Href="/poi-qrcodes" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QrCode">
                        Quản lý QR địa điểm
                    </MudNavLink>
                    <MudNavLink Href="/tours" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Route">
                        Quản lý chuyến du lịch
                    </MudNavLink>
                    <MudNavLink Href="/poi-translations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Translate">
                        Audio / Bản dịch
                    </MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">Quản lý</MudText>
                    <MudNavLink Href="/contributions" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RateReview">
                        Duyệt đóng góp
                    </MudNavLink>
                    <MudNavLink Href="/users" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">
                        Quản lý người dùng
                    </MudNavLink>
                    <MudNavLink Href="/notifications" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Notifications">
                        Thông báo
                    </MudNavLink>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/analytics" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Analytics">
                        Analytics
                    </MudNavLink>
                    <MudNavLink Href="/heatmap" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Whatshot">
                        Heatmap du khách
                    </MudNavLink>
                    <MudNavLink Href="/qr-logs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.QrCodeScanner">
                        Nhật ký quét QR
                    </MudNavLink>
                    <MudNavLink Href="/activity-log" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">
                        Nhật ký hoạt động
                    </MudNavLink>
                }
                else if (_isContributor)
                {
                    <!-- Contributor Menu -->
                    <MudNavLink Href="/contributor-dashboard" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Dashboard">
                        Dashboard
                    </MudNavLink>
                    <MudNavLink Href="/contributor-pois" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocationOn">
                        Quản lý địa điểm
                    </MudNavLink>
                    <MudNavLink Href="/my-contributions" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EditLocation">
                        Đóng góp của tôi
                    </MudNavLink>
                    <MudNavLink Href="/contributor-poi-translations" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Translate">
                        Audio / Bản dịch
                    </MudNavLink>
                    <MudNavLink Href="/notifications" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Notifications">
                        Thông báo
                    </MudNavLink>
                }
                else
                {
                    <!-- Not logged in -->
                    <MudNavLink Href="/login" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Login">
                        Đăng nhập
                    </MudNavLink>
                    <MudNavLink Href="/register" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PersonAdd">
                        Đăng ký Contributor
                    </MudNavLink>
                }
            </MudNavMenu>

            @if (_currentUser != null)
            {
                <MudNavMenu>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/profile" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Person">
                        Profile
                    </MudNavLink>
                    <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="@(_ => ConfirmLogout())">
                        Đăng xuất
                    </MudNavLink>
                </MudNavMenu>
            }
        </div>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudContainer>
}

<style>
    .layout-tall-appbar {
        --mud-appbar-height: 70px;
    }

    .topbar-tall {
        min-height: 70px !important;
    }

    .topbar-tall .mud-toolbar {
        min-height: 70px !important;
    }

    .drawer-layout {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .main-sidebar .mud-nav-link {
        border: 1px solid transparent;
        border-radius: 10px;
        margin: 2px 8px;
        transition: all .18s ease;
    }

    .main-sidebar .mud-nav-link.active {
        border-color: #2b7cd3;
        box-shadow: inset 0 0 0 1px rgba(43, 124, 211, 0.25);
        background: rgba(43, 124, 211, 0.08);
    }

    .main-sidebar .mud-nav-link.active,
    .main-sidebar .mud-nav-link.active .mud-nav-link-text {
        color: #2b7cd3 !important;
        font-weight: 600;
    }

    .main-sidebar .mud-nav-link.active .mud-nav-link-icon,
    .main-sidebar .mud-nav-link.active .mud-icon-root {
        color: #2b7cd3 !important;
    }

    .unread-count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background-color: #f44336;
        color: white;
        font-size: 11px;
        font-weight: 700;
        min-width: 20px;
        height: 20px;
        border-radius: 10px;
        padding: 0 6px;
        margin-left: 6px;
    }

    /* Mobile responsive */
    @@media (max-width: 600px) {
        .layout-tall-appbar {
            --mud-appbar-height: 56px;
        }

        .topbar-tall {
            min-height: 56px !important;
        }

        .topbar-tall .mud-toolbar {
            min-height: 56px !important;
            padding-left: 4px;
            padding-right: 4px;
        }

        .app-title {
            font-size: 1.1rem !important;
        }

        .user-details {
            display: none !important;
        }

        .topbar-tall .mud-avatar-small {
            width: 32px !important;
            height: 32px !important;
        }
    }

</style>

@implements IDisposable

@code {
    private bool _drawerOpen = true;
    private UserDto? _currentUser;
    private bool _isAdmin => _currentUser?.Role == "Admin";
    private bool _isContributor => _currentUser?.Role == "Contributor";
    private bool _initialized = false;
    private int _unreadCount = 0;
    private int _previousUnreadCount = 0;
    private bool _disposed = false;
    private CancellationTokenSource? _pollingCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCurrentUser();
            if (_currentUser == null)
            {
                Navigation.NavigateTo("/login");
                return;
            }
            _initialized = true;
            StateHasChanged();

            if (_isAdmin || _isContributor)
            {
                _ = RequestNotificationPermission();
                _ = PollNotificationsAsync();
            }
        }
    }

    private async Task RequestNotificationPermission()
    {
        try
        {
            await JS.InvokeVoidAsync("Notification.requestPermission");
        }
        catch
        {
        }
    }

    private async Task PollNotificationsAsync()
    {
        _pollingCts = new CancellationTokenSource();
        var token = _pollingCts.Token;

        try
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    var result = await Http.GetFromJsonAsync<UnreadCountDto>("api/notifications/unread-count", token);
                    if (result != null && _unreadCount != result.Count)
                    {
                        _previousUnreadCount = _unreadCount;
                        _unreadCount = result.Count;
                        if (!_disposed) StateHasChanged();

                        if (_unreadCount > _previousUnreadCount)
                        {
                            await ShowBrowserNotification();
                        }
                    }
                }
                catch
                {
                }
                await Task.Delay(30000, token);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ShowBrowserNotification()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                @"(function() {
                    if (Notification.permission === 'granted' && document.hidden) {
                        new Notification('ZoneGuide', {
                            body: 'Có thông báo mới',
                            icon: '/images/icon.svg',
                            tag: 'zoneguide-notification',
                            requireInteraction: true
                        });
                    }
                })()");
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        _disposed = true;
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
    }

    private async Task LoadCurrentUser()
    {
        try
        {
            _currentUser = await LocalStorage.GetItemAsync<UserDto>("user");
        }
        catch
        {
            _currentUser = null;
        }
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("accessToken");
        await LocalStorage.RemoveItemAsync("refreshToken");
        await LocalStorage.RemoveItemAsync("user");
        _currentUser = null;
        Snackbar.Add("Đã đăng xuất", Severity.Info);
        Navigation.NavigateTo("/login");
    }

    private async Task ConfirmLogout()
    {
        var shouldLogout = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn đăng xuất không?");
        if (!shouldLogout)
        {
            return;
        }

        await Logout();
    }

    private string GetRoleDisplayName()
    {
        return _currentUser?.Role switch
        {
            "Admin" => "Quản trị viên",
            "Contributor" => "Cộng tác viên",
            _ => "Người dùng"
        };
    }

}
