<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
             x:Class="ZoneGuide.Mobile.Views.POIListPage"
             x:DataType="vm:POIListViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Padding="14,10,14,0"
          RowSpacing="8">
        <Border Grid.Row="0"
                BackgroundColor="White"
                Stroke="#E2E8F0"
                StrokeShape="RoundRectangle 22"
                StrokeThickness="1"
                Padding="14,4">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="10">
                <Label Text="⌕"
                       FontSize="20"
                       TextColor="{StaticResource Gray400}"
                       VerticalTextAlignment="Center" />
                <Entry Grid.Column="1"
                       Text="{Binding SearchText}"
                       Placeholder="{local:Translate pois_search_placeholder}"
                       ClearButtonVisibility="WhileEditing"
                       BackgroundColor="Transparent" />
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        HeightRequest="52"
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}"
                        SelectionMode="Single"
                        Margin="0,2,0,2">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Padding="14,8"
                            BackgroundColor="White"
                            Stroke="#D9E0EA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding Converter={StaticResource CategoryChipIconConverter}}"
                                   FontSize="14"
                                   TextColor="#111111"
                                   VerticalTextAlignment="Center" />
                            <Label x:Name="ChipLabel"
                                   Text="{Binding}"
                                   FontSize="14"
                                   TextColor="{StaticResource Gray900}"
                                   FontAttributes="Bold"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal" />
                                    <VisualState Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor"
                                                    Value="#F3E8FF" />
                                            <Setter Property="Stroke"
                                                    Value="#A855F7" />
                                            <Setter TargetName="ChipLabel"
                                                    Property="Label.TextColor"
                                                    Value="#6D28D9" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding FilteredPOIs}"
                            SelectionMode="None"
                            Margin="0,0,0,12">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Padding="32,72"
                                         Spacing="10">
                        <Label Text="{local:Translate pois_empty_title}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{local:Translate pois_empty_subtitle}"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:POI">
                        <Frame Margin="2,6"
                               Padding="10"
                               CornerRadius="16"
                               BackgroundColor="White"
                               HasShadow="False">
                            <Grid ColumnDefinitions="78,*,Auto"
                                  ColumnSpacing="12">
                                <Grid Grid.Column="0"
                                      Grid.ColumnSpan="2"
                                      ColumnDefinitions="78,*"
                                      ColumnSpacing="12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=ViewDetailCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>

                                    <Frame Grid.Column="0"
                                           WidthRequest="78"
                                           HeightRequest="78"
                                           CornerRadius="14"
                                           Padding="0"
                                           BackgroundColor="#ECEAF8"
                                           IsClippedToBounds="True">
                                        <Image Source="{Binding ImageUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                               Aspect="AspectFill" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="5"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               MaxLines="2" />
                                        <Label Text="{Binding Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                               FontSize="14"
                                               TextColor="{StaticResource Gray500}"
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                </Grid>

                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="8"
                                                     VerticalOptions="Center">
                                    <Button Text="▶"
                                            WidthRequest="46"
                                            HeightRequest="46"
                                            CornerRadius="23"
                                            FontSize="16"
                                            Padding="0"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="White"
                                            VerticalOptions="Center"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=PlayPOICommand}"
                                            CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                                                         Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource PoiMatchConverter}">
                                                        <Binding Source="{RelativeSource AncestorType={x:Type vm:POIListViewModel}}"
                                                                 Path="CurrentNarrationPoiId" />
                                                        <Binding Path="Id" />
                                                        <Binding Source="{RelativeSource AncestorType={x:Type vm:POIListViewModel}}"
                                                                 Path="IsCurrentNarrationPlaying" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Text"
                                                        Value="⏸" />
                                                <Setter Property="BackgroundColor"
                                                        Value="{StaticResource Primary}" />
                                                <Setter Property="TextColor"
                                                        Value="White" />
                                                <Setter Property="Command"
                                                        Value="{Binding Source={RelativeSource AncestorType={x:Type vm:POIListViewModel}}, Path=ToggleStopResumePOICommand}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <views:MiniPlayerView Grid.Row="3" />
    </Grid>

</ContentPage>
