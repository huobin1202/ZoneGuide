@using ZoneGuide.Shared.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="mr-2" />
            @Notification.Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2">Nội dung</MudText>
                <MudDivider Class="my-2" />
                <MudText>@Notification.Message</MudText>
            </MudItem>

            @if (Notification.SenderName != null)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mt-4">Người gửi</MudText>
                    <MudDivider Class="my-2" />
                    <MudText>@Notification.SenderName</MudText>
                </MudItem>
            }

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mt-4">Loại</MudText>
                <MudDivider Class="my-2" />
                <MudText>@Notification.Type</MudText>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2" Class="mt-4">Thời gian</MudText>
                <MudDivider Class="my-2" />
                <MudText>@Notification.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</MudText>
            </MudItem>

            @if (Notification.ReadAt.HasValue)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mt-4">Đã đọc lúc</MudText>
                    <MudDivider Class="my-2" />
                    <MudText>@Notification.ReadAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</MudText>
                </MudItem>
            }

            @if (Notification.ReferenceType != null && Notification.ReferenceId.HasValue)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mt-4">Tham chiếu</MudText>
                    <MudDivider Class="my-2" />
                    <MudText>@Notification.ReferenceType #@Notification.ReferenceId</MudText>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="(() => MudDialog.Cancel())">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public NotificationDto Notification { get; set; } = null!;
}
