        if (_selectedPoiAddressSuggestion != null &&
            !string.Equals(_selectedPoiAddressSuggestion.DisplayName, _poiAddressQuery, StringComparison.OrdinalIgnoreCase))
        {
            _selectedPoiAddressSuggestion = null;
        }

        return Task.CompletedTask;
    }

    private async Task<IEnumerable<AddressSuggestion>> SearchPoiAddressSuggestionsAsync(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Trim().Length < 3)
        {
            _poiAddressStatus = string.Empty;
            return Array.Empty<AddressSuggestion>();
        }

        try
        {
            using var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&limit=5&q={Uri.EscapeDataString(value.Trim())}");
            request.Headers.TryAddWithoutValidation("User-Agent", "ZoneGuide-Admin/1.0");
            request.Headers.TryAddWithoutValidation("Accept-Language", "vi");

            using var response = await Http.SendAsync(request, token);
            if (!response.IsSuccessStatusCode)
            {
                _poiAddressStatus = "Không thể lấy gợi ý địa chỉ.";
                return Array.Empty<AddressSuggestion>();
            }

            var results = await response.Content.ReadFromJsonAsync<List<AddressSuggestion>>(cancellationToken: token)
                          ?? new List<AddressSuggestion>();

            _poiAddressStatus = results.Count == 0 ? "Không có địa chỉ" : $"Tìm thấy {results.Count} gợi ý địa chỉ.";
            return results;
        }
        catch (OperationCanceledException)
        {
            return Array.Empty<AddressSuggestion>();
        }
        catch
        {
            _poiAddressStatus = "Không thể lấy gợi ý địa chỉ.";
            return Array.Empty<AddressSuggestion>();
        }
    }

    private async Task OnPoiAddressSuggestionSelected(AddressSuggestion? suggestion)
    {
        _selectedPoiAddressSuggestion = suggestion;

        if (suggestion == null)
        {
            if (string.IsNullOrWhiteSpace(_poiAddressQuery))
            {
                _newPoi.Address = null;
                _poiAddressStatus = string.Empty;
            }
            return;
        }

        _poiAddressQuery = suggestion.DisplayName;
        _newPoi.Address = suggestion.DisplayName;
        ApplyAutoPoiName(suggestion.Name, suggestion.DisplayName);
        _poiAddressStatus = "Đã điền địa chỉ và cập nhật vị trí trên bản đồ.";

        if (!suggestion.TryGetCoordinates(out var lat, out var lng))
        {
            _poiAddressStatus = "Không đọc được tọa độ từ gợi ý địa chỉ.";
            return;
        }

        _newPoi.Latitude = Math.Round(lat, 6);
        _newPoi.Longitude = Math.Round(lng, 6);
        await JS.InvokeVoidAsync("addTempMarkerToPOIMap", lat, lng, false, _newPoi.TriggerRadius);
        await ShowSearchResultOnMap(lat, lng, suggestion.DisplayName);
        StateHasChanged();
    }

    private async Task OnTriggerRadiusChanged(double value)
    {
        _newPoi.TriggerRadius = value;

        try
        {
            await JS.InvokeVoidAsync("updateTempRadiusPreviewOnPOIMap", value);
        }
