@page "/map"
@layout PublicLayout
@inject IApiService ApiService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Bản đồ - ZoneGuide</PageTitle>

<div class="map-page">
    <div class="map-search">
        <MudTextField Value="@_searchQuery" Placeholder="Tìm địa điểm..."
                      Variant="Variant.Outlined" Immediate="true"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      ValueChanged="(string? v) => OnSearchChanged(v)" Class="my-2" />
    </div>

    <div class="map-categories">
        <MudChip T="string" Class="map-chip"
                 Color="@(_selectedCategory == null ? Color.Primary : Color.Default)"
                 OnClick="@((MouseEventArgs _) => FilterByCategory(null))">Tất cả</MudChip>
        @foreach (var cat in _categories)
        {
            <MudChip T="string" Class="map-chip"
                     Color="@(_selectedCategory == cat ? Color.Primary : Color.Default)"
                     OnClick="@((MouseEventArgs _) => FilterByCategory(cat))">@cat</MudChip>
        }
    </div>

    <div id="public-map"></div>

    <div class="map-geoloc-btn" @onclick="@((MouseEventArgs _) => CenterOnUser())">
        <MudIconButton Icon="@Icons.Material.Filled.MyLocation" Color="Color.Primary" Size="Size.Small" />
    </div>

    <div class="map-bottom-sheet @(_showBottomSheet ? "open" : "")">
        <div class="map-bottom-sheet-handle"></div>
        <MudText Typo="Typo.subtitle1" Class="map-bottom-title">Địa điểm</MudText>
        <div class="map-bottom-list">
            @if (_filteredPOIs is null)
            {
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="ma-4" />
            }
            else if (_filteredPOIs.Count == 0)
            {
                <MudText Class="mud-text-secondary ma-4">Không có địa điểm</MudText>
            }
            else
            {
                @foreach (var poi in _filteredPOIs)
                {
                    <div class="map-bottom-item" @onclick="@((MouseEventArgs _) => NavigateToPoi(poi.Id))">
                        <div class="map-bottom-thumb">
                            @if (!string.IsNullOrEmpty(poi.ImageUrl))
                            {
                                <img src="@poi.ImageUrl" alt="@poi.Name" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                            }
                        </div>
                        <div class="map-bottom-info">
                            <MudText Typo="Typo.subtitle2" Class="map-bottom-name">@poi.Name</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@poi.Category</MudText>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
@@media (prefers-color-scheme: dark) {
    .map-bottom-sheet { background: #1e1e1e; }
    .map-bottom-item:hover { background: #2a2a2a; }
    .map-bottom-name { color: var(--text-primary); }
}
.map-page {
    position: relative;
    width: 100%;
    height: calc(100vh - 52px - 64px);
}
.map-search {
    position: absolute;
    top: 6px;
    left: 8px;
    right: 8px;
    z-index: 1000;
}
.map-search ::deep .mud-input-outlined-border {
    border-color: transparent !important;
}
.map-search ::deep .mud-input {
    background: white;
    border-radius: 28px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
}
.map-categories {
    position: absolute;
    top: 56px;
    left: 8px;
    right: 8px;
    z-index: 1000;
    display: flex;
    gap: 6px;
    overflow-x: auto;
    padding: 2px 0;
    -webkit-overflow-scrolling: touch;
}
.map-categories::-webkit-scrollbar { display: none; }
.map-chip {
    flex-shrink: 0;
}
#public-map {
    width: 100%;
    height: 100%;
    z-index: 1;
}
.map-geoloc-btn {
    position: absolute;
    bottom: 240px;
    right: 12px;
    z-index: 1000;
    background: white;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
}
.map-bottom-sheet {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--bg-card);
    border-radius: 20px 20px 0 0;
    box-shadow: 0 -4px 16px var(--shadow-color);
    max-height: 45vh;
    transition: transform 0.3s ease;
    transform: translateY(calc(100% - 52px));
    overflow: hidden;
}
.map-bottom-sheet.open {
    transform: translateY(0);
}
.map-bottom-sheet-handle {
    width: 36px;
    height: 4px;
    background: #ddd;
    border-radius: 2px;
    margin: 8px auto;
}
.map-bottom-title {
    padding: 0 16px 8px;
    font-weight: 600;
}
.map-bottom-list {
    max-height: calc(45vh - 60px);
    overflow-y: auto;
    padding: 0 8px 8px;
}
.map-bottom-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border-radius: 10px;
    cursor: pointer;
}
.map-bottom-item:hover {
    background: #f8f9fa;
}
.map-bottom-thumb {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e3f2fd;
    color: #1976D2;
}
.map-bottom-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.map-bottom-info {
    flex: 1;
    overflow: hidden;
}
.map-bottom-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>

@code {
    private List<POIDto>? _allPOIs;
    private List<POIDto>? _filteredPOIs;
    private List<string> _categories = new();
    private string? _selectedCategory;
    private string _searchQuery = "";
    private bool _showBottomSheet;
    private DotNetObjectReference<PublicMap>? _dotNetRef;
    private bool _mapInitialized;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _allPOIs = await ApiService.GetPOIsAsync();
            _categories = _allPOIs
                .Where(p => !string.IsNullOrEmpty(p.Category))
                .Select(p => p.Category!)
                .Distinct()
                .OrderBy(c => c)
                .ToList();
            _filteredPOIs = _allPOIs;
            _showBottomSheet = _filteredPOIs.Count > 0;

            var poiData = _allPOIs.Select(p => new
            {
                id = p.Id,
                name = p.Name,
                lat = p.Latitude,
                lng = p.Longitude,
                category = p.Category ?? "POI"
            }).ToArray();

            double centerLat = _allPOIs.Any() ? _allPOIs.Average(p => p.Latitude) : 10.762622;
            double centerLng = _allPOIs.Any() ? _allPOIs.Average(p => p.Longitude) : 106.660172;

            await JS.InvokeVoidAsync("initPublicMap", "public-map", centerLat, centerLng, poiData, _dotNetRef);
            _mapInitialized = true;
            StateHasChanged();
        }
    }

    private void FilterByCategory(string? category)
    {
        _selectedCategory = category;
        ApplyFilter();
    }

    private void OnSearchChanged(string? value)
    {
        _searchQuery = value ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        var query = _searchQuery.Trim().ToLowerInvariant();
        _filteredPOIs = _allPOIs?
            .Where(p => (string.IsNullOrEmpty(_selectedCategory) || p.Category == _selectedCategory) &&
                        (string.IsNullOrEmpty(query) || p.Name?.ToLowerInvariant().Contains(query) == true))
            .ToList();
        StateHasChanged();
    }

    private async Task CenterOnUser()
    {
        await JS.InvokeVoidAsync("navigator.geolocation.getCurrentPosition",
            "window.publicMapCenter",
            "console.error",
            null);
    }

    private void NavigateToPoi(string id)
    {
        if (int.TryParse(id, out var poiId))
            Navigation.NavigateTo($"/poi/{poiId}");
    }

    [JSInvokable]
    public void OnPoiClick(int poiId)
    {
        Navigation.NavigateTo($"/poi/{poiId}");
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        try { await JS.InvokeVoidAsync("destroyPublicMap"); } catch { }
    }
}
