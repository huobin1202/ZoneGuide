@page "/users"
@using ZoneGuide.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Navigation

<PageTitle>ZoneGuide</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
       
        <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="@(() => OpenUserFormDialog())">
            Thêm người dùng
        </MudButton>
    </MudStack>
    
    <MudPaper Elevation="2" Class="pa-4">
        <MudTable Items="@users" Hover="true" Striped="true" Loading="@isLoading" LoadingProgressColor="Color.Primary"
                  Dense="true" Filter="new Func<UserDto, bool>(FilterFunc)">
            <ToolBarContent>
                <MudTextField @bind-Value="searchString" Placeholder="Tìm kiếm..." Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
                <MudSpacer />
                <MudChipSet SelectedValueChanged="OnRoleFilterChanged" T="string">
                    <MudChip Value="@("Tất cả")" Default="true" Color="Color.Default" Variant="Variant.Text">Tất cả</MudChip>
                    <MudChip Value="@("Admin")" Color="Color.Error" Variant="Variant.Text">Admin</MudChip>
                    <MudChip Value="@("Contributor")" Color="Color.Warning" Variant="Variant.Text">Contributor</MudChip>
                </MudChipSet>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Tên hiển thị</MudTh>
                <MudTh>Role</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Ngày tạo</MudTh>
                <MudTh>Đăng nhập cuối</MudTh>
                <MudTh>Hành động</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Tên">@context.DisplayName</MudTd>
                <MudTd DataLabel="Role">
                    <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small">@context.Role</MudChip>
                </MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@GetStatusText(context.Status)</MudChip>
                </MudTd>
                <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Đăng nhập cuối">@(context.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
                <MudTd DataLabel="Hành động">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenUserFormDialog(context))" title="Sửa người dùng" />
                    <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Info" Size="Size.Small"
                                   OnClick="@(() => OpenUserHistory())" title="Lịch sử" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Không có user nào</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Đang tải...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<UserDto> users = new();
    private bool isLoading = true;
    private string searchString = string.Empty;
    private string? roleFilter = null;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await LocalStorage.GetItemAsync<string>("accessToken");
            if (string.IsNullOrEmpty(token))
            {
                Navigation.NavigateTo("/login");
                return;
            }
            await LoadUsers();
            StateHasChanged();
        }
    }    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<UserDto>>("api/users");
            users = response?.Where(u => u.Role == "Admin" || u.Role == "Contributor").ToList() ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải danh sách: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private bool FilterFunc(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(searchString) && string.IsNullOrEmpty(roleFilter))
            return true;
        
        var matchSearch = string.IsNullOrWhiteSpace(searchString) ||
                          user.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                          user.DisplayName.Contains(searchString, StringComparison.OrdinalIgnoreCase);
        
        var matchRole = string.IsNullOrEmpty(roleFilter) || roleFilter == "Tất cả" ||
                        user.Role.Equals(roleFilter, StringComparison.OrdinalIgnoreCase);
        
        return matchSearch && matchRole;
    }
    
    private void OnRoleFilterChanged(string? value)
    {
        roleFilter = value;
        StateHasChanged();
    }
    
    private async Task OpenUserFormDialog(UserDto? user = null)
    {
        var parameters = new DialogParameters();
        if (user != null)
        {
            parameters.Add("User", user);
        }

        var title = user == null ? "Thêm người dùng" : "Chỉnh sửa người dùng";
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UserFormDialog>(title, parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadUsers();
        }
    }

    private void OpenUserHistory()
    {
        Navigation.NavigateTo("/activity-log?entityType=User");
    }
    
    private Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "Contributor" => Color.Warning,
        _ => Color.Info
    };
    
    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Suspended" => Color.Error,
        _ => Color.Default
    };
    
    private string GetStatusText(string status) => status switch
    {
        "Active" => "Hoạt động",
        "Suspended" => "Đã khóa",
        _ => status
    };
}
