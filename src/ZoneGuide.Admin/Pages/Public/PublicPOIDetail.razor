@page "/poi/{Id:int}"
@layout PublicLayout
@using ZoneGuide.Admin.Shared.Components
@inject IApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AudioPlayerInterop AudioInterop
@implements IAsyncDisposable

<PageTitle>@(_poi?.Name ?? "Địa điểm")</PageTitle>

@if (_poi is null)
{
    <div class="poi-detail-loading">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Class="mt-4">Đang tải...</MudText>
    </div>
}
else
{
    <div class="poi-detail">
        <div class="poi-hero" style="background-image: @(_imageBg)">
            <div class="poi-hero-overlay">
                @if (!string.IsNullOrEmpty(_poi.Category))
                {
                    <div class="poi-hero-category">@_poi.Category</div>
                }
                <MudText Typo="Typo.h4" Class="poi-hero-name">@_displayName</MudText>
                <MudText Typo="Typo.body2" Class="poi-hero-address">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" /> @_poi.Address
                </MudText>
            </div>
        </div>

        <div class="poi-content">
            <div class="poi-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           Disabled="@(!_canPlay)"
                           OnClick="@((MouseEventArgs _) => PlayNarration())">
                    Nghe giới thiệu
                </MudButton>
            </div>

            @if (!string.IsNullOrEmpty(_displayScript))
            {
                <div class="poi-section">
                    <MudText Typo="Typo.h6" Class="section-label">Giới thiệu</MudText>
                    <MudText Typo="Typo.body2" Class="poi-script">@_displayScript</MudText>
                </div>
            }

            <div class="poi-section">
                <MudText Typo="Typo.h6" Class="section-label">Thông tin</MudText>
                <MudPaper Class="poi-info-card" Elevation="0">
                    <div class="poi-info-row">
                        <span class="poi-info-label">Khoảng cách</span>
                        <span class="poi-info-value">~@(_poi.TriggerRadius) m</span>
                    </div>
                    <div class="poi-info-row">
                        <span class="poi-info-label">Ngôn ngữ</span>
                        <span class="poi-info-value">@(_poi.Language ?? "vi-VN")</span>
                    </div>
                </MudPaper>
            </div>

            <div class="poi-section">
                <MudText Typo="Typo.h6" Class="section-label">Vị trí</MudText>
                <div id="poi-mini-map" class="poi-mini-map"></div>
            </div>
        </div>

        @if (_hasTranslations)
        {
            <div class="poi-section px-4">
                <MudText Typo="Typo.h6" Class="section-label">Ngôn ngữ</MudText>
                <div class="language-chips">
                    @foreach (var lang in _translations)
                    {
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small"
                                 OnClick="@((MouseEventArgs _) => SwitchLanguage(lang.LanguageCode))">
                            @lang.LanguageCode
                        </MudChip>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
@@media (prefers-color-scheme: dark) {
    .poi-info-card { background: #1e1e1e !important; }
    .poi-script { color: #bbb !important; }
}
.poi-detail-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    color: #666;
}
.poi-hero {
    width: 100%;
    height: 220px;
    background-size: cover;
    background-position: center;
    position: relative;
}
.poi-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 20px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    color: white;
}
.poi-hero-category {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 12px;
    margin-bottom: 6px;
}
.poi-hero-name {
    font-weight: 700;
    margin-bottom: 4px;
}
.poi-hero-address {
    opacity: 0.85;
    display: flex;
    align-items: center;
    gap: 4px;
}
.poi-content {
    padding: 16px;
}
.poi-actions {
    margin-bottom: 20px;
}
.poi-section {
    margin-bottom: 20px;
}
.section-label {
    font-weight: 600;
    margin-bottom: 8px;
}
.poi-script {
    line-height: 1.6;
    color: #444;
}
.poi-info-card {
    padding: 12px 16px;
    background: #f8f9fa;
    border-radius: 12px;
}
.poi-info-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
}
.poi-info-label {
    color: #666;
}
.poi-info-value {
    font-weight: 500;
}
.language-chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}
.px-4 {
    padding-left: 16px;
    padding-right: 16px;
}
.poi-mini-map {
    width: 100%;
    height: 160px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 4px var(--shadow-color);
}
@@media (prefers-color-scheme: dark) {
    .poi-mini-map { filter: invert(0.9) hue-rotate(180deg); }
}
</style>

@code {
    [Parameter] public int Id { get; set; }

    private POIDto? _poi;
    private POIDto? _originalPoi;
    private List<POITranslationDto> _translations = new();
    private string _audioUrl = "";
    private bool _hasTranslations;
    private bool _canPlay;
    private string _imageBg = "background:linear-gradient(135deg,#1976D2,#1565C0)";
    private string _displayName = "";
    private string _displayScript = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadPOI();
    }

    private async Task LoadPOI()
    {
        try
        {
            _poi = await ApiService.GetPOIAsync(Id.ToString());
            if (_poi != null)
            {
                _originalPoi = new POIDto
                {
                    Id = _poi.Id,
                    Name = _poi.Name,
                    Category = _poi.Category,
                    Address = _poi.Address,
                    ImageUrl = _poi.ImageUrl,
                    Latitude = _poi.Latitude,
                    Longitude = _poi.Longitude,
                    TriggerRadius = _poi.TriggerRadius,
                    Language = _poi.Language,
                    AudioUrl = _poi.AudioUrl,
                    TTSScript = _poi.TTSScript
                };

                _audioUrl = _poi.AudioUrl ?? "";
                _canPlay = !string.IsNullOrEmpty(_audioUrl) || !string.IsNullOrEmpty(_poi.TTSScript);

                if (!string.IsNullOrEmpty(_poi.ImageUrl))
                    _imageBg = $"background-image:url('{_poi.ImageUrl}')";

                _displayName = _poi.Name;
                _displayScript = _poi.TTSScript ?? "";

                try
                {
                    _translations = await ApiService.GetPOITranslationsAsync(Id.ToString());
                    _hasTranslations = _translations.Count > 0;
                }
                catch { }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading POI {Id}: {ex.Message}");
        }
    }

    private async Task PlayNarration()
    {
        if (_poi == null || !_canPlay) return;

        var url = _audioUrl;

        if (string.IsNullOrEmpty(url) && !string.IsNullOrEmpty(_poi.TTSScript))
        {
            var apiBase = Navigation.BaseUri.TrimEnd('/');
            url = $"{apiBase}/api/tts/generate";
        }

        if (!string.IsNullOrEmpty(url))
        {
            await AudioInterop.RequestPlayAsync(new AudioTrack
            {
                Name = _displayName,
                Url = url
            });
        }
    }

    private async Task SwitchLanguage(string languageCode)
    {
        var translation = _translations.FirstOrDefault(t => t.LanguageCode == languageCode);
        if (translation == null) return;

        _displayName = translation.Name ?? _originalPoi?.Name ?? _poi?.Name ?? "";
        _displayScript = translation.TTSScript ?? _originalPoi?.TTSScript ?? _poi?.TTSScript ?? "";
        _audioUrl = translation.AudioUrl ?? _originalPoi?.AudioUrl ?? _poi?.AudioUrl ?? "";
        _canPlay = !string.IsNullOrEmpty(_audioUrl) || !string.IsNullOrEmpty(_displayScript);
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _poi != null)
        {
            if (_poi.Latitude != 0 && _poi.Longitude != 0)
                await JS.InvokeVoidAsync("initPoiMiniMap", "poi-mini-map", _poi.Latitude, _poi.Longitude, _poi.Name);

            var entry = JsonSerializer.Serialize(new
            {
                id = _poi.Id,
                name = _poi.Name,
                category = _poi.Category ?? "",
                imageUrl = _poi.ImageUrl,
                timestamp = DateTime.Now.ToString("o"),
                durationSeconds = 0,
                language = _poi.Language ?? "vi",
                playCount = 1
            });
            await JS.InvokeVoidAsync("ZoneGuideApp.addHistoryEntry", entry);
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("destroyPoiMiniMap"); } catch { }
    }
}
