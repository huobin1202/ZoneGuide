@page "/poi-map"
@inject IApiService ApiService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudText Typo="Typo.h4" Class="mb-4">POI Map View</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.body1">
                Bản đồ hiển thị tất cả các điểm POI đã tạo. Click vào marker để xem thông tin chi tiết.
            </MudText>
        </MudItem>
        <MudItem xs="12" md="4" Class="d-flex justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadPOIs">
                Refresh
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Class="pa-0" Elevation="2" Style="height: 600px; position: relative;">
        <div id="poi-map" style="width: 100%; height: 100%;"></div>
    </MudPaper>
    
    <MudPaper Class="pa-4 mt-4" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-2">Danh sách POI (@_pois.Count điểm)</MudText>
        <MudTable Items="@_pois" Dense="true" Hover="true" Bordered="true" Striped="true">
            <HeaderContent>
                <MudTh>Tên</MudTh>
                <MudTh>Vĩ độ</MudTh>
                <MudTh>Kinh độ</MudTh>
                <MudTh>Danh mục</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Hành động</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tên">@context.Name</MudTd>
                <MudTd DataLabel="Vĩ độ">@context.Latitude.ToString("F6")</MudTd>
                <MudTd DataLabel="Kinh độ">@context.Longitude.ToString("F6")</MudTd>
                <MudTd DataLabel="Danh mục">@context.Category</MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                        @(context.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Hành động">
                    <MudIconButton Icon="@Icons.Material.Filled.MyLocation" Size="Size.Small" 
                                   Color="Color.Primary"
                                   OnClick="@(() => CenterOnPOI(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small"
                                   OnClick="@(() => OpenInGoogleMaps(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<POIDto> _pois = new();
    private bool _loading = true;
    private bool _mapInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPOIs();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_mapInitialized && _pois.Any())
        {
            _mapInitialized = true;
            await InitializeMap();
        }
    }

    private async Task LoadPOIs()
    {
        _loading = true;
        _mapInitialized = false;
        StateHasChanged();
        
        _pois = await ApiService.GetPOIsAsync();
        
        _loading = false;
        StateHasChanged();
    }

    private async Task InitializeMap()
    {
        try
        {
            // Tính center của map dựa trên POIs
            double centerLat = _pois.Any() ? _pois.Average(p => p.Latitude) : 10.762622;
            double centerLng = _pois.Any() ? _pois.Average(p => p.Longitude) : 106.660172;

            var poiData = _pois.Select(p => new
            {
                id = p.Id,
                name = p.Name,
                lat = p.Latitude,
                lng = p.Longitude,
                description = p.ShortDescription ?? "",
                category = p.Category ?? "POI"
            }).ToArray();

            await JS.InvokeVoidAsync("initPOIMap", "poi-map", centerLat, centerLng, poiData);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khởi tạo bản đồ: {ex.Message}", Severity.Error);
        }
    }

    private async Task CenterOnPOI(POIDto poi)
    {
        try
        {
            await JS.InvokeVoidAsync("centerMapOnPOI", poi.Latitude, poi.Longitude, poi.Name);
        }
        catch
        {
            Snackbar.Add("Không thể di chuyển đến vị trí", Severity.Warning);
        }
    }

    private async Task OpenInGoogleMaps(POIDto poi)
    {
        var url = $"https://www.google.com/maps?q={poi.Latitude},{poi.Longitude}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
