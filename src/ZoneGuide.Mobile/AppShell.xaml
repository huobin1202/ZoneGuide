<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ZoneGuide.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Địa điểm"
            ContentTemplate="{DataTemplate views:POIListPage}"
            Icon="location.png"
            Route="pois" />

        <ShellContent
            Title="Bản đồ"
            ContentTemplate="{DataTemplate views:MapPage}"
            Icon="map.png"
            Route="map" />

        <ShellContent
            Title="Lịch sử"
            ContentTemplate="{DataTemplate views:HistoryPage}"
            Icon="history.png"
            Route="history" />

        <ShellContent
            Title="Tour"
            ContentTemplate="{DataTemplate views:TourListPage}"
            Icon="route.png"
            Route="tours" />

        <ShellContent
            Title="Cài đặt"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Icon="settings.png"
            Route="settings" />
    </TabBar>

</Shell>
