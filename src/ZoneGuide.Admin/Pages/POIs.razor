@page "/pois"
@using System.Net.Http.Json
@inject IApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject HttpClient Http
@inject WebTtsService WebTts

<MudGrid Spacing="0">
    <!-- Sidebar / List Area -->
    <MudItem xs="12" md="4" Style="height: calc(100vh - 64px); display: flex; flex-direction: column; border-right: 1px solid var(--mud-palette-lines-default); background-color: #f7f9fa;">
    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" ActivePanelIndex="@_activeTabIndex" ActivePanelIndexChanged="OnActiveTabIndexChanged" Style="flex-grow: 1; display: flex; flex-direction: column; background-color: #f7f9fa;">
            <MudTabPanel Text="@($"Danh sách ({ActivePoiCount})")">
                @if (_isEditMode)
                {
                    <div style="flex-grow: 1; overflow-y: auto; height: calc(100vh - 120px);" class="px-4 pb-4 pt-4">
                        <div class="d-flex justify-space-between align-center mb-1">
                            <MudText Typo="Typo.h6">
                                <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-2"/>
                                Chỉnh sửa địa điểm
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelEdit" />
                        </div>
                        
                        <MudForm @ref="_editForm" @bind-IsValid="_isValid">
                            <MudAutocomplete T="AddressSuggestion"
                                             Text="@_poiAddressQuery"
                                             TextChanged="OnPoiAddressTextChanged"
                                             Value="@_selectedPoiAddressSuggestion"
                                             ValueChanged="OnPoiAddressSuggestionSelected"
                                             SearchFunc="SearchPoiAddressSuggestionsAsync"
                                             ToStringFunc="@(item => item?.DisplayName)"
                                             Label="Địa chỉ"
                                             Placeholder="Nhập địa chỉ để gợi ý..."
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                             ResetValueOnEmptyText="true"
                                             DebounceInterval="250"
                                             MaxItems="5"
                                             Class="mt-3" />
                            @if (!string.IsNullOrWhiteSpace(_poiAddressStatus))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 d-block">@_poiAddressStatus</MudText>
                            }

                            <MudTextField @bind-Value="_newPoi.Name" Label="Tên địa điểm" Required="true" 
                                          RequiredError="Tên là bắt buộc" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
                            
                            <MudText Typo="Typo.caption" Class="mb-1 mt-3 d-block">Danh mục</MudText>
                            <div class="d-flex gap-2" style="overflow-x: auto; padding-bottom: 4px;">
                                @foreach(var cat in new[] { ("Du lịch", Icons.Material.Filled.Museum), ("Dịch vụ", Icons.Material.Filled.MiscellaneousServices), ("Ăn uống", Icons.Material.Filled.LocalDining), ("Giải trí", Icons.Material.Filled.EmojiEvents), ("Mua sắm", Icons.Material.Filled.LocalMall), ("Khác", Icons.Material.Filled.Place) })
                                {
                                    var isSelected = _newPoi.Category == cat.Item1;
                                    <div @onclick="() => _newPoi.Category = cat.Item1" 
                                         style="@($"cursor: pointer; min-width: 64px; height: 60px; border-radius: 8px; border: {(isSelected ? "2px solid var(--mud-palette-primary)" : "1px solid var(--mud-palette-lines-default)")}; display: flex; flex-direction: column; align-items: center; justify-content: center; background-color: {(isSelected ? "var(--mud-palette-primary-hover)" : "transparent")};")">
                                        <MudIcon Icon="@cat.Item2" Color="@(isSelected ? Color.Primary : Color.Error)" Size="Size.Small" />
                                        <span style="font-size: 10px; margin-top: 4px; color: @(isSelected ? "var(--mud-palette-primary)" : "inherit")">@cat.Item1</span>
                                    </div>
                                }
                            </div>

                            <MudTextField @bind-Value="_newPoi.TTSScript" Label="Nội dung thuyết minh (TTS)" 
                                          Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />

                            <MudGrid Class="mt-1">
                                <MudItem xs="12" sm="6">
                                    <MudNumericField T="double" Value="_newPoi.TriggerRadius"
                                                     ValueChanged="OnTriggerRadiusChanged"
                                                     Label="Bán kính kích hoạt (m)" Min="20" Max="300"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudNumericField T="double" @bind-Value="_newPoi.ApproachRadius"
                                                     Label="Bán kính thuyết minh (m)" Min="20" Max="500"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                            </MudGrid>

                            <MudGrid Class="mt-1">
                                <MudItem xs="12" sm="6">
                                    <MudNumericField T="double" @bind-Value="_newPoi.Latitude"
                                                     Label="Vĩ độ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     Step="0.000001" Culture="@System.Globalization.CultureInfo.InvariantCulture" />
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <MudNumericField T="double" @bind-Value="_newPoi.Longitude"
                                                     Label="Kinh độ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                     Step="0.000001" Culture="@System.Globalization.CultureInfo.InvariantCulture" />
                                </MudItem>
                            </MudGrid>

                            <MudNumericField T="int" @bind-Value="_newPoi.Priority"
                                             Label="Độ ưu tiên" Min="1" Max="10"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1" />

                            <MudFileUpload T="IBrowserFile" Accept=".png, .jpg, .jpeg" FilesChanged="UploadImage" Class="mt-3">
                                <ActivatorContent>
                                    <div class="poi-upload-frame">
                                        <button type="button" class="poi-upload-box">
                                            @if (string.IsNullOrWhiteSpace(_newPoi.ImageUrl))
                                            {
                                                <span class="poi-upload-placeholder">
                                                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Medium" />
                                                    <span>Tải lên hình ảnh</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <img src="@_newPoi.ImageUrl" alt="Ảnh địa điểm" class="poi-upload-preview" />
                                            }
                                        </button>
                                        @if (!string.IsNullOrWhiteSpace(_newPoi.ImageUrl))
                                        {
                                            <button type="button" class="poi-upload-remove"
                                                    @onclick="@(() => _newPoi.ImageUrl = null)"
                                                    @onclick:stopPropagation="true"
                                                    @onclick:preventDefault="true"
                                                    title="Xóa ảnh">×</button>
                                        }
                                    </div>
                                </ActivatorContent>
                            </MudFileUpload>
                            
                            <MudSwitch @bind-Value="_newPoi.IsActive" Label="Kích hoạt" Color="Color.Primary" Class="mt-3" />

                            <div class="d-flex justify-space-between mt-4 pb-4">
                                <MudButton OnClick="CancelEdit" Variant="Variant.Outlined">Hủy</MudButton>
                                <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                                           OnClick="SavePOI" Disabled="@(!_isValid || _saving)">
                                    @if (_saving)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    }
                                    Cập nhật
                                </MudButton>
                            </div>
                        </MudForm>
                    </div>
                }
                else
                {
                    <MudPaper Elevation="1" Class="pa-4 flex-grow-0 panel-card">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <div>
                                <MudText Typo="Typo.h6">Địa điểm</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@ActivePoiCount tổng • @FilteredPOIs.Count() đang hiển thị</MudText>
                            </div>
                            
                        </div>
                        <div class="mb-2">
                            <MudTextField @bind-Value="_searchString" Placeholder="Tìm kiếm địa điểm..." 
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                          Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="w-100" />
                        </div>
                        <div class="d-flex gap-2 mb-2">
                            <MudSelect T="string" Label="Danh mục" @bind-Value="_selectedCategory" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true" Class="filter-select">
                                <MudSelectItem Value="@( "Tất cả")" />
                                <MudSelectItem Value="@( "Du lịch")" />
                                <MudSelectItem Value="@( "Dịch vụ")" />
                                <MudSelectItem Value="@( "Ăn uống")" />
                                <MudSelectItem Value="@( "Giải trí")" />
                                <MudSelectItem Value="@( "Mua sắm")" />
                                <MudSelectItem Value="@( "Khác")" />
                            </MudSelect>
                            <MudSelect T="string" Label="Trạng thái" @bind-Value="_selectedStatus" Variant="Variant.Outlined" Margin="Margin.Dense" Class="filter-select">
                                <MudSelectItem Value="@( "Tất cả")" />
                                <MudSelectItem Value="@( "Đang bật")" />
                                <MudSelectItem Value="@( "Đã tắt")" />
                            </MudSelect>
                        </div>
                    </MudPaper>

                    <div style="flex-grow: 1; overflow-y: auto; background-color: #f7f9fa; height: calc(100vh - 290px);" class="pa-4">
                        @if (_loading)
                        {
                            <div class="d-flex justify-center my-4">
                                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            </div>
                        }
                        else
                        {
                            @foreach (var poi in FilteredPOIs)
                            {
                                <MudCard id="@($"poi-card-{poi.Id}")" Class="@($"mb-3 poi-card {GetPoiCardClass(poi)}")" @onclick="@(() => CenterOnPOI(poi))">
                                    <div class="poi-card-body">
                                        <img class="poi-thumb-img" src="@(string.IsNullOrEmpty(poi.ImageUrl) ? "/images/placeholder.png" : poi.ImageUrl)" alt="Ảnh địa điểm" />
                                        <div class="poi-main">
                                            <div class="d-flex justify-space-between align-start gap-2 mb-1">
                                                <div class="poi-title-wrap" title="@poi.Name">
                                                    <MudTooltip Text="@GetPoiDescriptionOrFallback(poi)">
                                                        <MudText Typo="Typo.subtitle1" Class="poi-name-ellipsis"><b>@poi.Name</b></MudText>
                                                    </MudTooltip>
                                                </div>
                                                <div class="d-flex gap-1 poi-card-actions">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" title="Chỉnh sửa" OnClick="@(() => OpenEditMode(poi))" />
                                                    <MudIconButton Icon="@(poi.IsActive ? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                                                   Size="Size.Small"
                                                                   Color="@(poi.IsActive ? Color.Success : Color.Warning)"
                                                                   title="@(poi.IsActive ? "Chuyển sang đã tắt" : "Chuyển sang đang bật")"
                                                                   OnClick="@(() => TogglePoiStatus(poi))" />
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 mb-1 flex-wrap">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ma-0">@(poi.Category ?? "Khác")</MudChip>
                                                <MudChip T="string" Size="Size.Small" Color="@(poi.IsActive ? Color.Success : Color.Default)" Class="ma-0">@(poi.IsActive ? "Đang bật" : "Đã tắt")</MudChip>
                                            </div>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1 d-flex align-center gap-1">
                                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" />
                                                <span class="poi-address-ellipsis" title="@DisplayAddressOrFallback(poi.Address)">@DisplayAddressOrFallback(poi.Address)</span>
                                            </MudText>
                                            <MudTooltip Text="@GetPoiDescriptionOrFallback(poi)">
                                                <MudText Typo="Typo.body2" Color="Color.Default" Class="clamp-2">
                                                    @(poi.TTSScript ?? poi.FullDescription ?? poi.ShortDescription ?? "Chưa có nội dung thuyết minh")
                                                </MudText>
                                            </MudTooltip>
                                        </div>
                                    </div>
                                </MudCard>
                            }
                            
                            @if (!FilteredPOIs.Any())
                            {
                                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mt-4">Không tìm thấy địa điểm nào.</MudText>
                            }
                        }
                    </div>
                }
            </MudTabPanel>

            <MudTabPanel Text="+ Thêm mới">
                <div style="flex-grow: 1; overflow-y: auto; height: calc(100vh - 120px);" class="px-4 pb-4 pt-4">
                    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Small" />
                        Click vào bản đồ để chọn tọa độ
                    </MudText>
                    
                    <MudForm @ref="_createForm" @bind-IsValid="_isValid">
                        <MudAutocomplete T="AddressSuggestion"
                                         Text="@_poiAddressQuery"
                                         TextChanged="OnPoiAddressTextChanged"
                                         Value="@_selectedPoiAddressSuggestion"
                                         ValueChanged="OnPoiAddressSuggestionSelected"
                                         SearchFunc="SearchPoiAddressSuggestionsAsync"
                                         ToStringFunc="@(item => item?.DisplayName)"
                                         Label="Địa chỉ"
                                         Placeholder="Nhập địa chỉ để gợi ý..."
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Adornment="Adornment.Start"
                                         AdornmentIcon="@Icons.Material.Filled.LocationOn"
                                         ResetValueOnEmptyText="true"
                                         DebounceInterval="250"
                                         MaxItems="5"
                                         Class="mt-3" />
                        @if (!string.IsNullOrWhiteSpace(_poiAddressStatus))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 d-block">@_poiAddressStatus</MudText>
                        }

                        <MudTextField @bind-Value="_newPoi.Name" Label="Tên địa điểm" Required="true" 
                                      RequiredError="Tên là bắt buộc" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-2" />
                        
                        <MudText Typo="Typo.caption" Class="mb-1 mt-3 d-block">Danh mục</MudText>
                        <div class="d-flex gap-2" style="overflow-x: auto; padding-bottom: 4px;">
                            @foreach(var cat in new[] { ("Du lịch", Icons.Material.Filled.Museum), ("Dịch vụ", Icons.Material.Filled.MiscellaneousServices), ("Ăn uống", Icons.Material.Filled.LocalDining), ("Giải trí", Icons.Material.Filled.EmojiEvents), ("Mua sắm", Icons.Material.Filled.LocalMall), ("Khác", Icons.Material.Filled.Place) })
                            {
                                var isSelected = _newPoi.Category == cat.Item1;
                                <div @onclick="() => _newPoi.Category = cat.Item1" 
                                     style="@($"cursor: pointer; min-width: 64px; height: 60px; border-radius: 8px; border: {(isSelected ? "2px solid var(--mud-palette-primary)" : "1px solid var(--mud-palette-lines-default)")}; display: flex; flex-direction: column; align-items: center; justify-content: center; background-color: {(isSelected ? "var(--mud-palette-primary-hover)" : "transparent")};")">
                                    <MudIcon Icon="@cat.Item2" Color="@(isSelected ? Color.Primary : Color.Error)" Size="Size.Small" />
                                    <span style="font-size: 10px; margin-top: 4px; color: @(isSelected ? "var(--mud-palette-primary)" : "inherit")">@cat.Item1</span>
                                </div>
                            }
                        </div>

                        <MudTextField @bind-Value="_newPoi.TTSScript" Label="Nội dung thuyết minh (TTS)" 
                                      Lines="3" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3" />

                        <MudGrid Class="mt-1">
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" Value="_newPoi.TriggerRadius"
                                                 ValueChanged="OnTriggerRadiusChanged"
                                                 Label="Bán kính kích hoạt (m)" Min="20" Max="300"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" @bind-Value="_newPoi.ApproachRadius"
                                                 Label="Bán kính thuyết minh (m)" Min="20" Max="500"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>

                        <MudGrid Class="mt-1">
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" @bind-Value="_newPoi.Latitude"
                                                 Label="Vĩ độ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Step="0.000001" Culture="@System.Globalization.CultureInfo.InvariantCulture" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudNumericField T="double" @bind-Value="_newPoi.Longitude"
                                                 Label="Kinh độ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Step="0.000001" Culture="@System.Globalization.CultureInfo.InvariantCulture" />
                            </MudItem>
                        </MudGrid>

                        <MudNumericField T="int" @bind-Value="_newPoi.Priority"
                                         Label="Độ ưu tiên" Min="1" Max="10"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1" />

                        <MudFileUpload T="IBrowserFile" Accept=".png, .jpg, .jpeg" FilesChanged="UploadImage" Class="mt-3">
                            <ActivatorContent>
                                <div class="poi-upload-frame">
                                    <button type="button" class="poi-upload-box">
                                        @if (string.IsNullOrWhiteSpace(_newPoi.ImageUrl))
                                        {
                                            <span class="poi-upload-placeholder">
                                                <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Medium" />
                                                <span>Tải lên hình ảnh</span>
                                            </span>
                                        }
                                        else
                                        {
                                            <img src="@_newPoi.ImageUrl" alt="Ảnh địa điểm" class="poi-upload-preview" />
                                        }
                                    </button>
                                    @if (!string.IsNullOrWhiteSpace(_newPoi.ImageUrl))
                                    {
                                        <button type="button" class="poi-upload-remove"
                                                @onclick="@(() => _newPoi.ImageUrl = null)"
                                                @onclick:stopPropagation="true"
                                                @onclick:preventDefault="true"
                                                title="Xóa ảnh">×</button>
                                    }
                                </div>
                            </ActivatorContent>
                        </MudFileUpload>
                        
                        <MudSwitch @bind-Value="_newPoi.IsActive" Label="Kích hoạt" Color="Color.Primary" Class="mt-3" />

                        <div class="d-flex justify-space-between mt-4 pb-4">
                            <MudButton OnClick="CancelCreate" Variant="Variant.Outlined">Xóa trống</MudButton>
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                                       OnClick="SavePOI" Disabled="@(!_isValid || _saving)">
                                @if (_saving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Thêm
                            </MudButton>
                        </div>
                    </MudForm>
                </div>
            </MudTabPanel>
        </MudTabs>
    </MudItem>

    <!-- Map Area -->
    <MudItem xs="12" md="8" Style="height: calc(100vh - 64px); position: relative;">
        <div id="poi-map" style="width: 100%; height: 100%; z-index: 1;"></div>
        <MudPaper Elevation="8" Class="pa-3 map-overlay" Style="top: 10px; left: 50px; width: 320px;">
            <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Primary">Tìm kiếm trên bản đồ</MudText>
            <div class="d-flex align-center gap-2">
                <MudAutocomplete T="MapSearchSuggestion"
                                 Text="@_mapSearchQuery"
                                 TextChanged="OnMapSearchTextChanged"
                                 Value="@_selectedMapSuggestion"
                                 ValueChanged="OnMapSuggestionSelected"
                                 SearchFunc="SearchMapSuggestionsAsync"
                                 ToStringFunc="@(item => item?.DisplayName)"
                                 Placeholder="Nhập địa chỉ hoặc địa danh..."
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 Immediate="true"
                                 ResetValueOnEmptyText="true"
                                 DebounceInterval="250"
                                 MaxItems="5"
                                 Class="flex-grow-1"
                                 OnKeyDown="@(async e => { if (e.Key == "Enter") await SearchOnMap(); })" />
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary" Variant="Variant.Filled" OnClick="SearchOnMap" title="Tìm vị trí" />
            </div>
        </MudPaper>
        
      
    </MudItem>
</MudGrid>

<style>
    .hover-effect:hover {
        box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
        transform: translateY(-2px);
        transition: all 0.2s ease-in-out;
    }
    .panel-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e7ebf0;
    }
    .poi-card {
        border: 1px solid #e7ebf0;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.04);
    }
    .poi-card.poi-card-selected {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.16), 0 14px 30px rgba(37,99,235,0.12);
        background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
    }
    .poi-card-body { display: flex; gap: 12px; padding: 12px; align-items: flex-start; }
    .poi-thumb-img {
        width: 88px;
        height: 88px;
        object-fit: cover;
        border-radius: 12px;
        background: #f0f2f5;
        flex-shrink: 0;
    }
    .poi-main { flex: 1; min-width: 0; }
    .poi-title-wrap { flex: 1; min-width: 0; }
    .poi-name-ellipsis {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .poi-card-actions { flex-shrink: 0; }
    .poi-address-ellipsis {
        display: inline-block;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .map-overlay {
        position: absolute;
        z-index: 2;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(8px);
        border-radius: 12px;
        box-shadow: 0 14px 30px rgba(0,0,0,0.16);
        border: 1px solid #e7ebf0;
    }
    .filter-select { min-width: 140px; }
    .poi-upload-box {
        width: 100%;
        min-height: 170px;
        border-radius: 12px;
        border: 2px dashed var(--mud-palette-primary);
        background: #f8fbff;
        padding: 0;
        cursor: pointer;
        overflow: hidden;
        display: block;
    }
    .poi-upload-frame {
        position: relative;
    }
    .poi-upload-placeholder {
        min-height: 170px;
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 8px;
        color: var(--mud-palette-primary);
        font-weight: 600;
    }
    .poi-upload-preview {
        width: 100%;
