<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
             x:Class="ZoneGuide.Mobile.Views.TourDetailPage"
             x:Name="PageRoot"
             x:DataType="vm:TourDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F3F4F6"
             Title="{Binding Tour.Name}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="0,0,0,360"
                                 Spacing="0">
                <Grid HeightRequest="308">
                    <Image Source="{Binding Tour.ThumbnailUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                           Aspect="AspectFill"
                           BackgroundColor="#D1D5DB" />

                    <BoxView Color="#26000000" />

                    <Grid Padding="16,52,16,18"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">
                        <Border Grid.Column="0"
                                WidthRequest="52"
                                HeightRequest="52"
                                BackgroundColor="#F2FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 26">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked" />
                            </Border.GestureRecognizers>
                            <Label Text="‹"
                                   FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="#111827" />
                        </Border>

                        <HorizontalStackLayout Grid.Column="2"
                                               Spacing="10">
                            <Border WidthRequest="52"
                                    HeightRequest="52"
                                    BackgroundColor="#F2FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 26">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSearchTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="⌕"
                                       FontSize="26"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="#111827" />
                            </Border>

                            <Border WidthRequest="52"
                                    HeightRequest="52"
                                    BackgroundColor="#F2FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 26">
                                <Label Text="♡"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="#111827" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                </Grid>

                <Grid Padding="16,0,16,0"
                      Margin="0,-28,0,0"
                      ColumnDefinitions="1.7*,Auto,1.15*"
                      ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="{Binding TourAudioButtonText}"
                            HeightRequest="56"
                            CornerRadius="28"
                            Padding="16,0"
                            FontSize="16"
                            FontAttributes="Bold"
                            BackgroundColor="#1F2937"
                            TextColor="White"
                            Command="{Binding ToggleTourAudioCommand}" />

                    <Border Grid.Column="1"
                            WidthRequest="56"
                            HeightRequest="56"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShowStartTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="⌖"
                               FontSize="22"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               TextColor="#111827" />
                    </Border>

                    <Border Grid.Column="2"
                            HeightRequest="56"
                            BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMapButtonTapped" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Label Text="🗺"
                                   FontSize="19"
                                   VerticalTextAlignment="Center"
                                   TextColor="#111827" />
                            <Label Text="{local:Translate map_title}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   VerticalTextAlignment="Center"
                                   TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <VerticalStackLayout Padding="16,18,16,0"
                                     Spacing="18">
                        <Label Text="{Binding Tour.Name}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               LineBreakMode="TailTruncation"
                               MaxLines="3" />

                        <FlexLayout Wrap="Wrap"
                                    Direction="Row"
                                    JustifyContent="Start"
                                    AlignItems="Start">
                            <Border Padding="12,7"
                                    Margin="0,0,8,8"
                                    BackgroundColor="#E5E7EB"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🧭"
                                           FontSize="15"
                                           TextColor="#111827" />
                                    <Label Text="{Binding DistanceDisplay}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </HorizontalStackLayout>
                            </Border>
                            <Border Padding="12,7"
                                    Margin="0,0,8,8"
                                    BackgroundColor="#E5E7EB"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="◷"
                                           FontSize="15"
                                           TextColor="#111827" />
                                    <Label Text="{Binding EstimatedDurationText}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </HorizontalStackLayout>
                            </Border>
                            <Border Padding="12,7"
                                    Margin="0,0,8,8"
                                    BackgroundColor="#E5E7EB"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="⌖"
                                           FontSize="15"
                                           TextColor="#111827" />
                                    <Label Text="{Binding PoiCountDisplay}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                </HorizontalStackLayout>
                            </Border>
                        </FlexLayout>

                        <Border BackgroundColor="#F5E9FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="16,14">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleOfflineCommand}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">
                                <Label Text="!"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="#A21CAF" />
                                <Label Grid.Column="1"
                                       Text="{Binding OfflineStatusText}"
                                       FontSize="14"
                                       TextColor="#A21CAF"
                                       LineBreakMode="WordWrap" />
                                <Label Grid.Column="2"
                                       Text="›"
                                       FontSize="28"
                                       VerticalOptions="Center"
                                       TextColor="#A21CAF" />
                            </Grid>
                        </Border>

                        <Label Text="{Binding Tour.Description}"
                               FontSize="16"
                               TextColor="#1F2937"
                               LineHeight="1.35"
                               LineBreakMode="WordWrap" />

                        <Border Padding="0"
                                BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 22">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMiniMapTapped" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="Auto,248">
                                <Grid Padding="16,14,16,0"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <Label Text="{local:Translate map_title}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#111827" />
                                    <Border Grid.Column="1"
                                            Padding="10,4"
                                            BackgroundColor="#F3F4F6"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10">
                                        <Label Text="{Binding PoiCountDisplay}"
                                               FontAttributes="Bold"
                                               TextColor="#374151" />
                                    </Border>
                                </Grid>

                                <maps:Map x:Name="MiniRouteMap"
                                          Grid.Row="1"
                                          Margin="12,10,12,12"
                                          IsShowingUser="False"
                                          IsTrafficEnabled="False"
                                          IsScrollEnabled="False"
                                          IsZoomEnabled="False" />
                            </Grid>
                        </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Border x:Name="PoiBottomSheet"
                VerticalOptions="End"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                HeightRequest="306"
                Padding="0,8,0,12"
                ZIndex="20">
            <Grid RowDefinitions="Auto,Auto,*"
                  RowSpacing="10">
                <Grid Grid.Row="0"
                      HeightRequest="28">
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnSheetPanUpdated" />
                    </Grid.GestureRecognizers>

                    <Border HorizontalOptions="Center"
                            VerticalOptions="Center"
                            WidthRequest="90"
                            HeightRequest="10"
                            BackgroundColor="#D1D5DB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 5" />
                </Grid>

                <Grid Grid.Row="1"
                      Padding="18,0,18,0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="{Binding Tour.Name}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#111827"
                           LineBreakMode="TailTruncation" />
                    <Border Grid.Column="1"
                            Padding="10,4"
                            BackgroundColor="#F3F4F6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="⌖"
                                   FontSize="15"
                                   TextColor="#374151" />
                            <Label Text="{Binding PoiCountDisplay}"
                                   FontAttributes="Bold"
                                   TextColor="#374151" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      Padding="16,0,16,0"
                      ColumnDefinitions="96,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            WidthRequest="88"
                            HeightRequest="212"
                            BackgroundColor="#F8FAFC"
                            Stroke="#E2E8F0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShowStartTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Padding="10"
                                             Spacing="14"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center">
                            <Border WidthRequest="54"
                                    HeightRequest="54"
                                    BackgroundColor="#2563EB"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 27">
                                <Label Text="🗺"
                                       FontSize="24"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="White" />
                            </Border>
                            <Label Text="{local:Translate map_show_start}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#1F2937" />
                        </VerticalStackLayout>
                    </Border>

                    <CollectionView x:Name="PoiCollectionView"
                                    Grid.Column="1"
                                    ItemsSource="{Binding POIs}"
                                    SelectionMode="None"
                                    HeightRequest="216">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Border WidthRequest="196"
                                        HeightRequest="212"
                                        Padding="0"
                                        BackgroundColor="White"
                                        Stroke="#E5E7EB"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.ViewPOIDetailCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="132,*"
                                          RowSpacing="8">
                                        <Grid Grid.Row="0">
                                            <Image Aspect="AspectFill">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource PreferredPoiImageSourceConverter}">
                                                        <Binding Path="ImagePath" />
                                                        <Binding Path="ImageUrl" />
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>

                                            <Border Margin="8"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="End"
                                                    Padding="8,3"
                                                    BackgroundColor="#F3F4F6"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 8">
                                                <Label Text="{Binding OrderInTour}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#111827" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Grid.Row="1"
                                                             Padding="12,0,12,10"
                                                             Spacing="4">
                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{local:Translate tour_detail_poi_hint}"
                                                   FontSize="12"
                                                   TextColor="#6B7280"
                                                   MaxLines="1" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Grid>
        </Border>

        <views:MiniPlayerView VerticalOptions="End"
                              ZIndex="30" />
    </Grid>

</ContentPage>
