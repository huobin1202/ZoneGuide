<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:models="clr-namespace:ZoneGuide.Shared.Models;assembly=ZoneGuide.Shared"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             x:Class="ZoneGuide.Mobile.Views.TourDetailPage"
             x:DataType="vm:TourDetailViewModel"
             Title="{Binding Tour.Name}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Grid HeightRequest="280">
                <Image Source="{Binding Tour.ThumbnailUrl}"
                       Aspect="AspectFill"
                       BackgroundColor="#E5E7EB" />
                <Grid BackgroundColor="#66000000" />
                <Grid Padding="16,20,16,24"
                      RowDefinitions="Auto,*,Auto">
                    <Frame Grid.Row="0"
                           Padding="10,6"
                           CornerRadius="18"
                           HasShadow="False"
                           BackgroundColor="#66000000"
                           HorizontalOptions="Start">
                        <Label Text="{local:Translate tours_title}"
                               FontSize="12"
                               TextColor="White" />
                    </Frame>

                    <VerticalStackLayout Grid.Row="2"
                                         Spacing="10">
                        <Label Text="{Binding Tour.Name}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="White"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Tour.Description}"
                               FontSize="14"
                               TextColor="#F3F4F6"
                               MaxLines="3"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <VerticalStackLayout Padding="16"
                                 Spacing="18">

                <Grid ColumnDefinitions="*,*,*"
                      ColumnSpacing="12">
                    <Frame Grid.Column="0"
                           Padding="14"
                           CornerRadius="18"
                           HasShadow="False"
                           BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB">
                        <VerticalStackLayout Spacing="6"
                                             HorizontalOptions="Center">
                            <Label Text="📍"
                                   FontSize="18"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding Tour.POICount}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="{local:Translate tour_detail_points}"
                                   FontSize="11"
                                   TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           Padding="14"
                           CornerRadius="18"
                           HasShadow="False"
                           BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB">
                        <VerticalStackLayout Spacing="6"
                                             HorizontalOptions="Center">
                            <Label Text="⏱️"
                                   FontSize="18"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding Tour.EstimatedDurationMinutes}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="{local:Translate tour_detail_duration}"
                                   FontSize="11"
                                   TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="2"
                           Padding="14"
                           CornerRadius="18"
                           HasShadow="False"
                           BorderColor="#E5E7EB"
                           BackgroundColor="#F9FAFB">
                        <VerticalStackLayout Spacing="6"
                                             HorizontalOptions="Center">
                            <Label Text="🚶"
                                   FontSize="18"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding DistanceDisplay}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" />
                            <Label Text="{local:Translate tour_detail_distance}"
                                   FontSize="11"
                                   TextColor="#6B7280"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Frame Padding="16"
                       CornerRadius="18"
                       HasShadow="False"
                       BackgroundColor="{Binding OfflineCardBackground}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">
                            <Label Text="⬇️"
                                   FontSize="22"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="{local:Translate tour_detail_offline}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <Label Text="{Binding OfflineStatusText}"
                                       FontSize="12"
                                       TextColor="#F3F4F6" />
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="{Binding OfflineActionText}"
                                    Padding="14,8"
                                    BackgroundColor="White"
                                    TextColor="{StaticResource Primary}"
                                    FontSize="12"
                                    CornerRadius="16"
                                    Command="{Binding ToggleOfflineCommand}" />
                        </Grid>

                        <ProgressBar Progress="{Binding DownloadProgress}"
                                     ProgressColor="White"
                                     BackgroundColor="#4DFFFFFF"
                                     IsVisible="{Binding IsDownloading}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="18"
                       CornerRadius="18"
                       HasShadow="False"
                       BorderColor="#E5E7EB"
                       BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{local:Translate tour_detail_stops}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="{Binding HighlightsText}"
                               FontSize="14"
                               TextColor="#4B5563"
                               LineHeight="1.4" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Padding="18"
                       CornerRadius="18"
                       HasShadow="False"
                       BorderColor="#E5E7EB"
                       BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{local:Translate tour_detail_about}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="{Binding Tour.Description}"
                               FontSize="14"
                               TextColor="#4B5563"
                               LineHeight="1.5" />
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{local:Translate tour_detail_pois}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <CollectionView ItemsSource="{Binding POIs}"
                                    SelectionMode="None"
                                    HeightRequest="420">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Frame Margin="0,0,0,10"
                                       Padding="14"
                                       CornerRadius="18"
                                       HasShadow="False"
                                       BorderColor="#E5E7EB"
                                       BackgroundColor="White">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TourDetailViewModel}}, Path=ViewPOIDetailCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">
                                        <Frame Grid.Column="0"
                                               WidthRequest="38"
                                               HeightRequest="38"
                                               Padding="0"
                                               CornerRadius="19"
                                               HasShadow="False"
                                               BackgroundColor="{StaticResource Primary}">
                                            <Label Text="{Binding OrderInTour}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Frame>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="4"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#111827"
                                                   MaxLines="1" />
                                            <Label Text="{Binding ShortDescription}"
                                                   FontSize="12"
                                                   TextColor="#6B7280"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="›"
                                               FontSize="22"
                                               TextColor="#9CA3AF"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <Button Text="{local:Translate tour_detail_start}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="28"
                        Margin="0,8,0,24"
                        Command="{Binding StartTourCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>