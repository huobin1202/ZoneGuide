@page "/my-contributions"
@using ZoneGuide.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<PageTitle>Đóng góp của tôi - ZoneGuide</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
    <MudGrid>
        <MudItem xs="12">
            <MudPaper Class="pa-4 mb-4">
                <div class="d-flex justify-space-between align-center">
                    <div>
                        <MudText Typo="Typo.h4" Class="mb-1">
                            <MudIcon Icon="@Icons.Material.Filled.EditLocation" Class="mr-2" />
                            Đóng góp của tôi
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Xin chào, @_currentUser?.DisplayName! Quản lý các POI bạn đã đóng góp.
                        </MudText>
                    </div>
                    <div class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddDialog">
                            Thêm POI mới
                        </MudButton>
              
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        
        <!-- Stats Cards -->
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Drafts" Color="Color.Default" Style="font-size: 48px;" />
                <MudText Typo="Typo.h4">@_stats.Draft</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Bản nháp</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.HourglassTop" Color="Color.Warning" Style="font-size: 48px;" />
                <MudText Typo="Typo.h4">@_stats.Pending</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Chờ duyệt</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 48px;" />
                <MudText Typo="Typo.h4">@_stats.Approved</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Đã duyệt</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 text-center">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Style="font-size: 48px;" />
                <MudText Typo="Typo.h4">@_stats.NeedsRevision</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Cần sửa</MudText>
            </MudPaper>
        </MudItem>
        
        <!-- Contributions List -->
        <MudItem xs="12">
            <MudPaper Class="pa-4">
                <MudTabs Elevation="0" Rounded="true" Centered="true" @bind-ActivePanelIndex="_activeTabIndex">
                    <MudTabPanel Text="Tất cả" BadgeData="@_contributions.Count" BadgeColor="Color.Primary" />
                    <MudTabPanel Text="Bản nháp" BadgeData="@_stats.Draft" BadgeColor="Color.Default" />
                    <MudTabPanel Text="Chờ duyệt" BadgeData="@_stats.Pending" BadgeColor="Color.Warning" />
                    <MudTabPanel Text="Đã duyệt" BadgeData="@_stats.Approved" BadgeColor="Color.Success" />
                    <MudTabPanel Text="Cần sửa" BadgeData="@_stats.NeedsRevision" BadgeColor="Color.Info" />
                </MudTabs>
                
                <MudDivider Class="my-4" />
                
                @if (_isLoading)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Indeterminate="true" />
                    </div>
                }
                else if (!FilteredContributions.Any())
                {
                    <MudAlert Severity="Severity.Info" Class="my-4">
                        Không có đóng góp nào trong mục này.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@FilteredContributions" Hover="true" Striped="true" Dense="true">
                        <HeaderContent>
                            <MudTh>ID</MudTh>
                            <MudTh>Tên POI</MudTh>
                            <MudTh>Vị trí</MudTh>
                            <MudTh>Trạng thái</MudTh>
                            <MudTh>Ngày tạo</MudTh>
                            <MudTh>Phản hồi</MudTh>
                            <MudTh>Hành động</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="ID">@context.Id</MudTd>
                            <MudTd DataLabel="Tên">
                                <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
                                @if (!string.IsNullOrEmpty(context.ShortDescription))
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                        @(context.ShortDescription.Length > 50 ? context.ShortDescription.Substring(0, 50) + "..." : context.ShortDescription)
                                    </MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Vị trí">
                                <MudLink Href="@($"https://maps.google.com/?q={context.Latitude},{context.Longitude}")" Target="_blank">
                                    @(context.Latitude?.ToString("F4") ?? "0"), @(context.Longitude?.ToString("F4") ?? "0")
                                </MudLink>
                            </MudTd>
                            <MudTd DataLabel="Trạng thái">
                                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@GetStatusText(context.Status)</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                            <MudTd DataLabel="Phản hồi">
                                @if (!string.IsNullOrEmpty(context.ReviewerFeedback))
                                {
                                    <MudTooltip Text="@context.ReviewerFeedback">
                                        <MudIcon Icon="@Icons.Material.Filled.Comment" Color="Color.Info" />
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </MudTd>
                            <MudTd DataLabel="Hành động">
                                @if (context.Status == "Draft" || context.Status == "NeedsRevision")
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialog(context))" Title="Sửa" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Success" Size="Size.Small"
                                                   OnClick="@(() => SubmitForReview(context))" Title="Gửi duyệt" />
                                }
                                @if (context.Status == "Draft")
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                   OnClick="@(() => DeleteContribution(context))" Title="Xóa" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Info" Size="Size.Small"
                                               OnClick="@(() => ViewHistory(context.Id))" Title="Lịch sử" />
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" />
                        </PagerContent>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private UserDto? _currentUser;
    private List<POIContributionDto> _contributions = new();
    private bool _isLoading = true;
    private int _activeTabIndex = 0;
    
    private ContributionStats _stats = new();
    
    private IEnumerable<POIContributionDto> FilteredContributions => _activeTabIndex switch
    {
        1 => _contributions.Where(c => c.Status == "Draft"),
        2 => _contributions.Where(c => c.Status == "Pending"),
        3 => _contributions.Where(c => c.Status == "Approved"),
        4 => _contributions.Where(c => c.Status == "NeedsRevision"),
        _ => _contributions
    };
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuth();
            if (_currentUser != null)
            {
                await LoadContributions();
                StateHasChanged();
            }
        }
    }
    
    private async Task CheckAuth()
    {
        try
        {
            _currentUser = await LocalStorage.GetItemAsync<UserDto>("user");
        }
        catch
        {
            _currentUser = null;
        }
        
        if (_currentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        
        if (_currentUser.Role != "Contributor" && _currentUser.Role != "Admin")
        {
            Snackbar.Add("Bạn không có quyền truy cập trang này", Severity.Error);
            Navigation.NavigateTo("/login");
            return;
        }
    }    private async Task LoadContributions()
    {
        _isLoading = true;
        try
        {
            var response = await Http.GetAsync("api/contributions/my");
            if (response.IsSuccessStatusCode)
            {
                _contributions = await response.Content.ReadFromJsonAsync<List<POIContributionDto>>() ?? new();
                CalculateStats();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải dữ liệu: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void CalculateStats()
    {
        _stats = new ContributionStats
        {
            Draft = _contributions.Count(c => c.Status == "Draft"),
            Pending = _contributions.Count(c => c.Status == "Pending"),
            Approved = _contributions.Count(c => c.Status == "Approved"),
            NeedsRevision = _contributions.Count(c => c.Status == "NeedsRevision"),
            Rejected = _contributions.Count(c => c.Status == "Rejected")
        };
    }
    
    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters<ContributorPOIDialog>
        {
            { x => x.Contribution, null },
            { x => x.IsEdit, false }
        };
        
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        
        var dialog = await DialogService.ShowAsync<ContributorPOIDialog>("Thêm POI mới", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadContributions();
        }
    }
    
    private async Task OpenEditDialog(POIContributionDto contribution)
    {
        var parameters = new DialogParameters<ContributorPOIDialog>
        {
            { x => x.Contribution, contribution },
            { x => x.IsEdit, true }
        };
        
        var options = new DialogOptions 
        { 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        
        var dialog = await DialogService.ShowAsync<ContributorPOIDialog>("Sửa POI", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadContributions();
        }
    }
    
    private async Task SubmitForReview(POIContributionDto contribution)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Gửi duyệt",
            $"Bạn có chắc muốn gửi POI '{contribution.Name}' để Admin duyệt?",
            yesText: "Gửi duyệt",
            cancelText: "Hủy");
        
        if (confirm == true)
        {
            try
            {
                var response = await Http.PostAsync($"api/contributions/{contribution.Id}/submit", null);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã gửi duyệt thành công!", Severity.Success);
                    await LoadContributions();
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Snackbar.Add($"Lỗi: {error}", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            }
        }
    }
    
    private async Task DeleteContribution(POIContributionDto contribution)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Xóa đóng góp",
            $"Bạn có chắc muốn xóa POI '{contribution.Name}'?",
            yesText: "Xóa",
            cancelText: "Hủy");
        
        if (confirm == true)
        {
            try
            {
                var response = await Http.DeleteAsync($"api/contributions/{contribution.Id}");
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Đã xóa thành công!", Severity.Success);
                    await LoadContributions();
                }
                else
                {
                    Snackbar.Add("Không thể xóa đóng góp này", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
            }
        }
    }
    
    private async Task ViewHistory(int contributionId)
    {
        var parameters = new DialogParameters<ApprovalHistoryDialog>
        {
            { x => x.ContributionId, contributionId }
        };
        
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<ApprovalHistoryDialog>("Lịch sử duyệt", parameters, options);
    }
    

    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "NeedsRevision" => Color.Info,
        _ => Color.Default
    };
    
    private string GetStatusText(string status) => status switch
    {
        "Draft" => "Bản nháp",
        "Pending" => "Chờ duyệt",
        "Approved" => "Đã duyệt",
        "Rejected" => "Từ chối",
        "NeedsRevision" => "Cần sửa",
        _ => status
    };
    
    private class ContributionStats
    {
        public int Draft { get; set; }
        public int Pending { get; set; }
        public int Approved { get; set; }
        public int NeedsRevision { get; set; }
        public int Rejected { get; set; }
    }
}
