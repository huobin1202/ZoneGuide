<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             x:Class="ZoneGuide.Mobile.Views.LanguageSelectionPage"
             x:Name="PageRoot"
             x:DataType="vm:LanguageSelectionViewModel"
             BackgroundColor="White">

    <Grid RowDefinitions="340,*">
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Primary}">
            <Grid Padding="28,40,28,28">
                <Ellipse Fill="#33FFFFFF"
                         WidthRequest="170"
                         HeightRequest="170"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         TranslationX="55"
                         TranslationY="-20" />
                <Ellipse Fill="#22FFFFFF"
                         WidthRequest="140"
                         HeightRequest="140"
                         HorizontalOptions="Start"
                         VerticalOptions="End"
                         TranslationX="-36"
                         TranslationY="34" />

                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="20">
                    <Border BackgroundColor="White"
                            Padding="18"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Label Text="◎"
                               FontSize="28"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Chào mừng đến với&#10;ZoneGuide"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Chọn ngôn ngữ trước khi bắt đầu.&#10;Bạn luôn có thể đổi lại trong Cài đặt."
                               FontSize="15"
                               TextColor="#DAD6FF"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Padding="24,0,24,28">
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28"
                    Margin="0,-36,0,0">
                <Grid RowDefinitions="Auto,*,Auto,Auto"
                      Padding="0,28,0,0">
                    <VerticalStackLayout Grid.Row="0"
                                         Padding="0,0,0,12"
                                         Spacing="6">
                        <HorizontalStackLayout Spacing="10"
                                               VerticalOptions="Center">
                            <Border BackgroundColor="{StaticResource Primary}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    WidthRequest="24"
                                    HeightRequest="24">
                                <Label Text="1"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <Label Text="Chọn ngôn ngữ của bạn"
                                   FontSize="20"
                                   FontAttributes="Bold" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding Languages}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="2"
                                             HorizontalItemSpacing="12"
                                             VerticalItemSpacing="12" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:LanguageOptionItem">
                                <Border Padding="14,12"
                                        BackgroundColor="White"
                                        Stroke="#E1E1E8"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 18">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.SelectLanguageCommand, Source={x:Reference PageRoot}}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                            <Setter Property="BackgroundColor" Value="#F4F1FF" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">
                                        <Border WidthRequest="40"
                                                HeightRequest="40"
                                                BackgroundColor="#F2F2F7"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding ShortCode}"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   TextColor="{StaticResource Gray900}" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding DisplayName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold" />
                                            <Label Text="{Binding Subtitle}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2"
                                                IsVisible="{Binding IsSelected}"
                                                WidthRequest="24"
                                                HeightRequest="24"
                                                BackgroundColor="{StaticResource Primary}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                VerticalOptions="Center">
                                            <Label Text="✓"
                                                   TextColor="White"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="2"
                            Text="Bắt đầu khám phá"
                            Margin="0,20,0,12"
                            HeightRequest="56"
                            CornerRadius="24"
                            FontSize="18"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}" />

                    <Label Grid.Row="3"
                           Text="Bạn có thể thay đổi lại ngôn ngữ trong Cài đặt"
                           FontSize="12"
                           TextColor="{StaticResource Gray500}"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,12" />
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
