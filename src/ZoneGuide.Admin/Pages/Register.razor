@page "/register"
@using ZoneGuide.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@layout EmptyLayout

<PageTitle>ZoneGuide</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 100vh; padding: 24px 0;">
    <MudPaper Elevation="4" Class="pa-8 rounded-lg" Style="width: 100%;">
        <div class="text-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Style="font-size: 64px;" />
            <MudText Typo="Typo.h4" Class="mt-2" Color="Color.Primary">ZoneGuide</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Đăng ký làm Contributor</MudText>
        </div>
        
        <MudDivider Class="mb-6" />
        
        <MudAlert Severity="Severity.Info" Class="mb-4" Icon="@Icons.Material.Filled.Info">
            <strong>Contributor</strong> có thể thêm POI (địa điểm) mới. POI sẽ được Admin duyệt trước khi hiển thị.
        </MudAlert>
        
        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            
            <MudTextField @bind-Value="_registerModel.DisplayName" 
                          Label="Họ và tên" 
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-4"
                          Required="true"
                          RequiredError="Vui lòng nhập họ tên" />
            
            <MudTextField @bind-Value="_registerModel.Email" 
                          Label="Email" 
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Class="mb-4"
                          Required="true"
                          RequiredError="Vui lòng nhập email" />
            
            <MudTextField @bind-Value="_registerModel.PhoneNumber" 
                          Label="Số điện thoại (không bắt buộc)" 
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Phone"
                          Class="mb-4" />
            
            <MudTextField @bind-Value="_registerModel.Password" 
                          Label="Mật khẩu" 
                          Variant="Variant.Outlined"
                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="() => _showPassword = !_showPassword"
                          Class="mb-4"
                          Required="true"
                          RequiredError="Vui lòng nhập mật khẩu"
                          HelperText="Tối thiểu 6 ký tự" />
            
            <MudTextField @bind-Value="_confirmPassword" 
                          Label="Xác nhận mật khẩu" 
                          Variant="Variant.Outlined"
                          InputType="@(_showConfirmPassword ? InputType.Text : InputType.Password)"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showConfirmPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnAdornmentClick="() => _showConfirmPassword = !_showConfirmPassword"
                          Class="mb-4"
                          Required="true"
                          RequiredError="Vui lòng xác nhận mật khẩu" />
            
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }
            
            <MudButton ButtonType="ButtonType.Submit" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="@_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Đang đăng ký...</span>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
                    <span>Đăng ký Contributor</span>
                }
            </MudButton>
        </EditForm>
        
        <MudDivider Class="my-6" />
        
        <div class="text-center">
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                Đã có tài khoản?
            </MudText>
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Primary" 
                       Href="/login"
                       FullWidth="true">
                <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                Đăng nhập
            </MudButton>
        </div>
        
        <MudText Typo="Typo.caption" Class="text-center mt-6 mud-text-secondary">
            © 2026 ZoneGuide
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private RegisterDto _registerModel = new() { RegisterAsContributor = true };
    private string _confirmPassword = string.Empty;
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;
    private bool _isLoading = false;
    private string? _errorMessage;
    
    private async Task HandleRegister()
    {
        _errorMessage = null;
        
        // Validate
        if (string.IsNullOrWhiteSpace(_registerModel.DisplayName))
        {
            _errorMessage = "Vui lòng nhập họ tên";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_registerModel.Email))
        {
            _errorMessage = "Vui lòng nhập email";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_registerModel.Password))
        {
            _errorMessage = "Vui lòng nhập mật khẩu";
            return;
        }
        
        if (_registerModel.Password.Length < 6)
        {
            _errorMessage = "Mật khẩu phải có ít nhất 6 ký tự";
            return;
        }
        
        if (_registerModel.Password != _confirmPassword)
        {
            _errorMessage = "Mật khẩu xác nhận không khớp";
            return;
        }
        
        _isLoading = true;
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", _registerModel);
            var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
            
            if (result?.Success == true)
            {
                Snackbar.Add("Đăng ký thành công! Vui lòng đăng nhập.", Severity.Success);
                Navigation.NavigateTo("/login");
            }
            else
            {
                _errorMessage = result?.Message ?? "Đăng ký thất bại";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Không thể kết nối đến server: " + ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
