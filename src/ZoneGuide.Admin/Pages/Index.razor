@page "/"
@inject IApiService ApiService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@implements IAsyncDisposable

@using Microsoft.AspNetCore.SignalR.Client


@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_dashboard != null)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng số địa điểm</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalPOIs</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng số chuyến tham quan</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalTours</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Headset" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Tổng lượt nghe</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.TotalListens</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Class="dashboard-kpi-icon-left" />
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Người dùng duy nhất</MudText>
                        <MudText Typo="Typo.h4">@_dashboard.UniqueUsers</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Realtime QR Monitoring</MudText>
                    <MudChip T="string" Color="@(_qrRealtimeConnected ? Color.Success : Color.Warning)" Variant="Variant.Filled" Size="Size.Small">
                        @(_qrRealtimeConnected ? "LIVE" : "OFFLINE")
                    </MudChip>
                </MudStack>

                <MudGrid Class="mt-2">
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Thiết bị active</MudText>
                        <MudText Typo="Typo.h5">@(_qrRealtime?.ActiveDeviceCount ?? 0)</MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Thiết bị duy nhất</MudText>
                        <MudText Typo="Typo.h5">@(_qrRealtime?.UniqueDeviceCount ?? 0)</MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Lượt truy cập QR</MudText>
                        <MudText Typo="Typo.h5">@(_qrRealtime?.TotalAccessCount ?? 0)</MudText>
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Đang truy cập</MudText>
                        <MudText Typo="Typo.h5">@(_qrRealtime?.AccessesLastMinute ?? 0)</MudText>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">
                    @GetRealtimeFooterText()
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-6">
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-4">Chỉ số chính</MudText>
                <MudSimpleTable Dense="true" Bordered="true">
                    <tbody>
                        <tr>
                            <td>Thời lượng nghe trung bình</td>
                            <td>@FormatDuration(_dashboard.AverageListenDurationSeconds)</td>
                        </tr>
                        <tr>
                            <td>Tỷ lệ hoàn thành</td>
                            <td>@(_dashboard.CompletionRate.ToString("P1"))</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Class="mb-4">Địa điểm nổi bật</MudText>
                @if (_dashboard.TopPOIs.Any())
                {
                    <MudSimpleTable Dense="true" Bordered="true">
                        <thead>
                            <tr>
                                <th>Tên địa điểm</th>
                                <th>Lượt nghe</th>
                                <th>Thời lượng TB</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var poi in _dashboard.TopPOIs.Take(5))
                            {
                                <tr>
                                    <td>@poi.Name</td>
                                    <td>@poi.ListenCount</td>
                                    <td>@FormatDuration(poi.AvgDurationSeconds)</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudText>Chưa có dữ liệu</MudText>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_dashboard.DailyStats.Any())
    {
        <MudPaper Class="pa-4 mt-6" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-4">Hoạt động theo ngày (30 ngày gần nhất)</MudText>
            <MudSimpleTable Dense="true" Bordered="true" Style="max-height: 400px; overflow-y: auto;">
                <thead>
                    <tr>
                        <th>Ngày</th>
                        <th>Lượt nghe</th>
                        <th>Người dùng duy nhất</th>
                        <th>Thời lượng TB</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stat in _dashboard.DailyStats.OrderByDescending(s => s.Date).Take(30))
                    {
                        <tr>
                            <td>@stat.Date.ToString("dd/MM/yyyy")</td>
                            <td>@stat.ListenCount</td>
                            <td>@stat.UniqueUsers</td>
                            <td>@FormatDuration(stat.AvgDurationSeconds)</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    }
}
else
{
    <MudAlert Severity="Severity.Warning">
        Không thể tải dữ liệu bảng điều khiển. Vui lòng kiểm tra kết nối API.
    </MudAlert>
}

@code {
    private DashboardAnalyticsDto? _dashboard;
    private QrMonitoringSnapshotDto? _qrRealtime;
    private HubConnection? _qrHubConnection;
    private bool _qrRealtimeConnected;
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            var currentUser = await LocalStorage.GetItemAsync<UserDto>("user");
            if (currentUser?.Role == "Contributor")
            {
                Navigation.NavigateTo("/contributor-dashboard");
                return;
            }
        }
        catch
        {
            // Ignore local storage errors and continue loading admin dashboard.
        }

        await LoadDashboard();
        await InitializeQrRealtimeAsync();
        StateHasChanged();
    }

    private async Task LoadDashboard()
    {
        _loading = true;
        _dashboard = await ApiService.GetDashboardAsync();
        _loading = false;
    }

    private async Task InitializeQrRealtimeAsync()
    {
        _qrRealtime = await ApiService.GetQrMonitoringSnapshotAsync();

        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:56040";
        var hubUrl = $"{apiBaseUrl.TrimEnd('/')}/hubs/qr-monitor";

        _qrHubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _qrHubConnection.Reconnecting += _ =>
        {
            _qrRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.Reconnected += _ =>
        {
            _qrRealtimeConnected = true;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.Closed += _ =>
        {
            _qrRealtimeConnected = false;
            return InvokeAsync(StateHasChanged);
        };

        _qrHubConnection.On<QrMonitoringSnapshotDto>("QrMonitorUpdated", snapshot =>
        {
            _qrRealtime = snapshot;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            await _qrHubConnection.StartAsync();
            _qrRealtimeConnected = true;
        }
        catch
        {
            _qrRealtimeConnected = false;
        }
    }

    private string GetRealtimeFooterText()
    {
        if (_qrRealtime == null || !_qrRealtime.LastAccessAtUtc.HasValue)
        {
            return "Chưa ghi nhận truy cập QR";
        }

        var poiText = _qrRealtime.LastPoiId.HasValue ? $"POI #{_qrRealtime.LastPoiId.Value}" : "POI không xác định";
        var localTime = _qrRealtime.LastAccessAtUtc.Value.ToLocalTime();
        return $"Truy cập gần nhất: {poiText} lúc {localTime:dd/MM/yyyy HH:mm:ss}";
    }

    private string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return ts.TotalMinutes >= 1 
            ? $"{(int)ts.TotalMinutes}m {ts.Seconds}s" 
            : $"{ts.Seconds}s";
    }

    public async ValueTask DisposeAsync()
    {
        if (_qrHubConnection != null)
        {
            await _qrHubConnection.DisposeAsync();
        }
    }
}
