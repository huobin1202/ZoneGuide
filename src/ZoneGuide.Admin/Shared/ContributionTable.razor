@using ZoneGuide.Shared.Models
@inject IJSRuntime JS

<MudTable Items="@FilteredContributions" Hover="true" Striped="true" Loading="@IsLoading" LoadingProgressColor="Color.Primary" Dense="true">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Tên POI</MudTh>
        <MudTh>Mô tả</MudTh>
        <MudTh>Người đóng góp</MudTh>
        <MudTh>Vị trí</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Ngày gửi</MudTh>
        <MudTh>Ngày duyệt</MudTh>
        <MudTh>Hành động</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Tên">
            <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
        </MudTd>
        <MudTd DataLabel="Mô tả">
            <MudTooltip Text="@GetDescriptionText(context)">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@TruncateText(GetDescriptionText(context), 80)</MudText>
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Người đóng góp">@context.ContributorName</MudTd>
        <MudTd DataLabel="Vị trí">
            <MudLink Href="javascript:void(0)" OnClick="@(() => OnShowLocation.InvokeAsync(context))">
                @GetLocationDisplay(context)
            </MudLink>
        </MudTd>
        <MudTd DataLabel="Trạng thái">
            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@GetStatusText(context.Status)</MudChip>
        </MudTd>
        <MudTd DataLabel="Ngày gửi">@(context.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
        <MudTd DataLabel="Ngày duyệt">@(context.ReviewedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
        <MudTd DataLabel="Hành động">
            @if (ShowReviewActions && context.Status == "Pending")
            {
                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small"
                               OnClick="@(() => OnReview.InvokeAsync(context))" title="Duyệt" />
            }
            <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Info" Size="Size.Small"
                           OnClick="@(() => OnViewHistory.InvokeAsync(context.Id))" title="Lịch sử" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Không có đóng góp nào</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Đang tải...</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
    </PagerContent>
</MudTable>

@code {
    [Parameter] public List<POIContributionDto> Contributions { get; set; } = new();
    [Parameter] public string? SearchKeyword { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool ShowReviewActions { get; set; } = true;
    [Parameter] public EventCallback<POIContributionDto> OnReview { get; set; }
    [Parameter] public EventCallback<int> OnViewHistory { get; set; }
    [Parameter] public EventCallback<POIContributionDto> OnShowLocation { get; set; }

    private readonly Dictionary<int, string> _addressCache = new();
    private readonly HashSet<int> _resolvingAddresses = new();

    private IEnumerable<POIContributionDto> FilteredContributions =>
        string.IsNullOrWhiteSpace(SearchKeyword)
            ? Contributions
            : Contributions.Where(MatchesSearchKeyword);

    protected override async Task OnParametersSetAsync()
    {
        var pending = Contributions
            .Where(c => c.Latitude.HasValue && c.Longitude.HasValue)
            .Where(c => !_addressCache.ContainsKey(c.Id) && !_resolvingAddresses.Contains(c.Id))
            .ToList();

        foreach (var contribution in pending)
        {
            _resolvingAddresses.Add(contribution.Id);
        }

        foreach (var contribution in pending)
        {
            await ResolveAddressAsync(contribution);
        }
    }
    
    private Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Pending" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "NeedsRevision" => Color.Info,
        _ => Color.Default
    };
    
    private string GetStatusText(string status) => status switch
    {
        "Draft" => "Bản nháp",
        "Pending" => "Chờ duyệt",
        "Approved" => "Đã duyệt",
        "Rejected" => "Từ chối",
        "NeedsRevision" => "Cần sửa",
        _ => status
    };
    
    private string TruncateText(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return value ?? "";
        return value.Length <= maxLength ? value : value.Substring(0, maxLength) + "...";
    }

    private string GetDescriptionText(POIContributionDto contribution)
    {
        return contribution.TTSScript
            ?? contribution.FullDescription
            ?? contribution.ShortDescription
            ?? "-";
    }

    private bool MatchesSearchKeyword(POIContributionDto contribution)
    {
        var keyword = SearchKeyword?.Trim();
        if (string.IsNullOrWhiteSpace(keyword))
        {
            return true;
        }

        return (contribution.Name?.Contains(keyword, StringComparison.OrdinalIgnoreCase) ?? false)
               || (contribution.ContributorName?.Contains(keyword, StringComparison.OrdinalIgnoreCase) ?? false)
               || (contribution.Category?.Contains(keyword, StringComparison.OrdinalIgnoreCase) ?? false)
               || (contribution.Status?.Contains(keyword, StringComparison.OrdinalIgnoreCase) ?? false)
               || (GetDescriptionText(contribution).Contains(keyword, StringComparison.OrdinalIgnoreCase));
    }

    private string GetLocationDisplay(POIContributionDto contribution)
    {
        if (_addressCache.TryGetValue(contribution.Id, out var address))
        {
            return address;
        }

        return contribution.Latitude.HasValue && contribution.Longitude.HasValue
            ? "Đang tải địa chỉ..."
            : "Không có địa chỉ";
    }

    private async Task ResolveAddressAsync(POIContributionDto contribution)
    {
        try
        {
            if (!contribution.Latitude.HasValue || !contribution.Longitude.HasValue)
            {
                _addressCache[contribution.Id] = "Không có địa chỉ";
                return;
            }

            var address = await JS.InvokeAsync<string>(
                "reverseGeocodeAddress",
                contribution.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture),
                contribution.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture));

            _addressCache[contribution.Id] = string.IsNullOrWhiteSpace(address) ? "Không có địa chỉ" : address;
        }
        catch
        {
            _addressCache[contribution.Id] = "Không có địa chỉ";
        }
        finally
        {
            _resolvingAddresses.Remove(contribution.Id);
            await InvokeAsync(StateHasChanged);
        }
    }
}
