    private async Task UploadImage(IBrowserFile file)
    {
        try
        {
            var maxAllowedSize = 5 * 1024 * 1024; // 5MB
            var stream = file.OpenReadStream(maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var format = file.ContentType;
            
            if (_isEditMode && _editModel != null)
            {
                _editModel.ImageUrl = $"data:{format};base64,{base64}";
            }
            else
            {
                _newContrib.ImageUrl = $"data:{format};base64,{base64}";
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải ảnh lên: {ex.Message}", Severity.Error);
        }
    }

    private Task OnContributionAddressTextChanged(string text)
    {
        _contributionAddressQuery = text ?? string.Empty;
        _contributionAddressStatus = string.IsNullOrWhiteSpace(_contributionAddressQuery)
            ? string.Empty
            : "Chọn một gợi ý để định vị và tự điền tên địa điểm.";

        if (_selectedContributionAddressSuggestion != null &&
            !string.Equals(_selectedContributionAddressSuggestion.DisplayName, _contributionAddressQuery, StringComparison.OrdinalIgnoreCase))
        {
            _selectedContributionAddressSuggestion = null;
        }

        return Task.CompletedTask;
    }

    private async Task<IEnumerable<AddressSuggestion>> SearchContributionAddressSuggestionsAsync(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Trim().Length < 3)
        {
            _contributionAddressStatus = string.Empty;
            return Array.Empty<AddressSuggestion>();
        }

        try
        {
            using var client = new HttpClient();
            using var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&limit=5&q={Uri.EscapeDataString(value.Trim())}");
            request.Headers.TryAddWithoutValidation("User-Agent", "ZoneGuide-Admin/1.0");
            request.Headers.TryAddWithoutValidation("Accept-Language", "vi");

            using var response = await client.SendAsync(request, token);
            if (!response.IsSuccessStatusCode)
            {
                _contributionAddressStatus = "Không thể lấy gợi ý địa chỉ.";
                return Array.Empty<AddressSuggestion>();
            }

            var results = await response.Content.ReadFromJsonAsync<List<AddressSuggestion>>(cancellationToken: token)
                          ?? new List<AddressSuggestion>();
            _contributionAddressStatus = results.Count == 0 ? "Không có địa chỉ" : $"Tìm thấy {results.Count} gợi ý địa chỉ.";
            return results;
        }
        catch
        {
            _contributionAddressStatus = "Không thể lấy gợi ý địa chỉ.";
            return Array.Empty<AddressSuggestion>();
        }
    }

    private async Task OnContributionAddressSuggestionSelected(AddressSuggestion? suggestion)
    {
        _selectedContributionAddressSuggestion = suggestion;

        if (suggestion == null)
        {
            if (string.IsNullOrWhiteSpace(_contributionAddressQuery))
            {
                _contributionAddressStatus = string.Empty;
            }
            return;
        }

        _contributionAddressQuery = suggestion.DisplayName;
        _contributionAddressStatus = "Đã điền địa chỉ và cập nhật vị trí trên bản đồ.";
        ApplyAutoContributionName(suggestion.Name, suggestion.DisplayName);

        if (!suggestion.TryGetCoordinates(out var lat, out var lng))
        {
            _contributionAddressStatus = "Không đọc được tọa độ từ gợi ý địa chỉ.";
            return;
        }

        ApplyContributionCoordinates(lat, lng);
        await JS.InvokeVoidAsync("addTempMarkerToPOIMap", lat, lng, false);
        StateHasChanged();
    }

    private async Task ResolveContributionAddressAsync(double lat, double lng)
    {
        try
        {
            using var client = new HttpClient();
            using var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"https://nominatim.openstreetmap.org/reverse?format=json&lat={lat.ToString(System.Globalization.CultureInfo.InvariantCulture)}&lon={lng.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
            request.Headers.TryAddWithoutValidation("User-Agent", "ZoneGuide-Admin/1.0");
            request.Headers.TryAddWithoutValidation("Accept-Language", "vi");

            using var response = await client.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                SetContributionAddressNotFound();
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ReverseGeocodeResult>();
            if (string.IsNullOrWhiteSpace(result?.DisplayName))
            {
                SetContributionAddressNotFound();
                return;
            }

            _contributionAddressQuery = result.DisplayName;
            _contributionAddressStatus = "Đã cập nhật địa chỉ từ vị trí trên bản đồ.";
            ApplyAutoContributionName(result.Name, result.DisplayName);
        }
        catch
        {
            SetContributionAddressNotFound();
        }
    }

    private void SetContributionAddressNotFound()
    {
        _contributionAddressQuery = "Không có địa chỉ";
        _contributionAddressStatus = "Không có địa chỉ";
    }

    private void ApplyContributionCoordinates(double lat, double lng)
    {
        if (_isEditMode && _editModel != null)
        {
            _editModel.Latitude = Math.Round(lat, 6);
            _editModel.Longitude = Math.Round(lng, 6);
            return;
        }

        _newContrib.Latitude = Math.Round(lat, 6);
        _newContrib.Longitude = Math.Round(lng, 6);
    }

    private void ApplyAutoContributionName(string? candidateName, string? displayName)
    {
        var suggestedName = string.IsNullOrWhiteSpace(candidateName)
            ? ExtractContributionNameFromAddress(displayName)
            : candidateName!.Trim();

        if (string.IsNullOrWhiteSpace(suggestedName))
        {
            return;
        }

        var currentName = _isEditMode && _editModel != null ? _editModel.Name : _newContrib.Name;
        if (string.IsNullOrWhiteSpace(currentName) || string.Equals(currentName, _lastAutoFilledContributionName, StringComparison.Ordinal))
        {
            if (_isEditMode && _editModel != null)
            {
                _editModel.Name = suggestedName;
            }
            else
            {
                _newContrib.Name = suggestedName;
            }

            _lastAutoFilledContributionName = suggestedName;
        }
    }

    private static string ExtractContributionNameFromAddress(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return string.Empty;
        }

        var firstPart = displayName.Split(',', 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault();

        return firstPart ?? displayName.Trim();
    }

    private void ResetContributionAddressState()
    {
        _contributionAddressQuery = "";
        _contributionAddressStatus = "";
        _selectedContributionAddressSuggestion = null;
        _lastAutoFilledContributionName = null;
    }

    private string GetContributionAddressDisplay(POIContributionDto contrib)
        => _contributionAddressCache.TryGetValue(contrib.Id, out var address) ? address : "Đang tải địa chỉ...";

    private async Task ResolveContributionAddressesAsync(IEnumerable<POIContributionDto> contributions)
    {
        foreach (var contribution in contributions.Where(c => c.Latitude.HasValue && c.Longitude.HasValue))
        {
            if (_contributionAddressCache.ContainsKey(contribution.Id))
            {
                continue;
            }

            try
            {
                var latitude = contribution.Latitude ?? 0;
                var longitude = contribution.Longitude ?? 0;
                var address = await JS.InvokeAsync<string>(
                    "reverseGeocodeAddress",
                    latitude.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    longitude.ToString(System.Globalization.CultureInfo.InvariantCulture));
                _contributionAddressCache[contribution.Id] = string.IsNullOrWhiteSpace(address) ? "Không có địa chỉ" : address;
            }
            catch
            {
                _contributionAddressCache[contribution.Id] = "Không có địa chỉ";
            }
        }
    }

    private async Task GenerateContributorTtsAsync()
    {
        var activeScript = _isEditMode && _editModel != null ? _editModel.TTSScript : _newContrib.TTSScript;
        if (string.IsNullOrWhiteSpace(activeScript))
        {
            Snackbar.Add("Vui lòng nhập nội dung thuyết minh trước.", Severity.Warning);
            return;
        }

        _isGeneratingContributorTts = true;
        try
        {
            var response = await ApiService.GenerateTtsAsync(activeScript, "vi-VN");
            if (string.IsNullOrWhiteSpace(response))
            {
                Snackbar.Add("Không tạo được giọng đọc.", Severity.Warning);
                return;
            }

            var audioUrl = response.StartsWith("data:audio", StringComparison.OrdinalIgnoreCase)
                ? response
                : $"data:audio/mp3;base64,{response}";

            if (_isEditMode && _editModel != null)
            {
                _editModel.AudioUrl = audioUrl;
            }
            else
            {
                _newContrib.AudioUrl = audioUrl;
            }

            Snackbar.Add("Đã tạo audio TTS thành công.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tạo audio: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isGeneratingContributorTts = false;
            StateHasChanged();
        }
    }

    private Color GetStatusColor(string statusString) 
    {
        if (Enum.TryParse<POIApprovalStatus>(statusString, out var status))
        {
            return status switch
            {
                POIApprovalStatus.Approved => Color.Success,
                POIApprovalStatus.Pending => Color.Warning,
                POIApprovalStatus.Rejected => Color.Error,
                POIApprovalStatus.NeedsRevision => Color.Info,
                _ => Color.Default
            };
        }
        return Color.Default;
    }

