<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ZoneGuide.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
    xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            x:Name="HomeTab"
            Title="{local:Translate tab_home}"
            ContentTemplate="{DataTemplate views:HomePage}"
            Icon="location.svg"
            Route="home" />

        <ShellContent
            x:Name="MapTab"
            Title="{local:Translate tab_map}"
            ContentTemplate="{DataTemplate views:MapPage}"
            Icon="map.png"
            Route="map" />

        <ShellContent
            x:Name="TourTab"
            Title="{local:Translate tab_tours}"
            ContentTemplate="{DataTemplate views:TourListPage}"
            Icon="location.png"
            Route="tours" />

        <ShellContent
            x:Name="MoreTab"
            Title="{local:Translate tab_more}"
            ContentTemplate="{DataTemplate views:MorePage}"
            Icon="settings.svg"
            Route="more" />
    </TabBar>

</Shell>
