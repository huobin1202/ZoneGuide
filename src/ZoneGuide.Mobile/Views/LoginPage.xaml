<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:converters="clr-namespace:ZoneGuide.Mobile.Converters"
             x:Class="ZoneGuide.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             BackgroundColor="#F6F7FB"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <Grid BackgroundColor="{StaticResource Primary}"
                  Padding="24,52,24,30"
                  MinimumHeightRequest="210">
                <VerticalStackLayout VerticalOptions="End"
                                     Spacing="8">
                          <Label Text="{local:Translate login_title}"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White" />
                          <Label Text="{local:Translate login_subtitle}"
                           FontSize="14"
                           TextColor="#DDD6FF" />
                </VerticalStackLayout>
            </Grid>

            <Border Margin="20,-32,20,24"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    Padding="20">
                <VerticalStackLayout Spacing="14">
                          <Label Text="{local:Translate login_email}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}" />
                    <Entry Text="{Binding Email}"
                           Placeholder="example@email.com"
                           Keyboard="Email"
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Next" />

                          <Label Text="{local:Translate login_password}"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}" />
                    <Entry Text="{Binding Password}"
                              Placeholder="{local:Translate login_password_placeholder}"
                           IsPassword="True"
                           ReturnType="Done" />

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource Error}"
                           FontSize="13"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}" />

                        <Button Text="{local:Translate login_button}"
                            HeightRequest="52"
                            CornerRadius="16"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
