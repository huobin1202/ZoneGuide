        {
            Snackbar.Add("Không đọc được yêu cầu chỉnh sửa vừa tạo.", Severity.Error);
            return;
        }

        var submitResponse = await Http.PostAsync($"api/contributions/{createdContribution.Id}/submit", null);
        if (!submitResponse.IsSuccessStatusCode)
        {
            Snackbar.Add("Đã tạo bản chỉnh sửa ở trạng thái nháp. Vui lòng gửi duyệt trong mục Đóng góp của tôi.", Severity.Warning);
        }
        else
        {
            Snackbar.Add("Đã tạo yêu cầu chỉnh sửa và gửi admin duyệt.", Severity.Success);
        }

        CancelEdit();
        await LoadData();
    }

    private int? ResolveOriginalPoiId(POIContributionDto contribution)
    {
        var exact = _allPoisForMap.FirstOrDefault(p =>
            string.Equals(p.Name, contribution.Name, StringComparison.OrdinalIgnoreCase)
            && Math.Abs(p.Latitude - (contribution.Latitude ?? 0)) < 0.0002
            && Math.Abs(p.Longitude - (contribution.Longitude ?? 0)) < 0.0002);
        if (exact != null && int.TryParse(exact.Id, out var exactId))
        {
            return exactId;
        }

        var byName = _allPoisForMap
            .Where(p => string.Equals(p.Name, contribution.Name, StringComparison.OrdinalIgnoreCase))
            .OrderBy(p => Math.Abs(p.Latitude - (contribution.Latitude ?? p.Latitude))
                        + Math.Abs(p.Longitude - (contribution.Longitude ?? p.Longitude)))
            .FirstOrDefault();

        return byName != null && int.TryParse(byName.Id, out var byNameId) ? byNameId : null;
    }

