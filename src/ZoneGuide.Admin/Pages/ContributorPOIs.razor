            return;
        }

        var createDto = new CreatePOIContributionDto
        {
            OriginalPOIId = originalPoiId,
            Name = _editModel.Name,
            Latitude = _editModel.Latitude,
            Longitude = _editModel.Longitude,
            TriggerRadius = _editModel.TriggerRadius,
            ApproachRadius = _editModel.ApproachRadius,
            Priority = _editModel.Priority,
            AudioUrl = _editModel.AudioUrl,
            TTSScript = _editModel.TTSScript,
            ImageUrl = _editModel.ImageUrl,
            Category = _editModel.Category,
            ContributorNotes = AttachTranslationMeta(_editModel.ContributorNotes, _editContribTranslations)
        };

        var createResponse = await Http.PostAsJsonAsync("api/contributions", createDto);
        if (!createResponse.IsSuccessStatusCode)
        {
            var createError = await createResponse.Content.ReadAsStringAsync();
            Snackbar.Add($"Không tạo được yêu cầu chỉnh sửa: {createError}", Severity.Error);
            return;
