@using System.Globalization
@using System.Net.Http.Json
@using ZoneGuide.Shared.Models
@inject HttpClient Http
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Place" Class="mr-2" />
            Vị trí đóng góp: @Contribution.Name
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <MudPaper Class="pa-3" Elevation="0" Style="border:1px solid rgba(25,118,210,.18); background:#f8fbff;">
                <MudText Typo="Typo.subtitle2">Địa chỉ</MudText>
                <MudText Typo="Typo.body2">@_addressDisplay</MudText>
                @if (HasLocation)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        @Contribution.Latitude?.ToString("F6", CultureInfo.InvariantCulture), @Contribution.Longitude?.ToString("F6", CultureInfo.InvariantCulture)
                    </MudText>
                }
            </MudPaper>

            @if (HasLocation)
            {
                <div id="@_mapElementId" style="width:100%; height:520px; border-radius:16px; overflow:hidden; border:1px solid rgba(15,23,42,.10);"></div>
            }
            else
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    Đóng góp này chưa có tọa độ để hiển thị trên bản đồ.
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public POIContributionDto Contribution { get; set; } = null!;

    private readonly string _mapElementId = $"contribution-map-{Guid.NewGuid():N}";
    private string _addressDisplay = "Đang tải địa chỉ...";
    private List<POIDto> _pois = new();
    private bool _mapInitialized;
    private string ContributionMarkerId => $"contribution-{Contribution.Id}";
    private bool HasLocation => Contribution.Latitude.HasValue && Contribution.Longitude.HasValue;

    protected override async Task OnInitializedAsync()
    {
        if (!HasLocation)
        {
            _addressDisplay = "Không có địa chỉ";
            return;
        }

        var poiTask = LoadAllPoisAsync();
        var addressTask = ResolveAddressAsync();
        await Task.WhenAll(poiTask, addressTask);
        _pois = poiTask.Result;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !HasLocation || _mapInitialized)
        {
            return;
        }

        _mapInitialized = true;

        var poiData = _pois
            .Select(p => new
            {
                id = p.Id,
                name = p.Name,
                address = p.Address,
                lat = p.Latitude,
                lng = p.Longitude,
                description = p.TTSScript ?? p.FullDescription ?? p.ShortDescription,
                category = p.Category ?? "Khác",
                imageUrl = p.ImageUrl,
                triggerRadius = p.TriggerRadius > 0 ? p.TriggerRadius : p.TriggerRadiusMeters
            })
            .Cast<object>()
            .ToList();

        poiData.Add(new
        {
            id = ContributionMarkerId,
            name = Contribution.Name,
            address = _addressDisplay,
            lat = Contribution.Latitude!.Value,
            lng = Contribution.Longitude!.Value,
            description = Contribution.TTSScript ?? Contribution.FullDescription ?? Contribution.ShortDescription,
            category = Contribution.Category ?? "Đóng góp",
            imageUrl = Contribution.ImageUrl,
            triggerRadius = Contribution.TriggerRadius,
            isContribution = true
        });

        await JS.InvokeVoidAsync(
            "initPOIMap",
            _mapElementId,
            Contribution.Latitude!.Value,
            Contribution.Longitude!.Value,
            poiData,
            null,
            true,
            ContributionMarkerId,
            true);
    }

    private async Task ResolveAddressAsync()
    {
        try
        {
            var address = await JS.InvokeAsync<string>(
                "reverseGeocodeAddress",
                Contribution.Latitude!.Value.ToString(CultureInfo.InvariantCulture),
                Contribution.Longitude!.Value.ToString(CultureInfo.InvariantCulture));
            _addressDisplay = string.IsNullOrWhiteSpace(address) ? "Không có địa chỉ" : address;
        }
        catch
        {
            _addressDisplay = "Không có địa chỉ";
        }
    }

    private async Task<List<POIDto>> LoadAllPoisAsync()
    {
        try
        {
            using var client = new HttpClient
            {
                BaseAddress = Http.BaseAddress
            };
            return await client.GetFromJsonAsync<List<POIDto>>("api/pois/all") ?? new List<POIDto>();
        }
        catch
        {
            return new List<POIDto>();
        }
    }

    private void Close() => MudDialog?.Close();
}
