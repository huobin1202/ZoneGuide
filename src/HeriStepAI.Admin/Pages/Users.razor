@page "/users"
@using HeriStepAI.Shared.Models
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Quản lý Users - HeriStepAI</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
        Quản lý Users
    </MudText>
    
    <MudPaper Elevation="2" Class="pa-4">
        <MudTable Items="@users" Hover="true" Striped="true" Loading="@isLoading" LoadingProgressColor="Color.Primary"
                  Dense="true" Filter="new Func<UserDto, bool>(FilterFunc)">
            <ToolBarContent>
                <MudTextField @bind-Value="searchString" Placeholder="Tìm kiếm..." Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0" />
                <MudSpacer />
                <MudChipSet SelectedChipChanged="OnRoleFilterChanged" T="string">
                    <MudChip Text="Tất cả" Default="true" Color="Color.Default" Variant="Variant.Text">Tất cả</MudChip>
                    <MudChip Text="Admin" Color="Color.Error" Variant="Variant.Text">Admin</MudChip>
                    <MudChip Text="Contributor" Color="Color.Warning" Variant="Variant.Text">Contributor</MudChip>
                    <MudChip Text="User" Color="Color.Info" Variant="Variant.Text">User</MudChip>
                </MudChipSet>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Email</MudTh>
                <MudTh>Tên hiển thị</MudTh>
                <MudTh>Role</MudTh>
                <MudTh>Trạng thái</MudTh>
                <MudTh>Ngày tạo</MudTh>
                <MudTh>Đăng nhập cuối</MudTh>
                <MudTh>Hành động</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Tên">@context.DisplayName</MudTd>
                <MudTd DataLabel="Role">
                    <MudChip T="string" Color="@GetRoleColor(context.Role)" Size="Size.Small">@context.Role</MudChip>
                </MudTd>
                <MudTd DataLabel="Trạng thái">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                </MudTd>
                <MudTd DataLabel="Ngày tạo">@context.CreatedAt.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Đăng nhập cuối">@(context.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
                <MudTd DataLabel="Hành động">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => OpenChangeRoleDialog(context))" title="Đổi Role" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>Không có user nào</MudText>
            </NoRecordsContent>
            <LoadingContent>
                <MudText>Đang tải...</MudText>
            </LoadingContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<UserDto> users = new();
    private bool isLoading = true;
    private string searchString = string.Empty;
    private string? roleFilter = null;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }
    
    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            var response = await Http.GetFromJsonAsync<List<UserDto>>("api/users");
            users = response ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải danh sách: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
    
    private bool FilterFunc(UserDto user)
    {
        if (string.IsNullOrWhiteSpace(searchString) && string.IsNullOrEmpty(roleFilter))
            return true;
        
        var matchSearch = string.IsNullOrWhiteSpace(searchString) ||
                          user.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase) ||
                          user.DisplayName.Contains(searchString, StringComparison.OrdinalIgnoreCase);
        
        var matchRole = string.IsNullOrEmpty(roleFilter) || roleFilter == "Tất cả" ||
                        user.Role.Equals(roleFilter, StringComparison.OrdinalIgnoreCase);
        
        return matchSearch && matchRole;
    }
    
    private void OnRoleFilterChanged(MudChip<string>? chip)
    {
        roleFilter = chip?.Text;
        StateHasChanged();
    }
    
    private async Task OpenChangeRoleDialog(UserDto user)
    {
        var parameters = new DialogParameters
        {
            { "User", user }
        };
        
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<ChangeRoleDialog>("Đổi Role", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadUsers();
        }
    }
    
    private Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "Contributor" => Color.Warning,
        _ => Color.Info
    };
    
    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Pending" => Color.Warning,
        "Suspended" => Color.Error,
        _ => Color.Default
    };
}
