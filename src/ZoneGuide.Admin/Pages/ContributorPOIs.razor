    private async Task SubmitEdit()
    {
        if (_editModel == null) return;
        
        try
        {
            var updateDto = new UpdatePOIContributionDto
            {
                Name = _editModel.Name,
                ShortDescription = _editModel.ShortDescription,
                FullDescription = _editModel.FullDescription,
                Latitude = _editModel.Latitude,
                Longitude = _editModel.Longitude,
                TriggerRadius = _editModel.TriggerRadius,
                ApproachRadius = _editModel.ApproachRadius,
                Priority = _editModel.Priority,
                AudioUrl = _editModel.AudioUrl,
                TTSScript = _editModel.TTSScript,
                ImageUrl = _editModel.ImageUrl,
                Category = _editModel.Category,
                ContributorNotes = _editModel.ContributorNotes
            };
            var response = await Http.PutAsJsonAsync($"api/contributions/{_editModel.Id}", updateDto);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Đã cập nhật bản đóng góp, vẫn theo luồng chờ admin duyệt.", Severity.Success);
                CancelEdit();
                await LoadData();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Lỗi: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

