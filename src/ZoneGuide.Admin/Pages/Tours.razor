@page "/tours"
@inject IApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Danh sach Tours</MudText>
            <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Quan ly cac tuyen tham quan du lich</MudText>
        </MudStack>

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog"
                   Style="min-width:160px;">
            Tao Tour moi
        </MudButton>
    </MudStack>

    <MudTextField @bind-Value="_searchString" Placeholder="Tim tour..."
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Immediate="true" Class="mt-4" />
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        @foreach (var tour in FilteredTours)
        {
            <MudItem xs="12" sm="6" md="4" lg="3" xl="3">
                <MudPaper Outlined="true" Class="tour-card">
                    @if (HasImage(tour))
                    {
                        <img src="@tour.ImageUrl" alt="@tour.Name" class="tour-card-image" />
                    }
                    else
                    {
                        <div class="tour-card-image tour-card-image-placeholder"></div>
                    }

                    <div class="tour-card-body">
                        <MudText Typo="Typo.h6" Class="tour-name-ellipsis" title="@tour.Name">@tour.Name</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">@TruncateText(tour.Description, 110)</MudText>

                        <MudStack Row="true" Spacing="2" Class="mb-2">
                            <MudText Typo="Typo.caption" Class="d-flex align-center mud-text-secondary">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                @FormatDuration(tour.EstimatedDurationMinutes)
                            </MudText>
                            <MudText Typo="Typo.caption" Class="d-flex align-center mud-text-secondary">
                                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                                @tour.POIIds.Count diem
                            </MudText>
                        </MudStack>

                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="tour-edit-btn"
                                       StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => OpenEditDialog(tour))">
                                Chinh sua
                            </MudButton>

                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Variant="Variant.Outlined"
                                           OnClick="@(() => ConfirmDelete(tour))" />
                        </MudStack>
                    </div>
                </MudPaper>
            </MudItem>
        }

        <MudItem xs="12" sm="6" md="4" lg="3" xl="3">
            <MudPaper Outlined="true" Class="tour-create-card" @onclick="OpenCreateDialog">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="fill-height" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">Them Tour moi</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (!FilteredTours.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            Khong tim thay tour phu hop voi tu khoa.
        </MudAlert>
    }
}

<style>
    .tour-card {
        border-radius: 16px;
        overflow: hidden;
        max-width: 320px;
        margin: 0 auto;
    }

    .tour-card-image {
        width: 100%;
        height: 136px;
        object-fit: cover;
        display: block;
    }

    .tour-card-image-placeholder {
        background: linear-gradient(140deg, #23243b, #0f111c 60%, #3d3f5c);
    }

    .tour-card-body {
        padding: 14px 14px 12px;
    }

    .tour-name-ellipsis {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .tour-card-body .mud-typography-body2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .tour-edit-btn {
        flex: 1;
    }

    .tour-create-card {
        height: 100%;
        min-height: 282px;
        border-style: dashed;
        border-width: 2px;
        cursor: pointer;
        border-color: #d8dceb;
        max-width: 320px;
        margin: 0 auto;
    }

    .fill-height {
        min-height: 282px;
    }
</style>

@code {
    private List<TourDto> _tours = new();
    private string _searchString = "";
    private bool _loading = true;

    private IEnumerable<TourDto> FilteredTours => string.IsNullOrWhiteSpace(_searchString)
        ? _tours
        : _tours.Where(t => 
            t.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            (t.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false));

    private static bool HasImage(TourDto tour)
    {
        return !string.IsNullOrWhiteSpace(tour.ImageUrl);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
    }

    private async Task LoadTours()
    {
        _loading = true;
        _tours = await ApiService.GetToursAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var pois = await ApiService.GetPOIsAsync();
        var parameters = new DialogParameters
        {
            { "Tour", null },
            { "IsEdit", false },
            { "AvailablePOIs", pois }
        };

        var dialog = await DialogService.ShowAsync<TourDialog>("Create New Tour", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadTours();
            Snackbar.Add("Tour created successfully", Severity.Success);
        }
    }

    private async Task OpenEditDialog(TourDto tour)
    {
        var pois = await ApiService.GetPOIsAsync();
        var parameters = new DialogParameters
        {
            { "Tour", tour },
            { "IsEdit", true },
            { "AvailablePOIs", pois }
        };

        var dialog = await DialogService.ShowAsync<TourDialog>("Edit Tour", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadTours();
            Snackbar.Add("Tour updated successfully", Severity.Success);
        }
    }

    private async Task ViewTourDetails(string tourId)
    {
        var tour = await ApiService.GetTourWithDetailsAsync(tourId);
        if (tour != null)
        {
            var parameters = new DialogParameters
            {
                { "Tour", tour }
            };

            await DialogService.ShowAsync<TourDetailsDialog>("Tour Details", parameters,
                new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        }
    }

    private async Task ConfirmDelete(TourDto tour)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Delete Tour",
            $"Are you sure you want to delete '{tour.Name}'?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            var success = await ApiService.DeleteTourAsync(tour.Id);
            if (success)
            {
                await LoadTours();
                Snackbar.Add("Tour deleted successfully", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to delete tour", Severity.Error);
            }
        }
    }

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "N/A";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    private string FormatDuration(int minutes)
    {
        if (minutes < 60) return $"{minutes} min";
        var hours = minutes / 60;
        var mins = minutes % 60;
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }
}
