<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ZoneGuide.Mobile.ViewModels"
             xmlns:local="clr-namespace:ZoneGuide.Mobile.Localization"
             xmlns:views="clr-namespace:ZoneGuide.Mobile.Views"
             x:Class="ZoneGuide.Mobile.Views.HistoryPage"
             x:Name="HistoryRoot"
             x:DataType="vm:HistoryViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F6F7FB">

    <Grid RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0"
                             Padding="16,20,16,12"
                             Spacing="14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="6">
                <Label Grid.Column="0"
                       Text="{local:Translate history_title}"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Gray950}"
                       VerticalOptions="End" />

            </Grid>

            <CollectionView ItemsSource="{Binding DateFilters}"
                            SelectionMode="None"
                            HeightRequest="86">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"
                                       ItemSpacing="0" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:HistoryDateFilterItem">
                        <Border BackgroundColor="White"
                                Padding="10,8"
                                Margin="0"
                                Stroke="#E4E4E8"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.SelectDateFilterCommand, Source={x:Reference HistoryRoot}}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsSelected}"
                                             Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                    <Setter Property="StrokeThickness" Value="1.8" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid WidthRequest="78">
                                <Label Text="{Binding LeadingIcon}"
                                       IsVisible="{Binding IsOverview}"
                                       FontSize="28"
                                       Margin="0,-6,0,0"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                                <Label Text="{local:Translate history_overview}"
                                       IsVisible="{Binding IsOverview}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="End"
                                       Margin="0,0,0,2" />
                                <VerticalStackLayout IsVisible="{Binding IsDateItem}"
                                                     Spacing="2"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding HeaderText}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray900}" />
                                    <Label Text="{Binding DateText}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray900}" />
                                    <Label Text="{Binding DayText}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Gray950}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView Margin="0,12,0,0"
                            IsGrouped="True"
                            ItemsSource="{Binding HistoryGroups}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="32,80"
                                         Spacing="10"
                                         HorizontalOptions="Center">
                        <Label Text="{local:Translate history_empty_title}"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{local:Translate history_empty_subtitle}"
                               FontSize="13"
                               TextColor="{StaticResource Gray500}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="vm:HistoryDayGroup">
                        <Label Text="{Binding Title}"
                               Margin="20,12,20,6"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:HistoryEntryViewModel">
                        <Frame Margin="16,6"
                               Padding="8"
                               BackgroundColor="White"
                               CornerRadius="18"
                               HasShadow="False">
                            <Grid ColumnDefinitions="90,*,Auto"
                                  ColumnSpacing="16">
                                <Frame Grid.Column="0"
                                       WidthRequest="90"
                                       HeightRequest="90"
                                       Padding="0"
                                       CornerRadius="16"
                                       BackgroundColor="#ECEAF8"
                                       IsClippedToBounds="True">
                                    <Image Source="{Binding ImageUrl, Converter={StaticResource FlexibleImageSourceConverter}}"
                                           Aspect="AspectFill" />
                                </Frame>

                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="4"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           MaxLines="1" />
                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="{StaticResource Gray500}"
                                           MaxLines="2" />
                                    <HorizontalStackLayout Spacing="8"
                                                           Margin="0,2,0,0">
                                        <Border BackgroundColor="#F2EFFF"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="8,2">
                                            <Label Text="{Binding Category, Converter={StaticResource LocalizedCategoryConverter}}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Primary}" />
                                        </Border>
                                        <Label Text="{Binding DurationText}"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalTextAlignment="Center" />
                                        <Label Text="•"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="Center" />
                                        <Label Text="{Binding PlayCountText}"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalTextAlignment="Center" />
                                        <Label Text="•"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray400}"
                                               VerticalTextAlignment="Center" />
                                        <Label Text="{Binding PlayedAtText}"
                                               FontSize="11"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding LastLanguageText}"
                                           FontSize="11"
                                           TextColor="{StaticResource Gray400}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="8"
                                                     VerticalOptions="Center">
                                    <Button Text="▶"
                                            WidthRequest="48"
                                            HeightRequest="48"
                                            CornerRadius="24"
                                            FontSize="16"
                                            Padding="0"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="White"
                                            Command="{Binding BindingContext.ReplayCommand, Source={x:Reference HistoryRoot}}"
                                            CommandParameter="{Binding .}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource PoiMatchConverter}">
                                                        <Binding Source="{x:Reference HistoryRoot}" Path="BindingContext.CurrentNarrationPoiId" />
                                                        <Binding Path="POIId" />
                                                        <Binding Source="{x:Reference HistoryRoot}" Path="BindingContext.IsCurrentNarrationPlaying" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Text" Value="⏸" />
                                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                                                <Setter Property="TextColor" Value="White" />
                                                <Setter Property="Command">
                                                    <Setter.Value>
                                                        <Binding Source="{x:Reference HistoryRoot}" Path="BindingContext.ToggleStopResumeCommand" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <ImageButton Source="trash_red.svg"
                                                 WidthRequest="48"
                                                 HeightRequest="48"
                                                 CornerRadius="24"
                                                 Padding="12"
                                                 BackgroundColor="#FFECEE"
                                                 Command="{Binding BindingContext.DeleteCommand, Source={x:Reference HistoryRoot}}"
                                                 CommandParameter="{Binding .}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <views:MiniPlayerView Grid.Row="2" />
    </Grid>

</ContentPage>
