@using System.Globalization
@inject IApiService ApiService
@inject IJSRuntime JS

<MudDialog Class="tour-planner-dialog">
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <div class="tour-planner-layout">
                <aside class="tour-pane tour-pane-left">
                    <div class="tour-pane-header">
                        <div>
                            <MudText Typo="Typo.h5" Class="tour-title">Quản lý Tour</MudText>
                            <MudText Typo="Typo.caption" Class="tour-muted">@($"{ActiveSelectedPOIs.Count}/{_selectedPOIs.Count} điểm đang hoạt động")</MudText>
                        </div>
                    </div>

                    <MudTextField @bind-Value="_searchKeyword"
                                  Placeholder="Tìm kiếm địa điểm..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="tour-search" />

                    <div class="tour-location-list">
                        @if (FilteredAvailablePOIs.Any())
                        {
                            @foreach (var poi in FilteredAvailablePOIs)
                            {
                                var selectedIndex = GetSelectedIndex(poi.Id);
                                var selected = selectedIndex >= 0;
                                <div class="tour-location-card @(selected ? "is-selected" : string.Empty) @(!poi.IsActive ? "is-inactive" : string.Empty)">
                                    <button type="button" class="tour-location-main" @onclick="@(() => TogglePOIAsync(poi))">
                                        <span class="tour-order-badge @(selected ? "is-active" : "is-idle")">@(selected ? (selectedIndex + 1).ToString(CultureInfo.InvariantCulture) : "+")</span>
                                        <span class="tour-location-copy">
                                            <span class="tour-location-name" title="@poi.Name">@poi.Name</span>
                                            <span class="tour-location-subtitle">
                                                @if (!poi.IsActive)
                                                {
                                                    <span class="tour-inactive-pill">Đã tắt</span>
                                                }
                                                @GetPOISubtitle(poi)
                                            </span>
                                        </span>
                                    </button>
                                    <span class="tour-route-actions">
                                        @if (selected)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Disabled="@(selectedIndex == 0)" OnClick="@(() => MovePOIAsync(poi, -1))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Disabled="@(selectedIndex == _selectedPOIs.Count - 1)" OnClick="@(() => MovePOIAsync(poi, 1))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemovePOIAsync(poi))" />
                                        }
                                        else
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Color="Color.Primary" OnClick="@(() => TogglePOIAsync(poi))" />
                                        }
                                    </span>
                                </div>
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">Không có địa điểm phù hợp với từ khóa.</MudAlert>
                        }
                    </div>
                </aside>

                <section class="tour-pane tour-pane-map">
                    <div id="@_mapElementId" class="tour-route-map"></div>
                    <div class="tour-map-summary">
                        <div class="tour-summary-chip">
                            <MudIcon Icon="@Icons.Material.Filled.Route" Size="Size.Small" />
                            <span>@DistanceLabel</span>
                        </div>
                        <div class="tour-summary-chip">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" />
                            <span>@DurationLabel</span>
                        </div>
                    </div>
                </section>

                <aside class="tour-pane tour-pane-right">
                    <MudText Typo="Typo.h5" Class="tour-title">Thông Tin Tour</MudText>
                    <MudText Typo="Typo.body2" Class="tour-muted tour-panel-description">Điền thông tin để tạo tour du lịch</MudText>

                    <MudStack Spacing="3" Class="mt-5">
                        <MudTextField @bind-Value="_model.Name" Label="Tên Tour" Required="true" RequiredError="Tên tour là bắt buộc" Variant="Variant.Outlined" />

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tour-field-label">Ảnh bìa</MudText>
                            <MudFileUpload T="IBrowserFile" Accept=".png, .jpg, .jpeg, .webp" FilesChanged="UploadImage">
                                <ActivatorContent>
                                    <div class="tour-upload-frame">
                                        <button type="button" class="tour-upload-box">
                                            @if (string.IsNullOrWhiteSpace(_model.ImageUrl))
                                            {
                                                <span class="tour-upload-placeholder">
                                                    <MudIcon Icon="@Icons.Material.Filled.FileUpload" Size="Size.Medium" />
                                                    <span>Nhấp hoặc kéo thả ảnh bìa</span>
                                                    <span>PNG, JPG, WEBP...</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <img src="@_model.ImageUrl" alt="Ảnh bìa tour" class="tour-cover-preview" />
                                            }
                                        </button>
                                        @if (!string.IsNullOrWhiteSpace(_model.ImageUrl))
                                        {
                                            <button type="button" class="tour-upload-remove"
                                                    @onclick="@(() => _model.ImageUrl = null)"
                                                    @onclick:stopPropagation="true"
                                                    @onclick:preventDefault="true"
                                                    title="Xóa ảnh">×</button>
                                        }
                                    </div>
                                </ActivatorContent>
                            </MudFileUpload>
                        </div>

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tour-field-label">Mô tả</MudText>
                            <MudTextField @bind-Value="_model.Description" Placeholder="Mô tả chi tiết hành trình tour..." Variant="Variant.Outlined" Lines="6" />
                        </div>

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tour-field-label">Thời gian</MudText>
                            <div class="tour-time-grid">
                                <MudTextField Value="@EstimatedHoursText" Label="Giờ" Variant="Variant.Outlined" ReadOnly="true" />
                                <MudTextField Value="@EstimatedMinutesText" Label="Phút" Variant="Variant.Outlined" ReadOnly="true" />
                            </div>
                        </div>

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tour-field-label">Quãng đường</MudText>
                            <MudTextField Value="@DistanceValueText" Label="Km" Variant="Variant.Outlined" ReadOnly="true" />
                            <MudText Typo="Typo.caption" Class="tour-route-note">
                                @if (_selectedPOIs.Count >= 2)
                                {
                                    <span>Ước tính đường chim bay: ~@FormatDistance(_straightLineDistanceKm) km</span>
                                }
                                else
                                {
                                    <span>Chọn thêm điểm để hệ thống tính quãng đường.</span>
                                }
                            </MudText>
                            <MudText Typo="Typo.caption" Class="tour-route-note">@(_routingAvailable ? "Đang dùng tuyến đường thực tế từ routing." : "Routing chưa sẵn sàng, tạm dùng ước tính theo đường nối thẳng.")</MudText>
                        </div>

                        <MudSwitch @bind-Value="_model.IsActive" Label="Kích hoạt tour" Color="Color.Primary" />
                    </MudStack>
                </aside>
            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!_isValid || _saving || !_selectedPOIs.Any())">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @(IsEdit ? "Lưu Tour" : "Tạo Tour")
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .tour-planner-dialog .mud-dialog {
        max-width: 1400px;
    }

    .tour-planner-dialog .mud-dialog-content {
        padding: 0;
    }

    .tour-planner-dialog .mud-dialog-actions {
        border-top: 1px solid #e9edf5;
        padding: 16px 20px;
    }

    .tour-planner-layout {
        display: grid;
        grid-template-columns: minmax(300px, 360px) minmax(420px, 1fr) minmax(320px, 380px);
        min-height: 78vh;
    }

    .tour-pane {
        min-width: 0;
        background: #fff;
    }

    .tour-pane-left,
    .tour-pane-right {
        padding: 24px 20px;
    }

    .tour-pane-left {
        border-right: 1px solid #e9edf5;
        background: linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
    }

    .tour-pane-right {
        border-left: 1px solid #e9edf5;
    }

    .tour-pane-map {
        position: relative;
        background: #f4f7fb;
    }

    .tour-pane-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .tour-title {
        font-weight: 700;
        color: #172554;
    }

    .tour-muted {
        color: #8a94a6;
    }

    .tour-panel-description {
        max-width: 280px;
    }

    .tour-search {
        margin-bottom: 18px;
    }

    .tour-location-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-height: calc(78vh - 180px);
        overflow: auto;
        padding-right: 4px;
    }

    .tour-location-card {
        width: 100%;
        border: 1px solid #e4eaf4;
        border-radius: 18px;
        padding: 8px 10px 8px 8px;
        background: #fff;
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
        transition: all 0.2s ease;
    }

    .tour-location-card.is-selected {
        border-color: #c7d2fe;
        box-shadow: 0 12px 24px rgba(37, 99, 235, 0.08);
    }

    .tour-location-card.is-inactive {
        opacity: 0.55;
        border-style: dashed;
    }

    .tour-location-main {
        flex: 1;
        min-width: 0;
        border: 0;
        background: transparent;
        padding: 6px 6px 6px 4px;
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
        cursor: pointer;
    }

    .tour-order-badge {
        width: 38px;
        height: 38px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
        color: #fff;
    }

    .tour-order-badge.is-active {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
    }

    .tour-order-badge.is-idle {
        border: 2px dashed #cfd8e6;
        color: #94a3b8;
        background: #fff;
    }

    .tour-location-copy {
        min-width: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .tour-location-name {
        font-size: 1rem;
        font-weight: 700;
        color: #12213f;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .tour-location-subtitle {
        font-size: 0.88rem;
        color: #8290a8;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .tour-inactive-pill {
        display: inline-block;
        margin-right: 6px;
        padding: 1px 6px;
        border-radius: 999px;
        background: #fee2e2;
        color: #b91c1c;
        font-size: 0.75rem;
        font-weight: 700;
        vertical-align: middle;
    }

    .tour-route-actions {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        flex-shrink: 0;
    }

    .tour-route-map {
        width: 100%;
        height: 100%;
        min-height: 78vh;
    }

    .tour-map-summary {
        position: absolute;
        left: 16px;
        right: 16px;
        bottom: 16px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        pointer-events: none;
    }

    .tour-summary-chip {
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.94);
        color: #1e3a8a;
        padding: 10px 14px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.15);
        font-weight: 600;
    }

    .tour-field-label {
        margin-bottom: 8px;
        color: #334155;
    }

    .tour-upload-box {
        width: 100%;
        min-height: 124px;
        border-radius: 22px;
        border: 1.5px dashed #d6deec;
        background: #fbfcfe;
        padding: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
    }

    .tour-upload-frame {
        position: relative;
    }

    .tour-upload-placeholder {
        color: #97a3b6;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        font-weight: 500;
    }

    .tour-cover-preview {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 16px;
        display: block;
    }

    .tour-upload-remove {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 30px;
        height: 30px;
        border: none;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.72);
        color: #fff;
        font-size: 22px;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
    }

    .tour-upload-remove:hover {
        background: rgba(220, 38, 38, 0.92);
    }

    .tour-time-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .tour-route-note {
        display: block;
        margin-top: 8px;
        color: #7c8799;
    }

    @@media (max-width: 1200px) {
        .tour-planner-layout {
            grid-template-columns: 320px minmax(0, 1fr);
        }

        .tour-pane-right {
            grid-column: 1 / -1;
            border-left: 0;
            border-top: 1px solid #e9edf5;
        }

        .tour-route-map {
            min-height: 56vh;
        }
    }

    @@media (max-width: 768px) {
        .tour-planner-layout {
            grid-template-columns: 1fr;
        }

        .tour-pane-left,
        .tour-pane-right {
            border: 0;
        }

        .tour-pane-left {
            border-bottom: 1px solid #e9edf5;
        }

        .tour-route-map {
            min-height: 50vh;
        }
    }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TourDto? Tour { get; set; }
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public List<POIDto> AvailablePOIs { get; set; } = new();

    private const double FallbackAverageSpeedKmPerHour = 35d;
    private readonly string _mapElementId = $"tour-route-map-{Guid.NewGuid():N}";
    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private bool _mapRendered;
    private bool _routingAvailable;
    private string _searchKeyword = string.Empty;
    private double _straightLineDistanceKm;
    private TourFormModel _model = new();
    private readonly List<POIDto> _selectedPOIs = new();
    private List<POIDto> ActiveSelectedPOIs => _selectedPOIs.Where(p => p.IsActive).ToList();

    private IEnumerable<POIDto> FilteredAvailablePOIs =>
        AvailablePOIs
            .Where(p => string.IsNullOrWhiteSpace(_searchKeyword)
                        || p.Name.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase)
                        || (p.Category?.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false)
                        || (p.ShortDescription?.Contains(_searchKeyword, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderByDescending(p => IsPOISelected(p.Id))
            .ThenBy(p => GetSelectedIndex(p.Id) < 0 ? int.MaxValue : GetSelectedIndex(p.Id))
            .ThenBy(p => p.Name);

    private string DistanceLabel => _selectedPOIs.Count >= 2 ? $"{DistanceValueText} km" : "Chưa đủ dữ liệu quãng đường";
    private string DurationLabel => _selectedPOIs.Count >= 2 ? $"{EstimatedHoursText} giờ {EstimatedMinutesText} phút" : "Chưa đủ dữ liệu thời gian";
    private string DistanceValueText => _model.DistanceKm.ToString("0.0", CultureInfo.InvariantCulture);
    private string EstimatedHoursText => (_model.EstimatedDurationMinutes / 60).ToString(CultureInfo.InvariantCulture);
    private string EstimatedMinutesText => (_model.EstimatedDurationMinutes % 60).ToString(CultureInfo.InvariantCulture);

    protected override void OnInitialized()
    {
        if (Tour != null)
        {
            _model = new TourFormModel
            {
                Name = Tour.Name,
                Description = Tour.Description,
                EstimatedDurationMinutes = Tour.EstimatedDurationMinutes,
                DistanceKm = Tour.DistanceKm,
                ImageUrl = Tour.ImageUrl,
                Difficulty = Tour.Difficulty,
                IsActive = Tour.IsActive
            };

            foreach (var poiId in Tour.POIIds)
            {
                if (activeLookup.TryGetValue(poiId, out var poi))
                {
                    _selectedPOIs.Add(poi);
                }
            }
        }

        _straightLineDistanceKm = CalculateStraightLineDistanceKm(_selectedPOIs);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _mapRendered = true;
        await RefreshRouteAsync();
    }

    private bool IsPOISelected(string poiId) => _selectedPOIs.Any(p => p.Id == poiId);

    private int GetSelectedIndex(string poiId) => _selectedPOIs.FindIndex(p => p.Id == poiId);

    private string GetPOISubtitle(POIDto poi)
    {
        if (!string.IsNullOrWhiteSpace(poi.ShortDescription))
        {
            return poi.ShortDescription;
        }

        if (!string.IsNullOrWhiteSpace(poi.Category))
        {
            return $"{poi.Category} • {poi.Latitude:F4}, {poi.Longitude:F4}";
        }

        return $"{poi.Latitude:F4}, {poi.Longitude:F4}";
    }

    private async Task TogglePOIAsync(POIDto poi)
    {
        var existing = _selectedPOIs.FirstOrDefault(p => p.Id == poi.Id);
        if (existing != null)
        {
            _selectedPOIs.Remove(existing);
        }
        else
        {
            _selectedPOIs.Add(poi);
        }

        await RefreshRouteAsync();
    }

    private async Task RemovePOIAsync(POIDto poi)
    {
        _selectedPOIs.Remove(poi);
        await RefreshRouteAsync();
    }

    private async Task MovePOIAsync(POIDto poi, int direction)
    {
        var index = _selectedPOIs.IndexOf(poi);
        var newIndex = index + direction;

        if (newIndex < 0 || newIndex >= _selectedPOIs.Count)
        {
            return;
        }

        _selectedPOIs.RemoveAt(index);
        _selectedPOIs.Insert(newIndex, poi);
        await RefreshRouteAsync();
    }

    private async Task RefreshRouteAsync()
    {
        var routingPois = ActiveSelectedPOIs;
        _straightLineDistanceKm = CalculateStraightLineDistanceKm(routingPois);

        if (!_mapRendered)
        {
            return;
        }

        var routeInput = routingPois.Select((poi, index) => new
        {
            id = poi.Id,
            name = poi.Name,
            lat = poi.Latitude,
            lng = poi.Longitude,
            order = index + 1
        }).ToList();

        RouteRenderResult? result = null;

        try
        {
            result = await JS.InvokeAsync<RouteRenderResult>("renderTourPlannerMap", _mapElementId, routeInput);
        }
        catch (JSException ex)
        {
            Console.WriteLine($"Tour routing map error: {ex.Message}");
        }

        if (result != null)
        {
            _routingAvailable = result.UsedRouting;
            _straightLineDistanceKm = result.StraightDistanceKm;
            _model.DistanceKm = Math.Round(result.DistanceKm, 1);
            _model.EstimatedDurationMinutes = result.DurationMinutes;
        }
        else
        {
            _routingAvailable = false;
            _model.DistanceKm = Math.Round(_straightLineDistanceKm, 1);
            _model.EstimatedDurationMinutes = EstimateDurationFromDistance(_straightLineDistanceKm);
        }

        if (routingPois.Count < 2)
        {
            _model.DistanceKm = Math.Round(_straightLineDistanceKm, 1);
            _model.EstimatedDurationMinutes = 0;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task UploadImage(IBrowserFile file)
    {
        if (file == null)
        {
            return;
        }

        try
        {
            var format = string.IsNullOrWhiteSpace(file.ContentType) ? "image/png" : file.ContentType;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var base64 = Convert.ToBase64String(memoryStream.ToArray());
            _model.ImageUrl = $"data:{format};base64,{base64}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading image file: {ex.Message}");
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_isValid)
        {
            return;
        }

        _saving = true;

        try
        {
            if (IsEdit && Tour != null)
            {
                var updateDto = new UpdateTourDto
                {
                    Name = _model.Name,
                    Description = _model.Description,
                    EstimatedDurationMinutes = _model.EstimatedDurationMinutes,
                    DistanceKm = _model.DistanceKm,
                    ImageUrl = _model.ImageUrl,
                    Difficulty = _model.Difficulty,
                    POIIds = ActiveSelectedPOIs.Select(p => p.Id).ToList(),
                    IsActive = _model.IsActive
                };

                var result = await ApiService.UpdateTourAsync(Tour.Id, updateDto);
                if (result != null)
                {
                    MudDialog.Close(DialogResult.Ok(result));
                }
            }
            else
            {
                var createDto = new CreateTourDto
                {
                    Name = _model.Name,
                    Description = _model.Description,
                    EstimatedDurationMinutes = _model.EstimatedDurationMinutes,
                    DistanceKm = _model.DistanceKm,
                    ImageUrl = _model.ImageUrl,
                    Difficulty = _model.Difficulty,
                    POIIds = ActiveSelectedPOIs.Select(p => p.Id).ToList()
                };

                var result = await ApiService.CreateTourAsync(createDto);
                if (result != null)
                {
                    MudDialog.Close(DialogResult.Ok(result));
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private static string FormatDistance(double distanceKm) => distanceKm.ToString("0.0", CultureInfo.InvariantCulture);

    private static int EstimateDurationFromDistance(double distanceKm)
    {
        if (distanceKm <= 0)
        {
            return 0;
        }

        return (int)Math.Round((distanceKm / FallbackAverageSpeedKmPerHour) * 60d, MidpointRounding.AwayFromZero);
    }

    private static double CalculateStraightLineDistanceKm(IReadOnlyList<POIDto> pois)
    {
        if (pois.Count < 2)
        {
            return 0;
        }

        var total = 0d;
        for (var i = 1; i < pois.Count; i++)
        {
            total += HaversineDistanceKm(pois[i - 1].Latitude, pois[i - 1].Longitude, pois[i].Latitude, pois[i].Longitude);
        }

        return total;
    }

    private static double HaversineDistanceKm(double lat1, double lon1, double lat2, double lon2)
    {
        const double earthRadiusKm = 6371d;
        var dLat = DegreesToRadians(lat2 - lat1);
        var dLon = DegreesToRadians(lon2 - lon1);
        var a = Math.Pow(Math.Sin(dLat / 2), 2)
                + Math.Cos(DegreesToRadians(lat1)) * Math.Cos(DegreesToRadians(lat2)) * Math.Pow(Math.Sin(dLon / 2), 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return earthRadiusKm * c;
    }

    private static double DegreesToRadians(double value) => value * Math.PI / 180d;

