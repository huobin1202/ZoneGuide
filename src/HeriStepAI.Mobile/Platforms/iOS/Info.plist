	<string>HeriStepAI cần quyền truy cập vị trí để hiển thị các điểm tham quan gần bạn.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>HeriStepAI cần quyền truy cập vị trí để tự động thông báo khi bạn đến gần điểm tham quan.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>HeriStepAI sử dụng nhận dạng giọng nói để cải thiện trải nghiệm người dùng.</string>
</dict>
</plist>
