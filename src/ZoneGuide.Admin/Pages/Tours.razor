@page "/tours"
@inject IApiService ApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Class="pa-4 mb-4" Elevation="0" Outlined="true">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
       

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog"
                   Disabled="@(_isTourDialogOpening || _loading)"
                   Style="min-width:160px;">
            Tạo chuyến đi
        </MudButton>
    </MudStack>

    <MudStack Row="true" Spacing="2" Class="mt-4">
        <MudTextField @bind-Value="_searchString" Placeholder="Tim tour..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" Class="flex-grow-1" />
        <MudSelect T="string" Label="Trang thai" @bind-Value="_selectedStatus" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 170px;">
            <MudSelectItem Value="@( "Tat ca")" />
            <MudSelectItem Value="@( "Dang bat")" />
            <MudSelectItem Value="@( "Da tat")" />
        </MudSelect>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid Spacing="3">
        @foreach (var tour in FilteredTours)
        {
            <MudItem xs="12" sm="6" md="4" lg="3" xl="3">
                <MudPaper Outlined="true" Class="tour-card">
                    <div class="tour-card-media">
                        @{ var galleryImages = GetTourGalleryImages(tour).ToList(); }

                        @if (galleryImages.Any())
                        {
                            <div class="tour-gallery @(galleryImages.Count == 1 ? "tour-gallery-single" : string.Empty)">
                                @foreach (var imageUrl in galleryImages)
                                {
                                    <img src="@imageUrl" alt="@tour.Name" class="tour-card-image" />
                                }
                            </div>
                        }
                        else
                        {
                            <div class="tour-card-image tour-card-image-placeholder"></div>
                        }

                        <div class="tour-image-actions" aria-label="Thao tac tour">
                            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                           Size="Size.Small"
                                           Class="tour-image-action-btn"
                                           Disabled="@_isTourDialogOpening"
                                           OnClick="@(() => OpenEditDialog(tour))" />
                            <MudIconButton Icon="@(tour.IsActive ? Icons.Material.Outlined.Visibility : Icons.Material.Outlined.VisibilityOff)"
                                           Size="Size.Small"
                                           Class="tour-image-action-btn"
                                           OnClick="@(() => ToggleTourStatus(tour))" />
                        </div>

                        <div class="tour-meta-overlay" aria-label="Thong tin tour">
                            <span class="tour-meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                @FormatDuration(tour.EstimatedDurationMinutes)
                            </span>
                            <span class="tour-meta-item">
                                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Class="mr-1" />
                                @tour.POIIds.Count diem
                            </span>
                        </div>
                    </div>

                    <div class="tour-card-body">
                        <div class="tour-status-row">
                            <MudText Typo="Typo.subtitle2" Class="tour-name-ellipsis" title="@tour.Name">@tour.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(tour.IsActive ? Color.Success : Color.Default)">
                                @(tour.IsActive ? "Dang bat" : "Da tat")
                            </MudChip>
                        </div>

                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@TruncateText(tour.Description, 110)</MudText>
                    </div>
                </MudPaper>
            </MudItem>
        }

        <MudItem xs="12" sm="6" md="4" lg="3" xl="3">
            <MudPaper Outlined="true" Class="@($"tour-create-card {(_isTourDialogOpening ? "is-disabled" : string.Empty)}")" @onclick="OpenCreateDialog">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="fill-height" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h6" Class="mud-text-secondary">Them Tour moi</MudText>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (!FilteredTours.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            Khong tim thay tour phu hop voi tu khoa.
        </MudAlert>
    }
}

<style>
    .tour-card {
        border-radius: 16px;
        overflow: hidden;
        width: 100%;
        min-height: 282px;
    }

    .tour-card-image {
        width: 100%;
        height: 118px;
        object-fit: cover;
        display: block;
    }

    .tour-card-media {
        position: relative;
    }

    .tour-gallery {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0;
    }

    .tour-gallery-single {
        grid-template-columns: minmax(0, 1fr);
    }

    .tour-image-actions {
        position: absolute;
        top: 8px;
        right: 8px;
        display: inline-flex;
        gap: 6px;
    }

    .tour-image-action-btn {
        border: 1px solid #d7dde8;
        background: rgba(248, 249, 252, 0.95);
        border-radius: 999px;
    }

    .tour-meta-overlay {
        position: absolute;
        right: 8px;
        bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 10px;
        border-radius: 10px;
        background: rgba(88, 88, 88, 0.86);
        color: #fff;
        backdrop-filter: blur(2px);
        max-width: calc(100% - 20px);
    }

    .tour-meta-item {
        display: inline-flex;
        align-items: center;
        font-size: 0.75rem;
        line-height: 1.2;
        white-space: nowrap;
    }

    .tour-card-image-placeholder {
        background: linear-gradient(140deg, #23243b, #0f111c 60%, #3d3f5c);
    }

    .tour-card-body {
        margin-top: 10px;
        padding: 12px 14px 14px;
        background: #eef1f6;
    }

    .tour-name-ellipsis {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .tour-card-body .mud-typography-body2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .tour-status-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .tour-create-card {
        height: 100%;
        min-height: 282px;
        border-style: dashed;
        border-width: 2px;
        cursor: pointer;
        border-color: #d8dceb;
        width: 100%;
    }

    .tour-create-card.is-disabled {
        opacity: 0.6;
        pointer-events: none;
        cursor: default;
    }

    .fill-height {
        min-height: 282px;
    }
</style>

@code {
    private List<TourDto> _tours = new();
    private string _searchString = "";
    private string _selectedStatus = "Tat ca";
    private bool _loading = true;
    private bool _isTourDialogOpening;
    private List<POIDto>? _cachedDialogPois;
    private DateTime _cachedDialogPoisAtUtc;
    private static readonly TimeSpan DialogPoiCacheTtl = TimeSpan.FromMinutes(2);

    private IEnumerable<TourDto> FilteredTours => _tours
        .Where(t => string.IsNullOrWhiteSpace(_searchString) ||
            t.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
            (t.Description?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(t => _selectedStatus == "Tat ca" ||
                    (_selectedStatus == "Dang bat" && t.IsActive) ||
                    (_selectedStatus == "Da tat" && !t.IsActive));

    private static bool HasImage(TourDto tour)
    {
        return !string.IsNullOrWhiteSpace(tour.ImageUrl);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTours();
        _ = WarmupDialogPoisAsync();
    }

    private async Task LoadTours()
    {
        _loading = true;
        _tours = await ApiService.GetToursAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        if (_isTourDialogOpening)
        {
            return;
        }

        _isTourDialogOpening = true;
        try
        {
            var pois = await GetDialogPoisAsync();
            var parameters = new DialogParameters
            {
                { "Tour", null },
                { "IsEdit", false },
                { "AvailablePOIs", pois }
            };

            var dialog = await DialogService.ShowAsync<TourDialog>("Create New Tour", parameters,
                new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                await LoadTours();
                Snackbar.Add("Tour created successfully", Severity.Success);
            }
        }
        finally
        {
            _isTourDialogOpening = false;
        }
    }

    private async Task OpenEditDialog(TourDto tour)
    {
        if (_isTourDialogOpening)
        {
            return;
        }

        _isTourDialogOpening = true;
        try
        {
            var pois = await GetDialogPoisAsync();
            var parameters = new DialogParameters
            {
                { "Tour", tour },
                { "IsEdit", true },
                { "AvailablePOIs", pois }
            };

            var dialog = await DialogService.ShowAsync<TourDialog>("Edit Tour", parameters,
                new DialogOptions { MaxWidth = MaxWidth.ExtraLarge, FullWidth = true });
            var result = await dialog.Result;

            if (!result.Canceled)
            {
                await LoadTours();
                Snackbar.Add("Tour updated successfully", Severity.Success);
            }
        }
        finally
        {
            _isTourDialogOpening = false;
        }
    }

    private async Task<List<POIDto>> GetDialogPoisAsync()
    {
        var now = DateTime.UtcNow;
        if (_cachedDialogPois != null && now - _cachedDialogPoisAtUtc <= DialogPoiCacheTtl)
        {
            return _cachedDialogPois;
        }

        _cachedDialogPois = await ApiService.GetPOIsAsync();
        _cachedDialogPoisAtUtc = now;
        return _cachedDialogPois;
    }

    private async Task WarmupDialogPoisAsync()
    {
        try
        {
            await GetDialogPoisAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Warmup dialog POIs failed: {ex.Message}");
        }
    }

    private async Task ViewTourDetails(string tourId)
    {
        var tour = await ApiService.GetTourWithDetailsAsync(tourId);
        if (tour != null)
        {
            var parameters = new DialogParameters
            {
                { "Tour", tour }
            };

            await DialogService.ShowAsync<TourDetailsDialog>("Tour Details", parameters,
                new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        }
    }

    private async Task ToggleTourStatus(TourDto tour)
    {
        var willActivate = !tour.IsActive;
        var confirm = await DialogService.ShowMessageBox(
            "Cap nhat trang thai Tour",
            willActivate
                ? $"Ban co chac muon bat lai '{tour.Name}' khong?"
                : $"Ban co chac muon tat '{tour.Name}' khong?",
            yesText: "Xac nhan", cancelText: "Huy");

        if (confirm == true)
        {
            var updated = await ApiService.UpdateTourAsync(tour.Id, new UpdateTourDto
            {
                IsActive = willActivate
            });

            if (updated != null)
            {
                await LoadTours();
                Snackbar.Add(willActivate ? "Da bat Tour" : "Da tat Tour", Severity.Success);
            }
            else
            {
                Snackbar.Add("Khong the cap nhat trang thai Tour", Severity.Error);
            }
        }
    }

    private static IEnumerable<string> GetTourGalleryImages(TourDto tour)
    {
        var poiImages = (tour.POIs ?? new List<POIDto>())
            .Select(p => p.ImageUrl)
            .Where(url => !string.IsNullOrWhiteSpace(url))
            .Select(url => url!)
            .Distinct()
            .Take(3)
            .ToList();

        if (poiImages.Any())
        {
            return poiImages;
        }

        return HasImage(tour)
            ? new List<string> { tour.ImageUrl! }
            : Enumerable.Empty<string>();
    }

    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "N/A";
        return text.Length <= maxLength ? text : text.Substring(0, maxLength) + "...";
    }

    private string FormatDuration(int minutes)
    {
        if (minutes < 60) return $"{minutes} min";
        var hours = minutes / 60;
        var mins = minutes % 60;
        return mins > 0 ? $"{hours}h {mins}m" : $"{hours}h";
    }
}
