@page "/mobile-monitoring"
@inject IApiService ApiService
@inject IConfiguration Configuration
@implements IAsyncDisposable

@using Microsoft.AspNetCore.SignalR.Client
@using ZoneGuide.Shared.Models

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5">Live Monitoring Mobile App</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Theo dõi phiên app mobile đang hoạt động theo thời gian thực.
            </MudText>
        </MudStack>

        <MudChip T="string" Color="@(_connected ? Color.Success : Color.Warning)" Variant="Variant.Filled">
            @(_connected ? "LIVE" : "OFFLINE")
        </MudChip>
    </MudStack>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Phiên đang active</MudText>
                <MudText Typo="Typo.h4">@(_snapshot?.ActiveSessionCount ?? 0)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Đã đăng nhập</MudText>
                <MudText Typo="Typo.h4">@(_snapshot?.AuthenticatedSessionCount ?? 0)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Ẩn danh</MudText>
                <MudText Typo="Typo.h4">@(_snapshot?.AnonymousSessionCount ?? 0)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Đang tracking</MudText>
                <MudText Typo="Typo.h4">@(_snapshot?.TrackingSessionCount ?? 0)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-4 mt-4" Elevation="1">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
            <MudText Typo="Typo.h6">Danh sách phiên gần nhất</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetFooterText()</MudText>
        </MudStack>

        @if (_snapshot?.Sessions.Any() == true)
        {
            <MudTable Items="@_snapshot.Sessions" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Người dùng</MudTh>
                    <MudTh>Thiết bị</MudTh>
                    <MudTh>Vị trí</MudTh>
                    <MudTh>POI gần nhất</MudTh>
                    <MudTh>Trạng thái</MudTh>
                    <MudTh>Cập nhật</MudTh>
                </HeaderContent>
                <RowTemplate Context="session">
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@GetUserLabel(session)</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@GetUserSubLabel(session)</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@session.Platform</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@session.AppVersion</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@session.Latitude.ToString("F6"), @session.Longitude.ToString("F6")</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Accuracy: @session.Accuracy.ToString("F0") m</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.body2">@GetPoiLabel(session)</MudText>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="1">
                            <MudChip T="string"
                                     Color="@(session.IsTracking ? Color.Success : Color.Default)"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @(session.IsTracking ? "Tracking" : "Idle")
                            </MudChip>
                            @if (!string.IsNullOrWhiteSpace(session.StatusMessage))
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@session.StatusMessage</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@session.LastSeenAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@FormatAgo(session.LastSeenAtUtc)</MudText>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info">Chưa có session mobile nào đang hoạt động.</MudAlert>
        }
    </MudPaper>
}

@code {
    private MobileLiveMonitoringSnapshotDto? _snapshot;
    private HubConnection? _hubConnection;
    private bool _connected;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadSnapshotAsync();
        await InitializeRealtimeAsync();
    }

    private async Task LoadSnapshotAsync()
    {
        _loading = true;
        _snapshot = await ApiService.GetMobileMonitoringSnapshotAsync();
        _loading = false;
    }

    private async Task InitializeRealtimeAsync()
    {
        var apiBaseUrl = Configuration["ApiBaseUrl"] ?? "https://localhost:56040";
        var hubUrl = $"{apiBaseUrl.TrimEnd('/')}/hubs/mobile-monitor";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.Reconnecting += _ =>
        {
            _connected = false;
            return InvokeAsync(StateHasChanged);
        };

        _hubConnection.Reconnected += _ =>
        {
            _connected = true;
            return InvokeAsync(StateHasChanged);
        };

        _hubConnection.Closed += _ =>
        {
            _connected = false;
            return InvokeAsync(StateHasChanged);
        };

        _hubConnection.On<MobileLiveMonitoringSnapshotDto>("MobileMonitorUpdated", snapshot =>
        {
            _snapshot = snapshot;
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            _connected = true;
        }
        catch
        {
            _connected = false;
        }
    }

    private string GetFooterText()
    {
        if (_snapshot?.LastUpdatedAtUtc is not DateTime updatedAtUtc)
        {
            return "Chưa có heartbeat";
        }

        return $"Heartbeat gần nhất: {updatedAtUtc.ToLocalTime():dd/MM/yyyy HH:mm:ss}";
    }

    private static string GetUserLabel(MobileLiveSessionDto session)
    {
        if (!string.IsNullOrWhiteSpace(session.UserDisplayName))
            return session.UserDisplayName;

        return session.IsAuthenticated ? "Người dùng đã đăng nhập" : "Khách ẩn danh";
    }

    private static string GetUserSubLabel(MobileLiveSessionDto session)
    {
        if (!string.IsNullOrWhiteSpace(session.UserEmail))
            return session.UserEmail;

        return $"Device: {session.DeviceId}";
    }

    private static string GetPoiLabel(MobileLiveSessionDto session)
    {
        if (!string.IsNullOrWhiteSpace(session.NearestPoiName))
            return session.NearestPoiId.HasValue
                ? $"{session.NearestPoiName} (#{session.NearestPoiId.Value})"
                : session.NearestPoiName;

        return "Chưa xác định";
    }

    private static string FormatAgo(DateTime utcTime)
    {
        var age = DateTime.UtcNow - utcTime;
        if (age.TotalSeconds < 60)
            return $"{Math.Max(1, (int)age.TotalSeconds)} giây trước";
        if (age.TotalMinutes < 60)
            return $"{(int)age.TotalMinutes} phút trước";

        return $"{(int)age.TotalHours} giờ trước";
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
